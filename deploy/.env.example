COMPOSE_PROJECT_NAME=chatplus

# Domains
PUBLIC_DOMAIN=example.com
CMS_DOMAIN=cms.example.com
PUBLIC_SITE_URL=https://example.com
CMS_PUBLIC_URL=https://cms.example.com
PUBLIC_BASE_PATH=
# Absolute path to this repository on the VPS host. Keep it aligned with where you cloned the repo.
HOST_PROJECT_ROOT=/srv/chatplus
# Optional. Leave empty only if you intentionally accept Let's Encrypt registration without email.
LETSENCRYPT_EMAIL=ops@example.com

# Internal build/runtime URLs
STRAPI_INTERNAL_URL=http://strapi:1337
# Leave placeholder on the very first deploy.
# Fill STRAPI_API_TOKEN only after you open Strapi admin and create a full-access API token.
STRAPI_API_TOKEN=replace-with-strapi-api-token
RELAY_INTERNAL_URL=http://content-relay:8787/strapi/publish
WEBHOOK_TOKEN=replace-with-shared-relay-token
RELAY_PORT=8787
RELAY_DISPATCH_TARGET=local
RELAY_LOCAL_COMMAND=/srv/chatplus/deploy/scripts/build-portal.sh
GITHUB_ACTIONS_TOKEN=
GITHUB_REPOSITORY=owner/repo
GITHUB_DISPATCH_EVENT=strapi-content-publish
RELAY_ALLOWED_MODELS=landing-page,tenders-page,business-types-page,site-setting,competitor,solution,channel,industry,integration,feature,business-type

# Postgres
POSTGRES_DB=chatplus
POSTGRES_USER=chatplus
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_SCHEMA=public

# Strapi secrets
APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
API_TOKEN_SALT=replace-with-random-string
ADMIN_JWT_SECRET=replace-with-random-string
TRANSFER_TOKEN_SALT=replace-with-random-string
JWT_SECRET=replace-with-random-string
ENCRYPTION_KEY=replace-with-random-string

# Uploads/media storage.
# Server-first production default is local uploads on the VPS.
# Switch to aws-s3 later only if you intentionally migrate storage.
UPLOAD_PROVIDER=local
CDN_URL=
CDN_ROOT_PATH=
AWS_ACCESS_KEY_ID=
AWS_ACCESS_SECRET=
AWS_REGION=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_FORCE_PATH_STYLE=false
AWS_ACL=public-read
AWS_SIGNED_URL_EXPIRES=900
AWS_BUCKET_PUBLIC_URL=

# Backups
BACKUP_DIR=deploy/data/backups
BACKUP_KEEP_DAYS=7
