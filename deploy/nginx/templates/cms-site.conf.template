server {
    listen 80;
    server_name ${CMS_DOMAIN};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location = /__relay/strapi/publish {
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass http://content-relay:8787/strapi/publish;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name ${CMS_DOMAIN};

    ssl_certificate /etc/letsencrypt/live/${CMS_DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${CMS_DOMAIN}/privkey.pem;

    include /etc/nginx/snippets/ssl-params.conf;
    include /etc/nginx/snippets/strapi-proxy.conf;

    client_max_body_size 64m;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location = /__relay/strapi/publish {
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass http://content-relay:8787/strapi/publish;
    }

    location / {
        proxy_pass http://strapi:1337;
    }
}
