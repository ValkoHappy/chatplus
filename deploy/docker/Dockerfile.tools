FROM node:22-bookworm-slim

WORKDIR /workspace
ENV NODE_ENV=production

COPY package*.json ./
RUN npm ci \
  --fetch-retries=5 \
  --fetch-retry-factor=2 \
  --fetch-retry-mintimeout=20000 \
  --fetch-retry-maxtimeout=120000 \
  --fetch-timeout=300000

COPY config ./config
COPY cms ./cms
COPY scripts ./scripts

CMD ["sh"]
