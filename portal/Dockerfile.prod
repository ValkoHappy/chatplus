FROM node:22-bookworm-slim

WORKDIR /app/portal
ENV NODE_ENV=production

COPY portal/package*.json ./
RUN npm ci

COPY portal/. .
COPY config ../config
COPY cms ../cms
COPY scripts ../scripts

CMD ["sh", "-lc", "mkdir -p /portal-output/current && find /portal-output/current -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null || true && npm run build && cp -R dist/. /portal-output/current/"]
