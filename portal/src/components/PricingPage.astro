---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import InternalLinksSection from './InternalLinksSection.astro';
import FaqSection from './FaqSection.astro';
import type { InternalLinksContext, InternalLinksVariant } from '../lib/link-sections';
import { withBasePath } from '../lib/urls';

interface LinkItem {
  label?: string;
  href?: string;
  description?: string;
}

interface ComparisonRow {
  parameter?: string;
  option_one?: string;
  option_two?: string;
  chat_plus?: string;
}

interface PageData {
  meta_title: string;
  meta_description: string;
  h1: string;
  subtitle?: string;
  canonical?: string;
  hreflang_ru?: string;
  hreflang_uk?: string;
  hreflang_en?: string;
  hero_cta_primary_label?: string;
  hero_cta_primary_url?: string;
  hero_cta_secondary_label?: string;
  hero_cta_secondary_url?: string;
  hero_trust_facts?: string[];
  problem_title?: string;
  problem_intro?: string;
  problems?: { title?: string; text?: string }[];
  solution_title?: string;
  solution_intro?: string;
  solution_steps?: { title?: string; text?: string }[];
  integrations_title?: string;
  integration_blocks?: { label?: string; text?: string }[];
  roi_title?: string;
  roi_intro?: string;
  roi_without_items?: string[];
  roi_with_items?: string[];
  roi_quote?: string;
  use_cases_title?: string;
  use_cases?: { title?: string; audience?: string; text?: string }[];
  comparison_title?: string;
  comparison_rows?: ComparisonRow[];
  faq_title?: string;
  faqs?: { question?: string; answer?: string }[];
  internal_links_title?: string;
  internal_links_intro?: string;
  internal_links?: LinkItem[];
  internal_links_variant?: InternalLinksVariant;
  internal_links_context?: InternalLinksContext;
  sticky_cta_title?: string;
  sticky_cta_text?: string;
  sticky_cta_primary_label?: string;
  sticky_cta_primary_url?: string;
  sticky_cta_secondary_label?: string;
  sticky_cta_secondary_url?: string;
  faq_schema?: Record<string, any> | null;
}

const { page } = Astro.props as { page: PageData };
const faqSchema = page.faq_schema ? JSON.stringify(page.faq_schema) : '';
const pricingPlans = (page.integration_blocks || []).slice(0, 3);
const useCases = (page.use_cases || []).map((item) => ({
  title: item.title || item.audience || '',
  text: item.text || '',
}));
const toHref = (href?: string) => withBasePath(href);
const tierMeta = [
  {
    name: 'Pilot',
    price: '$49',
    period: '/ мес',
    note: 'Входной контур для запуска первой команды и первого рабочего сценария',
    cta: 'Запустить пилот',
    icon: 'lucide:rocket',
    kicker: 'Для запуска',
    accent: false,
    features: [
      '1 команда и базовый контур запуска',
      'Каналы, AI и первая автоматизация',
      'Подходит для пилота и первых 1–3 операторов',
    ],
  },
  {
    name: 'Growth',
    price: '$99',
    period: '/ мес',
    note: 'Рабочий тариф для команды 5–10 агентов с CRM, AI и омниканалом',
    cta: 'Рассчитать Growth',
    icon: 'lucide:layers-3',
    kicker: '',
    accent: true,
    features: [
      'Команда 5–10 агентов в одном контуре',
      'CRM, омниканал, AI и автоматизация без допов',
      'Прозрачная модель владения без скрытых доплат',
    ],
  },
  {
    name: 'Enterprise',
    price: 'индивидуально',
    period: '',
    note: 'Индивидуальный расчёт под SLA, безопасность и кастомную архитектуру',
    cta: 'Обсудить Enterprise',
    icon: 'lucide:shield-check',
    kicker: 'Для сложных контуров',
    accent: false,
    features: [
      'SLA и приоритетная поддержка',
      'Расширенная безопасность и управление доступами',
      'Кастомные интеграции и архитектурный контур',
    ],
  },
];

const pricingProofs = [
  {
    title: 'Без скрытых платежей',
    text: 'Фиксируем сценарий, роли и каналы до запуска, а не после первого счёта.',
    icon: 'lucide:badge-check',
  },
  {
    title: 'Без наценки на сообщения',
    text: 'Коммерческая модель строится вокруг платформы и процесса, а не штрафов за рост трафика.',
    icon: 'lucide:message-circle-more',
  },
  {
    title: 'Переход без пересборки стека',
    text: 'Можно начать с пилота и вырасти в полноценный контур без новой миграции.',
    icon: 'lucide:arrow-up-right',
  },
];

const pricingHighlights = [
  {
    label: 'Ценовой диапазон',
    value: '$49–$99 / мес',
    text: 'Входной и рабочий контур без искусственного раздувания счёта.',
    icon: 'lucide:badge-dollar-sign',
  },
  {
    label: 'Рабочий контур',
    value: '5–10 агентов',
    text: 'Нормальная команда продаж или поддержки без пересборки стека.',
    icon: 'lucide:users',
  },
  {
    label: 'Скрытые доплаты',
    value: '0',
    text: 'Без наценки на сообщения, роли и AI-нагрузку поверх сценария.',
    icon: 'lucide:shield-check',
  },
];
---

<Base title={page.meta_title} description={page.meta_description} canonical={page.canonical} hideGlobalStickyCta={Boolean(page.sticky_cta_title || page.sticky_cta_text)}>
  {page.hreflang_ru && <link slot="head" rel="alternate" hreflang="ru" href={page.hreflang_ru} />}
  {page.hreflang_uk && <link slot="head" rel="alternate" hreflang="uk" href={page.hreflang_uk} />}
  {page.hreflang_en && <link slot="head" rel="alternate" hreflang="en" href={page.hreflang_en} />}
  {faqSchema && <script slot="head" type="application/ld+json" set:html={faqSchema} />}

  <section class="hero">
    <div class="hero-glow"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Pricing</span>
        <h1>{page.h1}</h1>
        {page.subtitle && <p class="subtitle">{page.subtitle}</p>}
        <div class="hero-actions">
          {page.hero_cta_primary_label && page.hero_cta_primary_url && (
            <a href={toHref(page.hero_cta_primary_url)} class="btn-primary">{page.hero_cta_primary_label}</a>
          )}
          {page.hero_cta_secondary_label && page.hero_cta_secondary_url && (
            <a href={toHref(page.hero_cta_secondary_url)} class="btn-secondary">{page.hero_cta_secondary_label}</a>
          )}
        </div>
        {page.hero_trust_facts && page.hero_trust_facts.length > 0 && (
          <ul class="hero-facts">
            {page.hero_trust_facts.map((fact) => (
              <li>
                <Icon name="lucide:circle-check-big" class="fact-icon" />
                <span>{fact}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="hero-panel">
        <div class="hero-panel-header">
          <span>Модель цены</span>
          <strong>Прозрачный контур без скрытых доплат и искусственных add-on-модулей</strong>
        </div>
        <div class="hero-highlight-list">
          {pricingHighlights.map((item) => (
            <article class="hero-highlight-card">
              <div class="hero-highlight-top">
                <div class="hero-highlight-icon">
                  <Icon name={item.icon} />
                </div>
                <div>
                  <span class="hero-highlight-label">{item.label}</span>
                  <strong class="hero-highlight-value">{item.value}</strong>
                </div>
              </div>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  {pricingPlans.length > 0 && (
    <section class="section pricing-section">
      <div class="container">
        <div class="section-header pricing-header">
          <h2>Тарифные контуры Chat Plus</h2>
          <p>Три уровня входа: быстрый пилот, рабочий growth-контур и enterprise-модель для сложной архитектуры.</p>
        </div>
        <div class="pricing-grid">
          {pricingPlans.map((plan, index) => {
            const meta = tierMeta[index];
            return (
              <article class:list={['pricing-tier', meta?.accent && 'pricing-tier--accent']}>
                <div class="pricing-tier-top">
                  <div class="tier-chip">
                    <Icon name={meta?.icon || 'lucide:circle'} class="tier-icon" />
                    <span>{plan.label || meta?.name}</span>
                  </div>
                  {meta?.accent && <span class="tier-popular">Основной выбор</span>}
                </div>

                {meta?.kicker && <p class="tier-kicker">{meta.kicker}</p>}

                <div class="tier-price-wrap">
                  <div class="tier-price-line">
                    <strong class:list={['tier-price', meta?.name === 'Enterprise' && 'tier-price--compact']}>{meta?.price}</strong>
                    {meta?.period && <span class="tier-period">{meta.period}</span>}
                  </div>
                  <p class="tier-note">{meta?.note}</p>
                </div>

                <p class="tier-description">{plan.text}</p>

                <ul class="tier-features">
                  {(meta?.features || []).map((feature) => (
                    <li>
                      <Icon name="lucide:circle-check-big" class="tier-check" />
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>

                  <a href={toHref(page.hero_cta_primary_url || '/demo')} class:list={['tier-cta', meta?.accent && 'tier-cta--accent']}>
                  {meta?.cta}
                </a>
              </article>
            );
          })}
        </div>

        <div class="pricing-proof-row">
          {pricingProofs.map((item) => (
            <article class="pricing-proof-card">
              <div class="pricing-proof-icon">
                <Icon name={item.icon} />
              </div>
              <div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="pricing-bottom-cta">
          <div>
            <strong>Не знаете, какой контур нужен именно вам?</strong>
            <p>На демо соберём модель цены под вашу команду, каналы, AI-нагрузку и CRM-связки.</p>
          </div>
          <div class="pricing-bottom-actions">
          <a href={toHref(page.hero_cta_primary_url || '/demo')} class="btn-primary">Рассчитать стоимость</a>
          <a href={toHref(page.hero_cta_secondary_url || '/demo')} class="btn-secondary btn-secondary--dark">Получить демо</a>
          </div>
        </div>
      </div>
    </section>
  )}

  {page.problem_title && page.problems && page.problems.length > 0 && (
    <section class="section section-dark">
      <div class="container">
        <div class="section-header">
          <h2>{page.problem_title}</h2>
          {page.problem_intro && <p>{page.problem_intro}</p>}
        </div>
        <div class="problem-grid">
          {page.problems.map((item, index) => (
            <article class="problem-card">
              <span class="problem-index">0{index + 1}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.solution_title && page.solution_steps && page.solution_steps.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.solution_title}</h2>
          {page.solution_intro && <p>{page.solution_intro}</p>}
        </div>
        <div class="step-grid">
          {page.solution_steps.map((item, index) => (
            <article class="step-card">
              <div class="step-number">Шаг {index + 1}</div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.comparison_title && page.comparison_rows && page.comparison_rows.length > 0 && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.comparison_title}</h2>
          <p>Сравнение не про “дешевле любой ценой”, а про управляемую стоимость владения платформой.</p>
        </div>
        <div class="table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th>Параметр</th>
                <th>Seat / add-on платформа</th>
                <th>Контактная платформа</th>
                <th>Chat Plus</th>
              </tr>
            </thead>
            <tbody>
              {page.comparison_rows.map((row) => (
                <tr>
                  <td>{row.parameter}</td>
                  <td>{row.option_one}</td>
                  <td>{row.option_two}</td>
                  <td class="accent-cell">{row.chat_plus}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  {page.roi_title && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.roi_title}</h2>
          {page.roi_intro && <p>{page.roi_intro}</p>}
        </div>
        <div class="roi-grid">
          <article class="roi-card bad">
            <h3>Без Chat Plus</h3>
            <ul>{(page.roi_without_items || []).map((item) => <li>{item}</li>)}</ul>
          </article>
          <article class="roi-card good">
            <h3>С Chat Plus</h3>
            <ul>{(page.roi_with_items || []).map((item) => <li>{item}</li>)}</ul>
          </article>
        </div>
        {page.roi_quote && <blockquote class="quote">{page.roi_quote}</blockquote>}
      </div>
    </section>
  )}

  {page.use_cases_title && useCases.length > 0 && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.use_cases_title}</h2>
        </div>
        <div class="audience-grid">
          {useCases.map((item, index) => (
            <article class="audience-card">
              <div class="audience-icon">
                <Icon name={index === 0 ? 'lucide:briefcase-business' : index === 1 ? 'lucide:headset' : 'lucide:building-2'} />
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <FaqSection title={page.faq_title} faqs={page.faqs} />

  <InternalLinksSection page={page} />

  {(page.sticky_cta_title || page.sticky_cta_text) && (
    <section class="final-cta">
      <div class="container final-cta-inner">
        <div>
          {page.sticky_cta_title && <h2>{page.sticky_cta_title}</h2>}
          {page.sticky_cta_text && <p>{page.sticky_cta_text}</p>}
        </div>
        <div class="final-actions">
          {page.sticky_cta_primary_label && page.sticky_cta_primary_url && (
          <a href={toHref(page.sticky_cta_primary_url)} class="btn-primary light">{page.sticky_cta_primary_label}</a>
          )}
          {page.sticky_cta_secondary_label && page.sticky_cta_secondary_url && (
          <a href={toHref(page.sticky_cta_secondary_url)} class="btn-secondary light">{page.sticky_cta_secondary_label}</a>
          )}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .container{max-width:1120px;margin:0 auto;padding:0 clamp(1.25rem,4vw,2rem)}
  .section{padding:clamp(3rem,6vw,5rem) 0}
  .section-soft{background:#f8fafc}
  .section-dark{background:linear-gradient(180deg,#131a37 0%,#1a2146 100%);color:#fff}
  .section-header{max-width:760px;margin-bottom:2rem}
  .section-header h2{font-size:clamp(1.8rem,3vw,2.6rem);line-height:1.05;letter-spacing:-.04em}
  .section-header p{margin-top:.9rem;color:#5b677c;line-height:1.75}
  .section-dark .section-header p{color:#c8d0ea}
  .hero{position:relative;overflow:hidden;padding:clamp(3.5rem,7vw,5.5rem) 0;background:linear-gradient(180deg,#eff3ff 0%,#fff 100%)}
  .hero-glow{position:absolute;inset:0;background:radial-gradient(circle at 20% 15%,rgba(99,102,241,.17),transparent 24%),radial-gradient(circle at 90% 20%,rgba(14,165,233,.12),transparent 18%)}
  .hero-grid{position:relative;display:grid;grid-template-columns:minmax(0,1.1fr) minmax(320px,.9fr);gap:2rem;align-items:center}
  .eyebrow{display:inline-flex;padding:.45rem .8rem;border-radius:999px;background:#e0e7ff;color:#4338ca;font-weight:700;font-size:.8rem;margin-bottom:1rem}
  .hero-copy h1{font-size:clamp(2.5rem,5vw,4.5rem);line-height:.96;letter-spacing:-.06em;color:#0f172a;max-width:10ch}
  .subtitle{margin-top:1rem;max-width:58ch;color:#475569;font-size:1.05rem;line-height:1.8}
  .hero-actions,.final-actions,.pricing-bottom-actions{display:flex;gap:.85rem;flex-wrap:wrap;margin-top:1.5rem}
  .btn-primary,.btn-secondary{display:inline-flex;align-items:center;justify-content:center;min-height:46px;padding:.8rem 1.2rem;border-radius:12px;font-weight:700;text-decoration:none}
  .btn-primary{background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;box-shadow:0 14px 28px rgba(99,102,241,.18)}
  .btn-secondary{border:1px solid #cbd5e1;background:#fff;color:#0f172a}
  .btn-primary.light{background:#fff;color:#0f172a;box-shadow:none}
  .btn-secondary.light{border-color:rgba(255,255,255,.35);background:transparent;color:#fff}
  .hero-facts{display:grid;gap:.75rem;list-style:none;padding:0;margin:1.5rem 0 0}
  .hero-facts li{display:flex;gap:.65rem;align-items:flex-start;color:#334155;font-weight:600}
  .fact-icon{width:1rem;height:1rem;color:#4f46e5;flex-shrink:0;margin-top:.2rem}
  .hero-panel{background:rgba(255,255,255,.88);border:1px solid rgba(226,232,240,.9);border-radius:24px;padding:1.3rem;box-shadow:0 26px 60px rgba(15,23,42,.08);backdrop-filter:blur(10px)}
  .hero-panel-header{display:grid;gap:.3rem;padding-bottom:1rem;border-bottom:1px solid #e2e8f0}
  .hero-panel-header span{font-size:.82rem;font-weight:700;color:#6366f1;text-transform:uppercase;letter-spacing:.08em}
  .hero-panel-header strong{font-size:1.05rem;color:#0f172a;line-height:1.35}
  .hero-highlight-list{display:grid;gap:.85rem;margin-top:1rem}
  .hero-highlight-card{padding:.95rem 1rem;border-radius:18px;border:1px solid #e2e8f0;background:#fff}
  .hero-highlight-top{display:flex;align-items:center;gap:.85rem}
  .hero-highlight-icon{width:2.2rem;height:2.2rem;border-radius:12px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;background:#eef2ff;color:#4338ca}
  .hero-highlight-label{display:block;font-size:.76rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#64748b}
  .hero-highlight-value{display:block;margin-top:.15rem;font-size:1rem;line-height:1.1;color:#0f172a}
  .hero-highlight-card p{margin-top:.65rem;color:#516074;line-height:1.6}
  .pricing-section{padding-top:0}
  .pricing-header{max-width:720px}
  .pricing-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1.1rem}
  .pricing-tier{position:relative;display:flex;flex-direction:column;padding:1.45rem;border-radius:22px;border:1px solid #e2e8f0;background:linear-gradient(180deg,#fff 0%,#fbfcff 100%);box-shadow:0 18px 36px rgba(15,23,42,.05)}
  .pricing-tier--accent{border-color:#6366f1;background:linear-gradient(180deg,#f8f8ff 0%,#fff 100%);box-shadow:0 22px 44px rgba(99,102,241,.14)}
  .pricing-tier--accent:before{content:'';position:absolute;inset:0 0 auto 0;height:4px;border-radius:22px 22px 0 0;background:linear-gradient(90deg,#6366f1,#8b5cf6)}
  .pricing-tier-top{display:flex;align-items:center;justify-content:space-between;gap:1rem}
  .tier-chip{display:inline-flex;align-items:center;gap:.55rem;padding:.42rem .72rem;border-radius:999px;background:#eef2ff;color:#4338ca;font-size:.82rem;font-weight:700}
  .tier-icon{width:1rem;height:1rem}
  .tier-popular{display:inline-flex;padding:.32rem .6rem;border-radius:999px;background:#ede9fe;color:#5b21b6;font-size:.76rem;font-weight:700}
  .tier-kicker{margin-top:.95rem;color:#64748b;font-size:.8rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase}
  .tier-price-wrap{margin-top:.75rem}
  .tier-price-line{display:flex;align-items:flex-end;gap:.35rem}
  .tier-price{font-size:clamp(1.9rem,3vw,2.6rem);line-height:1;font-weight:800;letter-spacing:-.04em;color:#0f172a}
  .tier-price--compact{font-size:clamp(1.35rem,2.2vw,2rem);line-height:1.05}
  .tier-period{font-size:.9rem;color:#64748b;font-weight:700}
  .tier-note{margin-top:.48rem;color:#64748b;font-size:.92rem;line-height:1.55;min-height:2.9rem}
  .tier-description{margin-top:1rem;color:#475569;line-height:1.7;min-height:5.3rem}
  .tier-features{display:grid;gap:.7rem;list-style:none;padding:0;margin:1rem 0 0}
  .tier-features li{display:flex;gap:.6rem;align-items:flex-start;color:#334155}
  .tier-check{width:1rem;height:1rem;color:#4f46e5;flex-shrink:0;margin-top:.18rem}
  .tier-cta{display:inline-flex;align-items:center;justify-content:center;min-height:46px;margin-top:1.2rem;border-radius:12px;border:1px solid #cbd5e1;background:#fff;color:#0f172a;text-decoration:none;font-weight:700}
  .tier-cta--accent{background:linear-gradient(135deg,#6366f1,#4f46e5);border-color:transparent;color:#fff;box-shadow:0 14px 28px rgba(99,102,241,.18)}
  .pricing-proof-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;margin-top:1rem}
  .pricing-proof-card{display:flex;gap:.9rem;align-items:flex-start;padding:1rem 1.1rem;border-radius:18px;border:1px solid #e2e8f0;background:#fff;min-height:132px}
