---
// Inline SVG illustration: omnichannel chat interface mockup
---
<div class="illus-wrap" aria-hidden="true">
  <svg viewBox="0 0 500 370" fill="none" xmlns="http://www.w3.org/2000/svg" class="illus-svg">
    <defs>
      <linearGradient id="ig" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#833AB4"/>
        <stop offset="50%" stop-color="#E1306C"/>
        <stop offset="100%" stop-color="#FCAF45"/>
      </linearGradient>
      <linearGradient id="heroGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#6366f1" stop-opacity="0.08"/>
        <stop offset="100%" stop-color="#6366f1" stop-opacity="0"/>
      </linearGradient>
      <filter id="winShadow" x="-5%" y="-5%" width="115%" height="120%">
        <feDropShadow dx="0" dy="12" stdDeviation="20" flood-color="#1e1b4b" flood-opacity="0.14"/>
      </filter>
      <filter id="cardShadow" x="-10%" y="-20%" width="130%" height="160%">
        <feDropShadow dx="0" dy="6" stdDeviation="10" flood-color="#0f172a" flood-opacity="0.1"/>
      </filter>
      <clipPath id="winClip">
        <rect x="4" y="4" width="420" height="298" rx="14"/>
      </clipPath>
    </defs>

    <!-- ══ MAIN WINDOW ══ -->
    <rect x="4" y="4" width="420" height="298" rx="14" fill="white" filter="url(#winShadow)"/>
    <rect x="4" y="4" width="420" height="298" rx="14" fill="white" stroke="#e2e8f0" stroke-width="1.5"/>

    <!-- Title bar -->
    <rect x="4" y="4" width="420" height="42" rx="0" fill="#f8fafc" clip-path="url(#winClip)"/>
    <rect x="4" y="30" width="420" height="16" fill="#f8fafc"/>
    <line x1="4" y1="46" x2="424" y2="46" stroke="#e2e8f0" stroke-width="1"/>
    <!-- rounded top fix -->
    <rect x="4" y="4" width="420" height="26" rx="14" fill="#f8fafc"/>

    <!-- Traffic lights -->
    <circle cx="26" cy="25" r="5.5" fill="#ff5f57"/>
    <circle cx="43" cy="25" r="5.5" fill="#ffbd2e"/>
    <circle cx="60" cy="25" r="5.5" fill="#28ca41"/>

    <!-- Title bar right: channel pills -->
    <rect x="300" y="16" width="32" height="18" rx="9" fill="#dcfce7"/>
    <text x="316" y="28" font-family="Inter,system-ui,sans-serif" font-size="8" font-weight="700" fill="#16a34a" text-anchor="middle">WA</text>
    <rect x="337" y="16" width="32" height="18" rx="9" fill="#dbeafe"/>
    <text x="353" y="28" font-family="Inter,system-ui,sans-serif" font-size="8" font-weight="700" fill="#1d4ed8" text-anchor="middle">TG</text>
    <rect x="374" y="16" width="32" height="18" rx="9" fill="#fce7f3"/>
    <text x="390" y="28" font-family="Inter,system-ui,sans-serif" font-size="8" font-weight="700" fill="#be185d" text-anchor="middle">IG</text>

    <!-- ══ LEFT SIDEBAR ══ -->
    <rect x="4" y="46" width="144" height="256" fill="#fafafa" clip-path="url(#winClip)"/>
    <line x1="148" y1="46" x2="148" y2="302" stroke="#e2e8f0" stroke-width="1"/>

    <!-- Sidebar search -->
    <rect x="12" y="53" width="128" height="22" rx="11" fill="#f1f5f9"/>
    <text x="24" y="67" font-family="Inter,system-ui,sans-serif" font-size="9" fill="#94a3b8">Поиск...</text>

    <!-- ── CHAT ITEM 1: WhatsApp (active) ── -->
    <rect x="6" y="82" width="138" height="52" rx="8" fill="#eef2ff"/>
    <!-- WA circle -->
    <circle cx="24" cy="108" r="13" fill="#25D366"/>
    <text x="24" y="114" font-family="Inter,system-ui,sans-serif" font-size="9" font-weight="800" fill="white" text-anchor="middle">W</text>
    <text x="44" y="103" font-family="Inter,system-ui,sans-serif" font-size="9.5" font-weight="700" fill="#1e293b">Анна П.</text>
    <text x="44" y="116" font-family="Inter,system-ui,sans-serif" font-size="8.5" fill="#64748b">Как насчёт встречи?</text>
    <text x="136" y="103" font-family="Inter,system-ui,sans-serif" font-size="7.5" fill="#94a3b8" text-anchor="end">14:23</text>
    <rect x="127" y="109" width="15" height="11" rx="5.5" fill="#6366f1"/>
    <text x="134.5" y="118" font-family="Inter,system-ui,sans-serif" font-size="7" font-weight="700" fill="white" text-anchor="middle">3</text>

    <!-- ── CHAT ITEM 2: Telegram ── -->
    <rect x="6" y="138" width="138" height="52" rx="8" fill="transparent"/>
    <circle cx="24" cy="164" r="13" fill="#2AABEE"/>
    <text x="24" y="170" font-family="Inter,system-ui,sans-serif" font-size="9" font-weight="800" fill="white" text-anchor="middle">T</text>
    <text x="44" y="159" font-family="Inter,system-ui,sans-serif" font-size="9.5" font-weight="700" fill="#1e293b">Retail Bot</text>
    <text x="44" y="172" font-family="Inter,system-ui,sans-serif" font-size="8.5" fill="#64748b">Заявка обработана ✓</text>
    <text x="136" y="159" font-family="Inter,system-ui,sans-serif" font-size="7.5" fill="#94a3b8" text-anchor="end">14:18</text>

    <!-- ── CHAT ITEM 3: Instagram ── -->
    <rect x="6" y="194" width="138" height="52" rx="8" fill="transparent"/>
    <circle cx="24" cy="220" r="13" fill="url(#ig)"/>
    <rect x="18" y="214" width="12" height="12" rx="4" fill="none" stroke="white" stroke-width="1.4"/>
    <circle cx="24" cy="220" r="3" fill="none" stroke="white" stroke-width="1.4"/>
    <circle cx="31" cy="213" r="1.2" fill="white"/>
    <text x="44" y="215" font-family="Inter,system-ui,sans-serif" font-size="9.5" font-weight="700" fill="#1e293b">Цветочный</text>
    <text x="44" y="228" font-family="Inter,system-ui,sans-serif" font-size="8.5" fill="#64748b">Добрый день! Хотим...</text>
    <text x="136" y="215" font-family="Inter,system-ui,sans-serif" font-size="7.5" fill="#94a3b8" text-anchor="end">13:55</text>
    <rect x="127" y="221" width="15" height="11" rx="5.5" fill="#e1306c"/>
    <text x="134.5" y="230" font-family="Inter,system-ui,sans-serif" font-size="7" font-weight="700" fill="white" text-anchor="middle">1</text>

    <!-- ── CHAT ITEM 4: SMS ── -->
    <rect x="6" y="250" width="138" height="48" rx="8" fill="transparent"/>
    <circle cx="24" cy="274" r="13" fill="#8b5cf6"/>
    <text x="24" y="279" font-family="Inter,system-ui,sans-serif" font-size="7.5" font-weight="800" fill="white" text-anchor="middle">SMS</text>
    <text x="44" y="269" font-family="Inter,system-ui,sans-serif" font-size="9" font-weight="700" fill="#1e293b">+7 999 123-45-67</text>
    <text x="44" y="282" font-family="Inter,system-ui,sans-serif" font-size="8.5" fill="#64748b">Подтверждение брони</text>

    <!-- ══ CHAT PANEL ══ -->
    <!-- Chat header -->
    <rect x="148" y="46" width="276" height="44" fill="white" clip-path="url(#winClip)"/>
    <line x1="148" y1="90" x2="424" y2="90" stroke="#f1f5f9" stroke-width="1"/>
    <circle cx="170" cy="68" r="14" fill="#25D366"/>
    <text x="170" y="74" font-family="Inter,system-ui,sans-serif" font-size="9" font-weight="800" fill="white" text-anchor="middle">АП</text>
    <text x="192" y="63" font-family="Inter,system-ui,sans-serif" font-size="10" font-weight="700" fill="#0f172a">Анна Петрова</text>
    <circle cx="189" cy="73" r="3" fill="#22c55e"/>
    <text x="196" y="77" font-family="Inter,system-ui,sans-serif" font-size="8" fill="#22c55e">онлайн · WhatsApp</text>
    <!-- Tags -->
    <rect x="335" y="58" width="42" height="16" rx="8" fill="#f0fdf4"/>
    <text x="356" y="69" font-family="Inter,system-ui,sans-serif" font-size="7.5" fill="#16a34a" text-anchor="middle">Горячий</text>
    <rect x="381" y="58" width="34" height="16" rx="8" fill="#eef2ff"/>
    <text x="398" y="69" font-family="Inter,system-ui,sans-serif" font-size="7.5" fill="#4338ca" text-anchor="middle">Лид</text>

    <!-- Chat background -->
    <rect x="148" y="90" width="276" height="170" fill="#f8fafc" clip-path="url(#winClip)"/>

    <!-- Message 1: Customer -->
    <rect x="158" y="102" width="168" height="34" rx="10" fill="white" stroke="#e2e8f0" stroke-width="1"/>
    <text x="170" y="116" font-family="Inter,system-ui,sans-serif" font-size="9" fill="#0f172a">Привет! Интересует продукт,</text>
    <text x="170" y="129" font-family="Inter,system-ui,sans-serif" font-size="9" fill="#0f172a">расскажите подробнее</text>

    <!-- Message 2: AI response -->
    <rect x="280" y="148" width="132" height="60" rx="10" fill="#6366f1"/>
    <text x="292" y="163" font-family="Inter,system-ui,sans-serif" font-size="8.5" fill="white">Chat Plus объединяет</text>
    <text x="292" y="176" font-family="Inter,system-ui,sans-serif" font-size="8.5" fill="white">все каналы в одном</text>
    <text x="292" y="189" font-family="Inter,system-ui,sans-serif" font-size="8.5" fill="white">окне с AI 24/7 →</text>
    <!-- AI Badge -->
    <rect x="282" y="137" width="42" height="13" rx="6.5" fill="#4f46e5"/>
    <text x="303" y="147" font-family="Inter,system-ui,sans-serif" font-size="7.5" font-weight="700" fill="white" text-anchor="middle">✦ AI</text>

    <!-- Message 3: Customer -->
    <rect x="158" y="222" width="138" height="22" rx="8" fill="white" stroke="#e2e8f0" stroke-width="1"/>
    <text x="170" y="236" font-family="Inter,system-ui,sans-serif" font-size="9" fill="#0f172a">Хочу записаться на демо!</text>

    <!-- Typing indicator -->
    <rect x="282" y="254" width="60" height="22" rx="11" fill="#ede9fe"/>
    <circle cx="298" cy="265" r="3" fill="#8b5cf6"/>
    <circle cx="308" cy="265" r="3" fill="#8b5cf6" opacity="0.6"/>
    <circle cx="318" cy="265" r="3" fill="#8b5cf6" opacity="0.3"/>
    <text x="344" y="268" font-family="Inter,system-ui,sans-serif" font-size="8" fill="#7c3aed">AI...</text>

    <!-- Input bar -->
    <rect x="148" y="260" width="276" height="42" fill="white" clip-path="url(#winClip)"/>
    <line x1="148" y1="260" x2="424" y2="260" stroke="#e2e8f0" stroke-width="1"/>
    <rect x="158" y="270" width="188" height="22" rx="11" fill="#f1f5f9"/>
    <text x="170" y="284" font-family="Inter,system-ui,sans-serif" font-size="8.5" fill="#94a3b8">Написать...</text>
    <!-- Send btn -->
    <circle cx="404" cy="281" r="12" fill="#6366f1"/>
    <path d="M399,281 h9 M404,276 l4,5 -4,5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <!-- Emoji -->
    <circle cx="380" cy="281" r="10" fill="#f1f5f9"/>
    <text x="380" y="285" font-family="Inter,system-ui,sans-serif" font-size="11" text-anchor="middle" fill="#94a3b8">☺</text>

    <!-- ══ FLOATING STAT CARDS ══ -->

    <!-- Card: +35% конверсия (top-right, outside window) -->
    <rect x="390" y="0" width="108" height="52" rx="12" fill="white" stroke="#e2e8f0" stroke-width="1.5" filter="url(#cardShadow)"/>
    <text x="402" y="26" font-family="Inter,system-ui,sans-serif" font-size="17" font-weight="800" fill="#16a34a">+35%</text>
    <text x="402" y="40" font-family="Inter,system-ui,sans-serif" font-size="8" fill="#64748b">конверсия лидов</text>
    <circle cx="485" cy="27" r="10" fill="#f0fdf4"/>
    <path d="M482 29l3-3 3 3M485 26v6" stroke="#16a34a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>

    <!-- Card: AI 24/7 (bottom left, outside window) -->
    <rect x="0" y="310" width="110" height="52" rx="12" fill="white" stroke="#e2e8f0" stroke-width="1.5" filter="url(#cardShadow)"/>
    <circle cx="20" cy="336" r="14" fill="#eef2ff"/>
    <path d="M15 334h10v5h-10zM17 330h6v2h-6z" fill="#6366f1"/>
    <text x="42" y="329" font-family="Inter,system-ui,sans-serif" font-size="11" font-weight="800" fill="#0f172a">AI 24/7</text>
    <text x="42" y="342" font-family="Inter,system-ui,sans-serif" font-size="8" fill="#64748b">без участия команды</text>

    <!-- Card: 15 мин (bottom-right) -->
    <rect x="380" y="318" width="114" height="52" rx="12" fill="white" stroke="#e2e8f0" stroke-width="1.5" filter="url(#cardShadow)"/>
    <text x="392" y="342" font-family="Inter,system-ui,sans-serif" font-size="17" font-weight="800" fill="#6366f1">15 мин</text>
    <text x="392" y="356" font-family="Inter,system-ui,sans-serif" font-size="8" fill="#64748b">до первого запуска</text>
    <circle cx="481" cy="332" r="10" fill="#eef2ff"/>
    <path d="M482 327l-3 5h3l-1 5 4-6h-3z" fill="#6366f1"/>

    <!-- Connecting dots decoration (outside window top-left) -->
    <circle cx="460" cy="170" r="3" fill="#c7d2fe"/>
    <circle cx="472" cy="158" r="2" fill="#c7d2fe" opacity="0.6"/>
    <circle cx="480" cy="182" r="2" fill="#c7d2fe" opacity="0.4"/>
    <circle cx="468" cy="194" r="1.5" fill="#c7d2fe" opacity="0.3"/>
  </svg>
</div>

<style>
  .illus-wrap {
    position: relative;
    width: 100%;
    max-width: 520px;
    flex-shrink: 0;
  }
  .illus-svg {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (max-width: 900px) {
    .illus-wrap { max-width: 440px; margin: 0 auto; }
  }
</style>
