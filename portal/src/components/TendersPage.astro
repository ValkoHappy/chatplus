---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import InternalLinksSection from './InternalLinksSection.astro';
import type { InternalLinksContext, InternalLinksVariant } from '../lib/link-sections';
import { withBasePath } from '../lib/urls';

interface LinkItem {
  label?: string;
  href?: string;
  description?: string;
}

interface ComparisonRow {
  parameter?: string;
  option_one?: string;
  option_two?: string;
  chat_plus?: string;
}

interface PageData {
  meta_title: string;
  meta_description: string;
  h1: string;
  subtitle?: string;
  canonical?: string;
  hreflang_ru?: string;
  hreflang_uk?: string;
  hreflang_en?: string;
  hero_cta_primary_label?: string;
  hero_cta_primary_url?: string;
  hero_cta_secondary_label?: string;
  hero_cta_secondary_url?: string;
  hero_trust_facts?: string[];
  problem_title?: string;
  problem_intro?: string;
  problems?: { title?: string; text?: string }[];
  solution_title?: string;
  solution_intro?: string;
  solution_steps?: { title?: string; text?: string }[];
  features_title?: string;
  features?: { title?: string; text?: string }[];
  integrations_title?: string;
  integration_blocks?: { label?: string; text?: string }[];
  roi_title?: string;
  roi_intro?: string;
  roi_without_items?: string[];
  roi_with_items?: string[];
  roi_quote?: string;
  use_cases_title?: string;
  use_cases?: { title?: string; audience?: string; text?: string }[];
  comparison_title?: string;
  comparison_rows?: ComparisonRow[];
  faq_title?: string;
  faqs?: { question?: string; answer?: string }[];
  internal_links_title?: string;
  internal_links_intro?: string;
  internal_links?: LinkItem[];
  internal_links_variant?: InternalLinksVariant;
  internal_links_context?: InternalLinksContext;
  sticky_cta_title?: string;
  sticky_cta_text?: string;
  sticky_cta_primary_label?: string;
  sticky_cta_primary_url?: string;
  sticky_cta_secondary_label?: string;
  sticky_cta_secondary_url?: string;
  software_schema?: Record<string, any> | null;
  faq_schema?: Record<string, any> | null;
}

const { page } = Astro.props as { page: PageData };
const softwareSchema = page.software_schema ? JSON.stringify(page.software_schema) : '';
const faqSchema = page.faq_schema ? JSON.stringify(page.faq_schema) : '';
const useCases = (page.use_cases || []).map((item) => ({
  title: item.title || item.audience || '',
  text: item.text || '',
}));
const toHref = (href?: string) => withBasePath(href);
---

<Base title={page.meta_title} description={page.meta_description} canonical={page.canonical} hideGlobalStickyCta={Boolean(page.sticky_cta_title || page.sticky_cta_text)}>
  {page.hreflang_ru && <link slot="head" rel="alternate" hreflang="ru" href={page.hreflang_ru} />}
  {page.hreflang_uk && <link slot="head" rel="alternate" hreflang="uk" href={page.hreflang_uk} />}
  {page.hreflang_en && <link slot="head" rel="alternate" hreflang="en" href={page.hreflang_en} />}
  {softwareSchema && <script slot="head" type="application/ld+json" set:html={softwareSchema} />}
  {faqSchema && <script slot="head" type="application/ld+json" set:html={faqSchema} />}

  <section class="hero">
    <div class="hero-glow"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Tenders</span>
        <h1>{page.h1}</h1>
        {page.subtitle && <p class="subtitle">{page.subtitle}</p>}
        <div class="hero-actions">
          {page.hero_cta_primary_label && page.hero_cta_primary_url && (
            <a href={toHref(page.hero_cta_primary_url)} class="btn-primary">{page.hero_cta_primary_label}</a>
          )}
          {page.hero_cta_secondary_label && page.hero_cta_secondary_url && (
            <a href={toHref(page.hero_cta_secondary_url)} class="btn-secondary">{page.hero_cta_secondary_label}</a>
          )}
        </div>
        {page.hero_trust_facts && page.hero_trust_facts.length > 0 && (
          <ul class="hero-facts">
            {page.hero_trust_facts.map((fact) => (
              <li>
                <Icon name="lucide:badge-check" class="fact-icon" />
                <span>{fact}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="hero-panel">
        <div class="hero-window">
          <div class="window-top">
            <span>Тендерный поток</span>
            <strong>Релевантные закупки за секунды</strong>
          </div>
          <div class="window-list">
            <article class="window-item">
              <div class="item-meta">
                <span class="item-source">44-ФЗ · Медицинское оборудование</span>
                <span class="item-deadline">2 дня до дедлайна</span>
              </div>
              <p>Заказчик изменил документацию. AI выделил критичные пункты и поставил дедлайн в календарь.</p>
            </article>
            <article class="window-item">
              <div class="item-meta">
                <span class="item-source">223-ФЗ · IT-инфраструктура</span>
                <span class="item-deadline">Новая закупка</span>
              </div>
              <p>Тендер доставлен в Telegram отдела, карточка в CRM создана автоматически.</p>
            </article>
            <article class="window-item accent">
              <div class="accent-line">
                <Icon name="lucide:sparkles" />
                <span>AI отсёк нерелевантные закупки и показал только нужные кейсы</span>
              </div>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  {page.problem_title && page.problems && page.problems.length > 0 && (
    <section class="section section-dark">
      <div class="container">
        <div class="section-header">
          <h2>{page.problem_title}</h2>
          {page.problem_intro && <p>{page.problem_intro}</p>}
        </div>
        <div class="problem-grid">
          {page.problems.map((item, index) => (
            <article class="problem-card">
              <div class="problem-number">0{index + 1}</div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.solution_title && page.solution_steps && page.solution_steps.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.solution_title}</h2>
          {page.solution_intro && <p>{page.solution_intro}</p>}
        </div>
        <div class="steps-grid">
          {page.solution_steps.map((item, index) => (
            <article class="step-card">
              <div class="step-index">Шаг {index + 1}</div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.features_title && page.features && page.features.length > 0 && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.features_title}</h2>
        </div>
        <div class="feature-grid">
          {page.features.map((item, index) => (
            <article class="feature-card">
              <div class="feature-icon">
                <Icon name={index === 0 ? 'lucide:bell-ring' : index === 1 ? 'lucide:file-search-2' : index === 2 ? 'lucide:database-zap' : index === 3 ? 'lucide:calendar-clock' : 'lucide:chart-column-big'} />
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.integrations_title && page.integration_blocks && page.integration_blocks.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.integrations_title}</h2>
        </div>
        <div class="integration-grid">
          {page.integration_blocks.map((item, index) => (
            <article class="integration-card">
              <div class="integration-icon">
                <Icon name={index === 0 ? 'lucide:message-square-share' : index === 1 ? 'lucide:briefcase-business' : index === 2 ? 'lucide:database' : index === 3 ? 'lucide:calendar-days' : 'lucide:workflow'} />
              </div>
              <h3>{item.label}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.roi_title && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.roi_title}</h2>
          {page.roi_intro && <p>{page.roi_intro}</p>}
        </div>
        <div class="roi-grid">
          <article class="roi-card bad">
            <h3>Без Chat Plus</h3>
            <ul>{(page.roi_without_items || []).map((item) => <li>{item}</li>)}</ul>
          </article>
          <article class="roi-card good">
            <h3>С Chat Plus</h3>
            <ul>{(page.roi_with_items || []).map((item) => <li>{item}</li>)}</ul>
          </article>
        </div>
        {page.roi_quote && <blockquote class="quote">{page.roi_quote}</blockquote>}
      </div>
    </section>
  )}

  {page.use_cases_title && useCases.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.use_cases_title}</h2>
        </div>
        <div class="audience-grid">
          {useCases.map((item, index) => (
            <article class="audience-card">
              <div class="audience-icon">
                <Icon name={index === 0 ? 'lucide:briefcase-business' : index === 1 ? 'lucide:building-2' : index === 2 ? 'lucide:user-round' : index === 3 ? 'lucide:network' : 'lucide:landmark'} />
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.comparison_title && page.comparison_rows && page.comparison_rows.length > 0 && (
    <section class="section section-dark">
      <div class="container">
        <div class="section-header">
          <h2>{page.comparison_title}</h2>
          <p>Сравнение здесь про скорость реакции, управление дедлайнами и контроль тендерного процесса, а не только про уведомления.</p>
        </div>
        <div class="table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th>Параметр</th>
                <th>Email / агрегатор</th>
                <th>Мобильное приложение</th>
                <th>Chat Plus Tenders</th>
              </tr>
            </thead>
            <tbody>
              {page.comparison_rows.map((row) => (
                <tr>
                  <td>{row.parameter}</td>
                  <td>{row.option_one}</td>
                  <td>{row.option_two}</td>
                  <td class="accent-cell">{row.chat_plus}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  {page.faq_title && page.faqs && page.faqs.length > 0 && (
    <section class="section">
      <div class="container faq-container">
        <div class="section-header">
          <h2>{page.faq_title}</h2>
        </div>
        <div class="faq-list">
          {page.faqs.map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <InternalLinksSection page={page} />

  {(page.sticky_cta_title || page.sticky_cta_text) && (
    <section class="final-cta">
      <div class="container final-cta-inner">
        <div>
          {page.sticky_cta_title && <h2>{page.sticky_cta_title}</h2>}
          {page.sticky_cta_text && <p>{page.sticky_cta_text}</p>}
        </div>
        <div class="final-actions">
          {page.sticky_cta_primary_label && page.sticky_cta_primary_url && (
          <a href={toHref(page.sticky_cta_primary_url)} class="btn-primary light">{page.sticky_cta_primary_label}</a>
          )}
          {page.sticky_cta_secondary_label && page.sticky_cta_secondary_url && (
          <a href={toHref(page.sticky_cta_secondary_url)} class="btn-secondary light">{page.sticky_cta_secondary_label}</a>
          )}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .container{max-width:1120px;margin:0 auto;padding:0 clamp(1.25rem,4vw,2rem)}.section{padding:clamp(3rem,6vw,5rem) 0}.section-soft{background:#f8fafc}.section-dark{background:linear-gradient(180deg,#0f172a 0%,#1e1b4b 100%);color:#fff}.section-header{max-width:820px;margin-bottom:2rem}.section-header h2{font-size:clamp(1.8rem,3vw,2.7rem);line-height:1.05;letter-spacing:-.04em}.section-header p{margin-top:.9rem;color:#64748b;line-height:1.75}.section-dark .section-header p{color:#cbd5e1}.hero{position:relative;overflow:hidden;padding:clamp(3.5rem,7vw,5.8rem) 0;background:linear-gradient(135deg,#0f172a 0%,#1f2557 50%,#312e81 100%);color:#fff}.hero-glow{position:absolute;inset:0;background:radial-gradient(circle at 18% 18%,rgba(34,197,94,.12),transparent 18%),radial-gradient(circle at 82% 20%,rgba(99,102,241,.22),transparent 20%)}.hero-grid{position:relative;display:grid;grid-template-columns:minmax(0,1fr) minmax(340px,.95fr);gap:2rem;align-items:center}.eyebrow{display:inline-flex;padding:.45rem .8rem;border-radius:999px;background:rgba(255,255,255,.12);color:#c7d2fe;font-weight:700;font-size:.8rem;margin-bottom:1rem}.hero-copy h1{font-size:clamp(2.5rem,5vw,4.4rem);line-height:.95;letter-spacing:-.06em;max-width:12ch}.subtitle{margin-top:1rem;max-width:58ch;color:#dbe4ff;font-size:1.05rem;line-height:1.8}.hero-actions,.final-actions{display:flex;gap:.85rem;flex-wrap:wrap;margin-top:1.5rem}.btn-primary,.btn-secondary{display:inline-flex;align-items:center;justify-content:center;min-height:46px;padding:.8rem 1.2rem;border-radius:12px;font-weight:700;text-decoration:none}.btn-primary{background:#fff;color:#0f172a}.btn-secondary{border:1px solid rgba(255,255,255,.28);background:transparent;color:#fff}.btn-primary.light{background:#fff;color:#0f172a}.btn-secondary.light{border-color:rgba(255,255,255,.35);background:transparent;color:#fff}.hero-facts{display:grid;gap:.75rem;list-style:none;padding:0;margin:1.5rem 0 0}.hero-facts li{display:flex;gap:.65rem;align-items:flex-start;color:#dbe4ff;font-weight:600}.fact-icon{width:1rem;height:1rem;color:#86efac;flex-shrink:0;margin-top:.2rem}.hero-panel{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:24px;padding:1rem;backdrop-filter:blur(10px)}.hero-window{background:#fff;border-radius:18px;padding:1rem;color:#0f172a;box-shadow:0 24px 56px rgba(15,23,42,.2)}.window-top{display:grid;gap:.2rem;padding-bottom:.85rem;border-bottom:1px solid #e2e8f0}.window-top span{font-size:.82rem;font-weight:700;color:#6366f1;text-transform:uppercase;letter-spacing:.08em}.window-top strong{font-size:1.05rem}.window-list{display:grid;gap:.8rem;margin-top:1rem}.window-item{padding:.9rem;border-radius:14px;background:#f8fafc;border:1px solid #e2e8f0}.window-item p,.problem-card p,.step-card p,.feature-card p,.integration-card p,.audience-card p,.faq-item p,.link-desc,.roi-card li,.quote{line-height:1.7;color:#55657d}.item-meta{display:flex;justify-content:space-between;gap:1rem;align-items:center;font-size:.8rem;font-weight:700;margin-bottom:.45rem}.item-source{color:#0f172a}.item-deadline{color:#6366f1}.window-item.accent{background:#eef2ff}.accent-line{display:flex;gap:.6rem;align-items:flex-start;color:#4338ca;font-weight:700}.problem-grid,.steps-grid,.feature-grid,.integration-grid,.audience-grid,.links-grid{display:grid;gap:1rem}.problem-grid{grid-template-columns:repeat(4,minmax(0,1fr))}.problem-card{padding:1.2rem;border-radius:18px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.04)}.problem-number{display:inline-flex;margin-bottom:.7rem;color:#818cf8;font-weight:800;letter-spacing:.08em}.problem-card h3,.step-card h3,.feature-card h3,.integration-card h3,.audience-card h3{font-size:1.05rem;line-height:1.25}.problem-card p{color:#dbe4ff}.steps-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.step-card,.feature-card,.integration-card,.audience-card{padding:1.25rem;border-radius:20px;border:1px solid #e2e8f0;background:#fff}.step-index{display:inline-flex;padding:.35rem .6rem;border-radius:999px;background:#eef2ff;color:#4338ca;font-weight:700;font-size:.8rem;margin-bottom:.75rem}.feature-grid{grid-template-columns:repeat(5,minmax(0,1fr))}.feature-icon,.integration-icon,.audience-icon{width:2.6rem;height:2.6rem;border-radius:14px;display:inline-flex;align-items:center;justify-content:center;background:#eef2ff;color:#4338ca;margin-bottom:.8rem}.integration-grid{grid-template-columns:repeat(5,minmax(0,1fr))}.roi-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}.roi-card{padding:1.3rem;border-radius:20px}.roi-card.bad{background:#fff1f2;border:1px solid #fecdd3}.roi-card.good{background:#ecfdf5;border:1px solid #bbf7d0}.roi-card h3{margin-bottom:.8rem}.roi-card ul{list-style:none;padding:0;margin:0;display:grid;gap:.6rem}.quote{margin-top:1.2rem;padding:1rem 1.2rem;border-left:4px solid #6366f1;background:#fff;border-radius:0 14px 14px 0;font-style:italic}.audience-grid{grid-template-columns:repeat(5,minmax(0,1fr))}.faq-container{max-width:860px}.faq-list{display:grid;gap:.75rem}.faq-item{padding:1rem 1.1rem;border-radius:16px;border:1px solid #e2e8f0;background:#fff}.faq-item summary{cursor:pointer;font-weight:700;color:#0f172a}.faq-item p{margin-top:.75rem}.table-wrap{overflow:auto;border:1px solid rgba(255,255,255,.1);border-radius:20px;background:rgba(255,255,255,.04)}.compare-table{width:100%;border-collapse:collapse;min-width:780px}.compare-table th,.compare-table td{padding:1rem 1.1rem;text-align:left;border-bottom:1px solid rgba(255,255,255,.08);vertical-align:top}.compare-table thead th{font-size:.8rem;letter-spacing:.08em;color:#cbd5e1;text-transform:uppercase}.compare-table td:first-child{font-weight:700;color:#fff;width:22%}.compare-table td{color:#dbe4ff}.accent-cell{font-weight:700;color:#a5b4fc}.links-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.link-card{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;padding:1.1rem;border-radius:18px;border:1px solid #e2e8f0;background:#fff;color:inherit;text-decoration:none}.link-title{display:block;font-weight:800;color:#0f172a}.link-desc{display:block;margin-top:.25rem;font-size:.92rem}.link-arrow{width:1rem;height:1rem;color:#6366f1;flex-shrink:0;margin-top:.15rem}.final-cta{padding:clamp(3rem,6vw,4.5rem) 0;background:linear-gradient(135deg,#131a37 0%,#2d3272 100%);color:#fff}.final-cta-inner{display:flex;align-items:center;justify-content:space-between;gap:1.5rem}.final-cta h2{font-size:clamp(1.7rem,3vw,2.4rem);line-height:1.05;letter-spacing:-.04em}.final-cta p{margin-top:.9rem;max-width:60ch;color:#d8dff8;line-height:1.75}@media (max-width:1100px){.feature-grid,.integration-grid,.audience-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.problem-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.steps-grid{grid-template-columns:1fr}}@media (max-width:980px){.hero-grid,.roi-grid,.links-grid,.final-cta-inner{grid-template-columns:1fr;display:grid}.hero-copy h1{max-width:none}}@media (max-width:720px){.hero{padding:2.5rem 0}.hero-actions,.final-actions{flex-direction:column}.btn-primary,.btn-secondary{width:100%}.problem-grid,.feature-grid,.integration-grid,.audience-grid,.links-grid{grid-template-columns:1fr}}
</style>
