---
import BlockTable from '../blocks/BlockTable.astro';

const { section } = Astro.props as { section: Record<string, any> };
const rows = Array.isArray(section.rows) ? section.rows : [];
---

<BlockTable
  title={section.title}
  intro={section.intro}
  rows={rows}
  option_one_label={section.option_one_label}
  option_two_label={section.option_two_label}
  option_highlight_label={section.option_highlight_label}
  variant="comparison"
/>
