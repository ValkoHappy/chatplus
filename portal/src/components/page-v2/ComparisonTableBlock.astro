---
const { section } = Astro.props as { section: Record<string, any> };
const rows = Array.isArray(section.rows) ? section.rows : [];
---

{rows.length > 0 && (
  <section class="section section-tonal">
    <div class="container">
      {(section.title || section.intro) && (
        <div class="section-header">
          {section.title && <h2>{section.title}</h2>}
          {section.intro && <p>{section.intro}</p>}
        </div>
      )}
      <div class="pagev2-compare-wrap">
        <table class="pagev2-compare-table">
          <thead>
            <tr>
              <th>Parameter</th>
              <th>{section.option_one_label || 'Option one'}</th>
              <th>{section.option_two_label || 'Option two'}</th>
              <th class="pagev2-compare-table__accent-head">{section.option_highlight_label || 'Chat Plus'}</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr>
                <td class="pagev2-compare-table__param">{row.parameter}</td>
                <td>{row.option_one}</td>
                <td>{row.option_two}</td>
                <td class="pagev2-compare-table__accent-cell">{row.option_highlight}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
)}

<style>
  .pagev2-compare-wrap {
    overflow: auto;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    background: #fff;
  }

  .pagev2-compare-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 720px;
  }

  .pagev2-compare-table th,
  .pagev2-compare-table td {
    padding: 1rem 1.05rem;
    text-align: left;
    border-bottom: 1px solid #eef2f7;
    vertical-align: top;
  }

  .pagev2-compare-table thead th {
    color: #64748b;
    font-size: .78rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: #f8fafc;
  }

  .pagev2-compare-table__param {
    font-weight: 700;
    color: #0f172a;
    width: 24%;
  }

  .pagev2-compare-table__accent-head,
  .pagev2-compare-table__accent-cell {
    color: #4338ca;
    font-weight: 800;
  }
</style>
