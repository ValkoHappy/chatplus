---
const { section } = Astro.props as { section: Record<string, any> };
---

{section.quote && (
  <section class="section">
    <div class="container container-narrow">
      <article class="pagev2-testimonial">
        {section.title && <span class="pagev2-testimonial__eyebrow">{section.title}</span>}
        <blockquote>{section.quote}</blockquote>
        {(section.author || section.role) && (
          <footer>
            {section.author && <strong>{section.author}</strong>}
            {section.role && <span>{section.role}</span>}
          </footer>
        )}
      </article>
    </div>
  </section>
)}

<style>
  .pagev2-testimonial {
    display: grid;
    gap: .95rem;
    padding: 1.4rem;
    border-radius: 26px;
    background: linear-gradient(135deg, rgba(238, 242, 255, .92), rgba(255, 255, 255, .98));
    border: 1px solid rgba(165, 180, 252, .35);
    box-shadow: 0 18px 36px rgba(79, 70, 229, .08);
  }

  .pagev2-testimonial__eyebrow {
    color: #4f46e5;
    font-size: .74rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .pagev2-testimonial blockquote {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1.2rem, 2.4vw, 1.55rem);
    line-height: 1.6;
    letter-spacing: -.02em;
  }

  .pagev2-testimonial footer {
    display: grid;
    gap: .2rem;
    color: #475569;
  }

  .pagev2-testimonial strong {
    color: #0f172a;
  }
</style>
