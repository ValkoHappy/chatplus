---
import BlockFinalCta from '../blocks/BlockFinalCta.astro';

const { section } = Astro.props as { section: Record<string, any> };
---

<BlockFinalCta
  title={section.title}
  text={section.text}
  primary_label={section.primary_label}
  primary_url={section.primary_url}
  secondary_label={section.secondary_label}
  secondary_url={section.secondary_url}
  variant={section.variant || 'light'}
/>
