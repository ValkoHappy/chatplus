---
import { withBasePath } from '../../lib/urls';

const { section } = Astro.props as { section: Record<string, any> };
const links = Array.isArray(section.links) ? section.links : [];
const toHref = (href?: string) => withBasePath(href);
---

{links.length > 0 && (
  <section class="section section-tonal">
    <div class="container">
      {(section.title || section.intro) && (
        <div class="section-header">
          {section.title && <h2>{section.title}</h2>}
          {section.intro && <p>{section.intro}</p>}
        </div>
      )}
      <div class="pagev2-links">
        {links.map((link) => (
          <a href={toHref(link.href)} class="pagev2-link-card">
            <span class="pagev2-link-card__label">{link.label}</span>
            {link.description && <span class="pagev2-link-card__description">{link.description}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .pagev2-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .pagev2-link-card {
    display: grid;
    gap: .4rem;
    min-height: 110px;
    padding: 1rem 1.1rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, .96);
    border: 1px solid rgba(226, 232, 240, .95);
    box-shadow: 0 16px 30px rgba(15, 23, 42, .05);
    transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
  }

  .pagev2-link-card:hover {
    transform: translateY(-2px);
    border-color: rgba(99, 102, 241, .35);
    box-shadow: 0 20px 40px rgba(79, 70, 229, .1);
  }

  .pagev2-link-card__label {
    color: #0f172a;
    font-weight: 800;
    letter-spacing: -.02em;
  }

  .pagev2-link-card__description {
    color: #475569;
    line-height: 1.6;
  }
</style>
