---
import BlockLinkGrid from '../blocks/BlockLinkGrid.astro';

const { section } = Astro.props as { section: Record<string, any> };
const links = Array.isArray(section.links) ? section.links : [];
---

<BlockLinkGrid
  title={section.title}
  intro={section.intro}
  links={links}
  variant="related"
  showIcons={false}
  sectionClass="section section-tonal"
/>
