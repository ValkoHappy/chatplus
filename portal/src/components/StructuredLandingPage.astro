---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { getSiteSettings } from '../lib/strapi';
import NavigationGroupsSection from './NavigationGroupsSection.astro';
import InternalLinksSection from './InternalLinksSection.astro';
import FaqSection from './FaqSection.astro';
import ChatIllustration from './ChatIllustration.astro';
import type { InternalLinksContext, InternalLinksVariant, LinkItem, NavigationGroup } from '../lib/link-sections';
import { withBasePath } from '../lib/urls';

interface BreadcrumbItem {
  label?: string;
  href?: string;
}

interface PageData {
  meta_title: string;
  meta_description: string;
  h1: string;
  subtitle?: string;
  canonical?: string;
  hreflang_ru?: string;
  hreflang_uk?: string;
  hreflang_en?: string;
  hero_cta_primary_label?: string;
  hero_cta_primary_url?: string;
  hero_cta_secondary_label?: string;
  hero_cta_secondary_url?: string;
  hero_eyebrow?: string;
  hero_variant?: 'resource' | 'company' | 'campaign';
  hero_highlights_label?: string;
  hero_highlights?: string[];
  hero_trust_facts?: string[];
  problem_title?: string;
  problem_intro?: string;
  problems?: { title?: string; text?: string }[];
  problem_summary?: string;
  solution_title?: string;
  solution_intro?: string;
  solution_steps?: { title?: string; text?: string }[];
  features_title?: string;
  features?: { title?: string; text?: string }[];
  integrations_title?: string;
  integration_blocks?: { label?: string; text?: string }[];
  roi_title?: string;
  roi_intro?: string;
  roi_without_items?: string[];
  roi_with_items?: string[];
  roi_quote?: string;
  use_cases_title?: string;
  use_cases?: { title?: string; audience?: string; text?: string }[];
  comparison_title?: string;
  comparison_rows?: { parameter?: string; option_one?: string; option_two?: string; chat_plus?: string }[];
  faq_title?: string;
  faqs?: { question?: string; answer?: string }[];
  breadcrumbs?: BreadcrumbItem[];
  navigation_groups_title?: string;
  navigation_groups_intro?: string;
  navigation_groups?: NavigationGroup[];
  internal_links_title?: string;
  internal_links_intro?: string;
  internal_links?: LinkItem[];
  internal_links_variant?: InternalLinksVariant;
  internal_links_context?: InternalLinksContext;
  sticky_cta_title?: string;
  sticky_cta_text?: string;
  sticky_cta_primary_label?: string;
  sticky_cta_primary_url?: string;
  sticky_cta_secondary_label?: string;
  sticky_cta_secondary_url?: string;
  software_schema?: Record<string, any> | null;
  faq_schema?: Record<string, any> | null;
}

const { page } = Astro.props as { page: PageData };
const siteSettings = await getSiteSettings();
const labels = siteSettings?.page_templates?.shared?.structured_page || {};
const softwareSchema = page.software_schema ? JSON.stringify(page.software_schema) : '';
const faqSchema = page.faq_schema ? JSON.stringify(page.faq_schema) : '';
const toHref = (href?: string) => withBasePath(href);
---

<Base title={page.meta_title} description={page.meta_description} canonical={page.canonical} hideGlobalStickyCta={Boolean(page.sticky_cta_title || page.sticky_cta_text)}>
  {page.hreflang_ru && <link slot="head" rel="alternate" hreflang="ru" href={page.hreflang_ru} />}
  {page.hreflang_uk && <link slot="head" rel="alternate" hreflang="uk" href={page.hreflang_uk} />}
  {page.hreflang_en && <link slot="head" rel="alternate" hreflang="en" href={page.hreflang_en} />}
  {softwareSchema && <script slot="head" type="application/ld+json" set:html={softwareSchema} />}
  {faqSchema && <script slot="head" type="application/ld+json" set:html={faqSchema} />}

  <!-- HERO -->
  <section class="hero-section">
    <div class="hero-bg-dots"></div>
    <div class:list={['container', 'hero-grid', page.hero_variant && `hero-grid--${page.hero_variant}`]}>
      <div class="hero-inner">
        {page.breadcrumbs && page.breadcrumbs.length > 0 && (
          <nav class="breadcrumbs reveal" aria-label="Хлебные крошки">
            {page.breadcrumbs.map((item, index) => (
              <>
                {index > 0 && <span class="breadcrumbs-sep">/</span>}
                {item.href ? (
                <a href={toHref(item.href)} class="breadcrumbs-link">{item.label}</a>
                ) : (
                  <span class="breadcrumbs-current">{item.label}</span>
                )}
              </>
            ))}
          </nav>
        )}
        {page.hero_eyebrow && <span class="hero-eyebrow reveal">{page.hero_eyebrow}</span>}
        <h1 class="hero-h1 text-gradient reveal">{page.h1}</h1>
        {page.subtitle && <p class="hero-subtitle reveal delay-1">{page.subtitle}</p>}
        {(page.hero_cta_primary_label || page.hero_cta_secondary_label) && (
          <div class="hero-ctas reveal delay-2">
            {page.hero_cta_primary_label && page.hero_cta_primary_url && (
            <a href={toHref(page.hero_cta_primary_url)} class="btn-primary">{page.hero_cta_primary_label}</a>
            )}
            {page.hero_cta_secondary_label && page.hero_cta_secondary_url && (
            <a href={toHref(page.hero_cta_secondary_url)} class="btn-outline">{page.hero_cta_secondary_label}</a>
            )}
          </div>
        )}
        {page.hero_trust_facts && page.hero_trust_facts.length > 0 && (
          <ul class="hero-trust">
            {page.hero_trust_facts.map((fact) => (
              <li class="trust-item">
                <span class="trust-check">
                  <svg width="12" height="12" viewBox="0 0 12 12"><polyline points="2 6 5 9 10 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                {fact}
              </li>
            ))}
          </ul>
        )}
      </div>
      <div class="hero-visual animate-float reveal delay-3">
        <ChatIllustration />
        {page.hero_highlights && page.hero_highlights.length > 0 && (
          <aside class="hero-highlight-card">
            {page.hero_highlights_label && <span class="hero-highlight-label">{page.hero_highlights_label}</span>}
            <ul class="hero-highlight-list">
              {page.hero_highlights.map((item) => (
                <li class="hero-highlight-item">
                  <span class="hero-highlight-bullet"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </aside>
        )}
      </div>
    </div>
  </section>

  <!-- PROBLEMS -->
  {page.problem_title && (
    <section class="section section-dark">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">{page.problem_title}</h2>
          {page.problem_intro && <p class="section-intro">{page.problem_intro}</p>}
        </div>
        {page.problems && page.problems.length > 0 && (
          <div class="problems-grid">
            {page.problems.map((item, i) => (
              <article class="problem-card reveal">
                <div class="problem-num">{String(i + 1).padStart(2, '0')}</div>
                <div class="problem-content">
                  <h3 class="card-title text-white">{item.title}</h3>
                  {item.text && <p class="card-text text-soft">{item.text}</p>}
                </div>
              </article>
            ))}
          </div>
        )}
        {page.problem_summary && (
          <p class="problem-summary">{page.problem_summary}</p>
        )}
      </div>
    </section>
  )}

  <!-- SOLUTION STEPS -->
  {page.solution_title && page.solution_steps && page.solution_steps.length > 0 && (
    <section class="section section-tinted" id="solution">
      <div class="container steps-container">
        <div class="steps-left-sticky">
          <div class="section-header reveal">
            <h2 class="section-title">{page.solution_title}</h2>
            {page.solution_intro && <p class="section-intro">{page.solution_intro}</p>}
          </div>
        </div>
        <div class="steps-right-scroll">
          <div class="steps-list">
            {page.solution_steps.map((item, i) => (
              <article class="step-item reveal">
                <div class="step-num-wrap">
                  <div class="step-num">{i + 1}</div>
                  {i < (page.solution_steps?.length ?? 0) - 1 && <div class="step-line"></div>}
                </div>
                <div class="step-body">
                  <h3 class="step-title">{item.title}</h3>
                  <p class="card-text">{item.text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- FEATURES -->
  {page.features_title && (
    <section class="section">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">{page.features_title}</h2>
        </div>
        {page.features && page.features.length > 0 && (
          <div class="features-grid">
            {page.features.map((item, i) => {
              const icons = [
                'lucide:message-circle-more',
                'lucide:bot',
                'lucide:radio',
                'lucide:workflow',
                'lucide:briefcase-business',
                'lucide:chart-column-big',
                'lucide:webhook',
                'lucide:circle-check-big',
              ];
              const icon = icons[i % icons.length];
              return (
                <article class="feature-card reveal delay-1">
                  <div class="feature-icon-wrap">
                    <Icon name={icon} class="feature-icon" />
                  </div>
                  <div>
                    <h3 class="feature-title">{item.title}</h3>
                    {item.text && <p class="card-text-sm">{item.text}</p>}
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- INTEGRATIONS -->
  {page.integrations_title && (
    <section class="section section-tinted overflow-hidden">
      <div class="container">
        <div class="section-header reveal text-center">
          <h2 class="section-title">{page.integrations_title}</h2>
        </div>
        {page.integration_blocks && page.integration_blocks.length > 0 && (
          <div class="integrations-cloud reveal delay-1">
            {page.integration_blocks.map((item, i) => {
              const icons = ['lucide:plug', 'lucide:database', 'lucide:calendar-days', 'lucide:webhook', 'lucide:bot', 'lucide:briefcase-business'];
              const icon = icons[i % icons.length];
              return (
                <div class="integration-pill">
                  <div class="integration-icon-wrap">
                    <Icon name={icon} class="integration-icon" />
                  </div>
                  <span class="integration-label">{item.label}</span>
                </div>
              );
            })}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ROI -->
  {page.roi_title && (
    <section class="section">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">{page.roi_title}</h2>
          {page.roi_intro && <p class="section-intro">{page.roi_intro}</p>}
        </div>
        {(page.roi_without_items?.length || page.roi_with_items?.length) && (
          <div class="roi-grid">
            {page.roi_without_items && page.roi_without_items.length > 0 && (
              <article class="roi-card roi-card--bad">
                <div class="roi-card-header">
                  <span class="roi-icon roi-icon--bad">✕</span>
                  <h3 class="roi-card-title">{labels.roi_without_title || 'Без Chat Plus'}</h3>
                </div>
                <ul class="roi-list">
                  {page.roi_without_items.map((item) => <li class="roi-item">{item}</li>)}
                </ul>
              </article>
            )}
            {page.roi_with_items && page.roi_with_items.length > 0 && (
              <article class="roi-card roi-card--good">
                <div class="roi-card-header">
                  <span class="roi-icon roi-icon--good">✓</span>
                  <h3 class="roi-card-title">{labels.roi_with_title || 'С Chat Plus'}</h3>
                </div>
                <ul class="roi-list">
                  {page.roi_with_items.map((item) => <li class="roi-item">{item}</li>)}
                </ul>
              </article>
            )}
          </div>
        )}
        {page.roi_quote && (
          <blockquote class="roi-quote">
            <span class="roi-quote-mark">&ldquo;</span>
            {page.roi_quote}
          </blockquote>
        )}
      </div>
    </section>
  )}

  <!-- USE CASES -->
  {page.use_cases_title && (
    <section class="section section-tinted">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">{page.use_cases_title}</h2>
        </div>
        {page.use_cases && page.use_cases.length > 0 && (
          <div class="use-cases-grid">
            {page.use_cases.map((item, i) => {
              const icons = ['lucide:briefcase-business', 'lucide:headset', 'lucide:megaphone', 'lucide:building', 'lucide:store', 'lucide:users'];
              const icon = icons[i % icons.length];
              return (
                <article class="use-case-card">
                  <div class="use-case-head">
                    <div class="use-case-icon-wrap">
                      <Icon name={icon} class="use-case-icon" />
                    </div>
                    <h3 class="card-title">{item.title || item.audience}</h3>
                  </div>
                  <p class="card-text">{item.text}</p>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- COMPARISON TABLE -->
  {page.comparison_title && page.comparison_rows && page.comparison_rows.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">{page.comparison_title}</h2>
        </div>
        <div class="table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th>{labels.comparison_header_parameter || 'Параметр'}</th>
                <th>{labels.comparison_header_one || 'Вариант 1'}</th>
                <th>{labels.comparison_header_two || 'Вариант 2'}</th>
                <th class="table-accent">{labels.comparison_header_chat_plus || 'Chat Plus'}</th>
              </tr>
            </thead>
            <tbody>
              {page.comparison_rows.map((row) => (
                <tr>
                  <td class="table-param">{row.parameter}</td>
                  <td>{row.option_one}</td>
                  <td>{row.option_two}</td>
                  <td class="table-accent table-bold">{row.chat_plus}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <FaqSection title={page.faq_title} faqs={page.faqs} sectionClass="section section-tinted" containerClass="container container-narrow" />

  <NavigationGroupsSection page={page} />
  <InternalLinksSection page={page} />

  <!-- FINAL CTA -->
  {(page.sticky_cta_title || page.sticky_cta_text) && (
    <section class="cta-section">
      <div class="cta-bg"></div>
      <div class="container cta-inner">
        {page.sticky_cta_title && <h2 class="cta-title">{page.sticky_cta_title}</h2>}
        {page.sticky_cta_text && <p class="cta-text">{page.sticky_cta_text}</p>}
        {(page.sticky_cta_primary_label || page.sticky_cta_secondary_label) && (
          <div class="cta-buttons">
            {page.sticky_cta_primary_label && page.sticky_cta_primary_url && (
          <a href={toHref(page.sticky_cta_primary_url)} class="btn-white">{page.sticky_cta_primary_label}</a>
            )}
            {page.sticky_cta_secondary_label && page.sticky_cta_secondary_url && (
          <a href={toHref(page.sticky_cta_secondary_url)} class="btn-ghost">{page.sticky_cta_secondary_label}</a>
            )}
          </div>
        )}
      </div>
    </section>
  )}

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      // Reveal animation
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(e => {
          if(e.isIntersecting) {
            e.target.classList.add('revealed');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    });
  </script>
</Base>

<style>
  /* ── Typography cards ── */
  .card-text  { font-size: 0.95rem; color: #475569; line-height: 1.7; }
  .card-text-sm { font-size: 0.9rem; color: #475569; line-height: 1.65; }

  /* ── HERO (PREMIUM GLOW) ── */
  .hero-section {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 5vw, 4rem);
    background: linear-gradient(175deg, #0f172a 0%, #1a1040 55%, #0f172a 100%);
  }
  .hero-section::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 120px;
    background: linear-gradient(to bottom, transparent, #0f172a);
    pointer-events: none;
    z-index: 2;
  }
  .hero-bg-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(99, 102, 241, 0.4) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.25;
    pointer-events: none;
    z-index: 0;
  }
  .hero-bg-dots::before {
    content: '';
    position: absolute;
    top: -15%; left: -10%;
    width: 60%; height: 70%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
    filter: blur(60px);
    animation: float 8s infinite alternate ease-in-out;
  }
  .hero-bg-dots::after {
    content: '';
    position: absolute;
    bottom: -15%; right: -5%;
    width: 70%; height: 80%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.12) 0%, transparent 70%);
    filter: blur(80px);
    animation: float 12s infinite alternate-reverse ease-in-out;
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    z-index: 1;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: .35rem .8rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.16);
    color: #c7d2fe;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .breadcrumbs {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: #cbd5e1;
  }
  .breadcrumbs-link,
  .breadcrumbs-current {
    position: relative;
    z-index: 1;
  }
  .breadcrumbs-link {
    color: #e2e8f0;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .breadcrumbs-link:hover {
    color: #ffffff;
  }
  .breadcrumbs-current {
    color: #94a3b8;
  }
  .breadcrumbs-sep {
    color: rgba(148, 163, 184, 0.75);
  }
  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 0.5rem;
    position: relative;
  }
  .hero-visual::before {
    content: '';
    position: absolute;
    inset: 8% 0 auto 12%;
    height: 72%;
    border-radius: 32px;
    background: radial-gradient(circle, rgba(99, 102, 241, .25), transparent 68%);
    filter: blur(30px);
    pointer-events: none;
  }
  .hero-h1 {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: #94a3b8;
    line-height: 1.8;
    max-width: 90%;
  }
  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  .hero-trust {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
    padding: 0; margin: 1rem 0 0 0;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: #cbd5e1;
    font-weight: 500;
  }
  .trust-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #4f46e5);
    color: white;
    flex-shrink: 0;
    box-shadow: 0 4px 10px rgba(99, 102, 241, 0.2);
  }
  .hero-highlight-card {
    position: absolute;
    right: 0;
    bottom: 4%;
    width: min(280px, 78%);
    display: grid;
    gap: .9rem;
    padding: 1.1rem 1.1rem 1rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.72), rgba(15, 23, 42, 0.54));
    box-shadow: 0 20px 46px rgba(15, 23, 42, 0.28);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .hero-highlight-label {
    color: #c7d2fe;
    font-size: .73rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .hero-highlight-list {
    display: grid;
    gap: .55rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .hero-highlight-item {
    display: flex;
    align-items: flex-start;
    gap: .65rem;
    color: #e2e8f0;
    font-size: .9rem;
    line-height: 1.55;
  }
  .hero-highlight-bullet {
    display: inline-flex;
    width: 8px;
    height: 8px;
    margin-top: .45rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #818cf8, #a78bfa);
    flex-shrink: 0;
  }

  /* ── PROBLEMS ── */
  .problems-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 1.25rem;
  }
  .problem-card {
    display: flex;
    gap: 1.15rem;
    align-items: flex-start;
    padding: 1.5rem;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    border: 1px solid rgba(203, 213, 225, 0.92);
    border-radius: 20px;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.1);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }
  .problem-card:hover {
    background: linear-gradient(180deg, #ffffff 0%, #f5f7ff 100%);
    border-color: rgba(99, 102, 241, 0.32);
    transform: translateY(-4px);
    box-shadow: 0 26px 52px rgba(15, 23, 42, 0.12);
  }
  .problem-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 14px;
    background: #eef2ff;
    border: 1px solid #c7d2fe;
    font-size: 0.9rem;
    font-weight: 800;
