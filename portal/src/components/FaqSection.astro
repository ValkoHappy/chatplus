---
import BlockFaq from './blocks/BlockFaq.astro';

interface FaqItem {
  question?: string;
  answer?: string;
}

interface Props {
  title?: string;
  intro?: string;
  faqs?: FaqItem[];
  sectionClass?: string;
  containerClass?: string;
}

const {
  title,
  intro,
  faqs = [],
  sectionClass = 'section',
  containerClass = 'container',
} = Astro.props as Props;
---

<BlockFaq title={title} intro={intro} faqs={faqs} sectionClass={sectionClass} containerClass={containerClass} />
