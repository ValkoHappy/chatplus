---
interface FaqItem {
  question?: string;
  answer?: string;
}

interface Props {
  title?: string;
  faqs?: FaqItem[];
  sectionClass?: string;
  containerClass?: string;
}

const {
  title,
  faqs = [],
  sectionClass = 'section',
  containerClass = 'container faq-container',
} = Astro.props as Props;

const items = faqs.filter((item) => item?.question && item?.answer);
---

{title && items.length > 0 && (
  <section class={sectionClass}>
    <div class={containerClass}>
      <div class="section-header reveal">
        <h2>{title}</h2>
      </div>
      <div class="faq-list">
        {items.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{item.question}</span>
              <span class="faq-chevron" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </span>
            </summary>
            <div class="faq-body">
              <p class="faq-answer">{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .faq-list {
    display: grid;
    gap: 0.75rem;
  }

  .faq-item {
    display: grid;
    grid-template-rows: auto 0fr;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(226, 232, 240, 0.95);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.04);
    transition: border-color 0.22s ease, box-shadow 0.22s ease, grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item[open] {
    grid-template-rows: auto 1fr;
    border-color: rgba(129, 140, 248, 0.4);
    box-shadow: 0 18px 38px rgba(79, 70, 229, 0.08);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    font-weight: 700;
    font-size: 0.975rem;
    color: #0f172a;
    cursor: pointer;
    user-select: none;
    list-style: none;
    text-align: left;
    font-family: inherit;
  }

  .faq-question:hover {
    color: #6366f1;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-body {
    overflow: hidden;
  }

  .faq-answer {
    padding: 0 1.25rem 1.1rem;
    font-size: 0.92rem;
    color: #475569;
    line-height: 1.75;
  }

  .faq-chevron {
    flex-shrink: 0;
    color: #94a3b8;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), color 0.22s ease;
  }

  .faq-item[open] .faq-chevron {
    color: #6366f1;
    transform: rotate(180deg);
  }
</style>
