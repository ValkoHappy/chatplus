---
interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  align?: 'left' | 'center';
  className?: string;
}

const { eyebrow, title, intro, align = 'left', className = '' } = Astro.props as Props;
const classes = ['section-header', 'block-header', align === 'center' ? 'block-header--center' : '', className]
  .filter(Boolean)
  .join(' ');
---

{(eyebrow || title || intro) && (
  <div class={classes}>
    {eyebrow && <p class="block-header__eyebrow">{eyebrow}</p>}
    {title && <h2>{title}</h2>}
    {intro && <p>{intro}</p>}
  </div>
)}
