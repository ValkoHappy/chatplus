---
interface Props {
  title?: string;
  description?: string;
  icon?: string;
  href?: string;
  className?: string;
}

const { title, description, href, className = '' } = Astro.props as Props;
const classes = ['block-card', href ? 'block-card--interactive' : '', className].filter(Boolean).join(' ');
const Tag = href ? 'a' : 'div';
---

<Tag href={href} class={classes}>
  <slot />
  {title && <span class="block-card__label">{title}</span>}
  {description && <span class="block-card__description">{description}</span>}
</Tag>
