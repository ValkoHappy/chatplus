---
import BlockHeader from './BlockHeader.astro';

interface FaqItem {
  question?: string;
  answer?: string;
}

interface Props {
  title?: string;
  intro?: string;
  faqs?: FaqItem[];
  sectionClass?: string;
  containerClass?: string;
  variant?: 'default' | 'compact';
}

const {
  title,
  intro,
  faqs = [],
  sectionClass = 'section',
  containerClass = 'container block-faq__container',
  variant = 'default',
} = Astro.props as Props;

const technicalQuestions = new Set(['can this page be edited in strapi?']);
const technicalAnswers = new Set(['yes. the page record owns route, seo, sections and links.']);
const items = faqs
  .filter((item) => item?.question && item?.answer)
  .filter((item) => {
    const question = item.question?.trim().toLowerCase();
    const answer = item.answer?.trim().toLowerCase();
    return !technicalQuestions.has(question || '') && !technicalAnswers.has(answer || '');
  });
const resolvedTitle = title?.trim() || 'Частые вопросы';
const resolvedContainerClass = Array.from(
  new Set(`${containerClass} block-faq__container`.split(/\s+/).filter(Boolean)),
).join(' ');
const classes = [sectionClass, 'block-faq', `block-faq--${variant}`].filter(Boolean).join(' ');
---

{items.length > 0 && (
  <section class={classes}>
    <div class={resolvedContainerClass}>
      <BlockHeader title={resolvedTitle} intro={intro} />
      <div class="faq-list block-faq__list">
        {items.map((item) => (
          <details class="faq-item block-faq__item">
            <summary class="faq-question block-faq__question">
              <span>{item.question}</span>
              <span class="faq-chevron block-faq__chevron" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </span>
            </summary>
            <div class="faq-body block-faq__body">
              <p class="faq-answer block-faq__answer">{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}
