---
import { Icon } from 'astro-icon/components';
import {
  getLinkIcon,
  resolveInternalLinksEyebrow,
  resolveInternalLinksIntro,
  resolveInternalLinksTitle,
  type LinkItem,
  type LinkSectionPageData,
} from '../lib/link-sections';
import { withBasePath } from '../lib/urls';

interface Props {
  page: LinkSectionPageData;
}

const { page } = Astro.props as Props;
const links = (page.internal_links || []).filter((item: LinkItem) => item?.label && item?.href);
const title = resolveInternalLinksTitle(page);
const intro = resolveInternalLinksIntro(page);
const eyebrow = resolveInternalLinksEyebrow(page);
const toHref = (href?: string) => withBasePath(href);
---

{links.length > 0 && title && (
  <section class="link-section link-section--quiet">
    <div class="container">
      <div class="link-section-header">
        {eyebrow && <p class="link-section-eyebrow">{eyebrow}</p>}
        <h2 class="link-section-title">{title}</h2>
        {intro && <p class="link-section-intro">{intro}</p>}
      </div>

      <div class="link-section-grid">
        {links.map((item) => (
          <a href={toHref(item.href)} class="link-card">
            <div class="link-card-icon">
              <Icon name={getLinkIcon(item.href)} class="link-card-icon-svg" />
            </div>
            <div class="link-card-copy">
              <span class="link-card-title">{item.label}</span>
              {item.description && <span class="link-card-description">{item.description}</span>}
            </div>
            <Icon name="lucide:arrow-right" class="link-card-arrow" />
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .link-section {
    padding: clamp(2.8rem, 6vw, 4.5rem) 0;
  }

  .link-section--quiet {
    background:
      linear-gradient(180deg, rgba(248, 250, 252, 0.72) 0%, rgba(255, 255, 255, 0.96) 100%);
  }

  .link-section-header {
    max-width: 820px;
    margin-bottom: 1.7rem;
  }

  .link-section-eyebrow {
    margin: 0 0 0.55rem;
    color: #6366f1;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .link-section-title {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    line-height: 1.06;
    letter-spacing: -0.04em;
  }

  .link-section-intro {
    margin: 0.75rem 0 0;
    color: #64748b;
    font-size: 0.98rem;
    line-height: 1.7;
    max-width: 64ch;
  }

  .link-section-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .link-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.95rem;
    align-items: start;
    padding: 1.1rem 1.15rem;
    border-radius: 20px;
    border: 1px solid rgba(226, 232, 240, 0.9);
    background: rgba(255, 255, 255, 0.95);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 10px 26px rgba(15, 23, 42, 0.05);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .link-card:hover {
    transform: translateY(-2px);
    border-color: rgba(99, 102, 241, 0.22);
    box-shadow: 0 18px 36px rgba(15, 23, 42, 0.08);
  }

  .link-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 16px;
    background: linear-gradient(135deg, #eef2ff 0%, #ede9fe 100%);
    color: #4f46e5;
    flex-shrink: 0;
  }

  .link-card-icon-svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .link-card-copy {
    min-width: 0;
  }

  .link-card-title {
    display: block;
    color: #0f172a;
    font-size: 1.02rem;
    font-weight: 800;
    line-height: 1.24;
  }

  .link-card-description {
    display: -webkit-box;
    margin-top: 0.38rem;
    color: #64748b;
    font-size: 0.94rem;
    line-height: 1.58;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .link-card-arrow {
    width: 1.05rem;
    height: 1.05rem;
    color: #94a3b8;
    margin-top: 0.12rem;
    flex-shrink: 0;
  }

  @media (max-width: 980px) {
    .link-section-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
