---
import BlockLinkGrid from './blocks/BlockLinkGrid.astro';
import {
  getLinkIcon,
  resolveInternalLinksEyebrow,
  resolveInternalLinksIntro,
  resolveInternalLinksTitle,
  type LinkItem,
  type LinkSectionPageData,
} from '../lib/link-sections';

interface Props {
  page: LinkSectionPageData;
}

const { page } = Astro.props as Props;
const links = (page.internal_links || [])
  .filter((item: LinkItem) => item?.label && item?.href)
  .map((item: LinkItem) => ({
    ...item,
    icon: getLinkIcon(item.href),
  }));
const title = resolveInternalLinksTitle(page);
const intro = resolveInternalLinksIntro(page);
const eyebrow = resolveInternalLinksEyebrow(page);
---

{links.length > 0 && title && (
  <BlockLinkGrid
    eyebrow={eyebrow}
    title={title}
    intro={intro}
    links={links}
    variant="internal"
    sectionClass="link-section link-section--quiet"
  />
)}

<style>
  :global(.link-section) {
    padding: clamp(2.8rem, 6vw, 4.5rem) 0 clamp(4.6rem, 8vw, 6.5rem);
  }

  :global(.link-section--quiet) {
    background: linear-gradient(180deg, rgba(248, 250, 252, 0.72) 0%, rgba(255, 255, 255, 0.96) 100%);
  }
</style>
