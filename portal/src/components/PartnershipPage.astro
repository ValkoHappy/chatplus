---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import InternalLinksSection from './InternalLinksSection.astro';
import FaqSection from './FaqSection.astro';
import type { InternalLinksContext, InternalLinksVariant } from '../lib/link-sections';
import { withBasePath } from '../lib/urls';

interface LinkItem {
  label?: string;
  href?: string;
  description?: string;
}

interface ComparisonRow {
  parameter?: string;
  option_one?: string;
  option_two?: string;
  chat_plus?: string;
}

interface PageData {
  meta_title: string;
  meta_description: string;
  h1: string;
  subtitle?: string;
  canonical?: string;
  hero_eyebrow?: string;
  hreflang_ru?: string;
  hreflang_uk?: string;
  hreflang_en?: string;
  hero_cta_primary_label?: string;
  hero_cta_primary_url?: string;
  hero_cta_secondary_label?: string;
  hero_cta_secondary_url?: string;
  hero_trust_facts?: string[];
  problem_title?: string;
  problem_intro?: string;
  problems?: { title?: string; text?: string }[];
  solution_title?: string;
  solution_intro?: string;
  solution_steps?: { title?: string; text?: string }[];
  integrations_title?: string;
  integration_blocks?: { label?: string; text?: string }[];
  roi_title?: string;
  roi_intro?: string;
  roi_without_items?: string[];
  roi_with_items?: string[];
  roi_quote?: string;
  use_cases_title?: string;
  use_cases?: { title?: string; audience?: string; text?: string }[];
  comparison_title?: string;
  comparison_rows?: ComparisonRow[];
  faq_title?: string;
  faqs?: { question?: string; answer?: string }[]; 
  internal_links_title?: string;
  internal_links_intro?: string;
  internal_links?: LinkItem[];
  internal_links_variant?: InternalLinksVariant;
  internal_links_context?: InternalLinksContext;
  sticky_cta_title?: string;
  sticky_cta_text?: string;
  sticky_cta_primary_label?: string;
  sticky_cta_primary_url?: string;
  sticky_cta_secondary_label?: string;
  sticky_cta_secondary_url?: string;
  faq_schema?: Record<string, any> | null;
  section_labels?: Record<string, string>;
}

const { page } = Astro.props as { page: PageData };
const faqSchema = page.faq_schema ? JSON.stringify(page.faq_schema) : '';
const pillars = (page.integration_blocks || []).slice(0, 3);
const partnerTypes = (page.use_cases || []).map((item) => ({
  title: item.title || item.audience || '',
  text: item.text || '',
}));
const toHref = (href?: string) => withBasePath(href);
const sectionLabels = page.section_labels || {};
---

<Base title={page.meta_title} description={page.meta_description} canonical={page.canonical} hideGlobalStickyCta={Boolean(page.sticky_cta_title || page.sticky_cta_text)}>
  {page.hreflang_ru && <link slot="head" rel="alternate" hreflang="ru" href={page.hreflang_ru} />}
  {page.hreflang_uk && <link slot="head" rel="alternate" hreflang="uk" href={page.hreflang_uk} />}
  {page.hreflang_en && <link slot="head" rel="alternate" hreflang="en" href={page.hreflang_en} />}
  {faqSchema && <script slot="head" type="application/ld+json" set:html={faqSchema} />}

  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">{page.hero_eyebrow || sectionLabels.hero_eyebrow}</span>
        <h1>{page.h1}</h1>
        {page.subtitle && <p class="subtitle">{page.subtitle}</p>}
        <div class="hero-actions">
          {page.hero_cta_primary_label && page.hero_cta_primary_url && (
            <a href={toHref(page.hero_cta_primary_url)} class="btn-primary">{page.hero_cta_primary_label}</a>
          )}
          {page.hero_cta_secondary_label && page.hero_cta_secondary_url && (
            <a href={toHref(page.hero_cta_secondary_url)} class="btn-secondary">{page.hero_cta_secondary_label}</a>
          )}
        </div>
      </div>

      <div class="hero-side">
        <div class="stats-grid">
          {(page.hero_trust_facts || []).slice(0, 3).map((fact, index) => (
            <article class="stat-card">
              <div class="stat-icon">
                <Icon name={index === 0 ? 'lucide:badge-percent' : index === 1 ? 'lucide:users-round' : 'lucide:briefcase-business'} />
              </div>
              <p>{fact}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  {page.problem_title && page.problems && page.problems.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.problem_title}</h2>
          {page.problem_intro && <p>{page.problem_intro}</p>}
        </div>
        <div class="problem-grid">
          {page.problems.map((item) => (
            <article class="problem-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.integrations_title && pillars.length > 0 && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.integrations_title}</h2>
        </div>
        <div class="pillar-grid">
          {pillars.map((item, index) => (
            <article class="pillar-card">
              <div class="pillar-head">
                <div class="pillar-icon">
                  <Icon name={index === 0 ? 'lucide:handshake' : index === 1 ? 'lucide:files' : 'lucide:repeat'} />
                </div>
                <h3>{item.label}</h3>
              </div>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.solution_title && page.solution_steps && page.solution_steps.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.solution_title}</h2>
          {page.solution_intro && <p>{page.solution_intro}</p>}
        </div>
        <div class="timeline">
          {page.solution_steps.map((item, index) => (
            <article class="timeline-item">
              <div class="timeline-index">0{index + 1}</div>
              <div class="timeline-body">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.comparison_title && page.comparison_rows && page.comparison_rows.length > 0 && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.comparison_title}</h2>
          <p>{sectionLabels.comparison_intro}</p>
        </div>
        <div class="table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th>{sectionLabels.comparison_parameter}</th>
                <th>{sectionLabels.comparison_option_one}</th>
                <th>{sectionLabels.comparison_option_two}</th>
                <th>{sectionLabels.comparison_chat_plus}</th>
              </tr>
            </thead>
            <tbody>
              {page.comparison_rows.map((row) => (
                <tr>
                  <td>{row.parameter}</td>
                  <td>{row.option_one}</td>
                  <td>{row.option_two}</td>
                  <td class="accent-cell">{row.chat_plus}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  {page.use_cases_title && partnerTypes.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.use_cases_title}</h2>
        </div>
        <div class="partner-grid">
          {partnerTypes.map((item, index) => (
            <article class="partner-card">
              <div class="partner-icon">
                <Icon name={index === 0 ? 'lucide:megaphone' : index === 1 ? 'lucide:settings-2' : 'lucide:badge-dollar-sign'} />
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.roi_title && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.roi_title}</h2>
          {page.roi_intro && <p>{page.roi_intro}</p>}
        </div>
        <div class="roi-grid">
          <article class="roi-card bad">
            <h3>{sectionLabels.roi_without_title}</h3>
            <ul>{(page.roi_without_items || []).map((item) => <li>{item}</li>)}</ul>
          </article>
          <article class="roi-card good">
            <h3>{sectionLabels.roi_with_title}</h3>
            <ul>{(page.roi_with_items || []).map((item) => <li>{item}</li>)}</ul>
          </article>
        </div>
        {page.roi_quote && <blockquote class="quote">{page.roi_quote}</blockquote>}
      </div>
    </section>
  )}

  <FaqSection title={page.faq_title} faqs={page.faqs} />

  <InternalLinksSection page={page} />

  {(page.sticky_cta_title || page.sticky_cta_text) && (
    <section class="final-cta">
      <div class="container final-cta-inner">
        <div>
          {page.sticky_cta_title && <h2>{page.sticky_cta_title}</h2>}
          {page.sticky_cta_text && <p>{page.sticky_cta_text}</p>}
        </div>
        <div class="final-actions">
          {page.sticky_cta_primary_label && page.sticky_cta_primary_url && (
          <a href={toHref(page.sticky_cta_primary_url)} class="btn-primary light">{page.sticky_cta_primary_label}</a>
          )}
          {page.sticky_cta_secondary_label && page.sticky_cta_secondary_url && (
          <a href={toHref(page.sticky_cta_secondary_url)} class="btn-secondary light">{page.sticky_cta_secondary_label}</a>
          )}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .container{margin:0 auto;padding:0 clamp(1.25rem,4vw,2rem)}.section{padding:clamp(3rem,6vw,5rem) 0}.section-soft{background:#f8fafc}.section-dark{background:linear-gradient(180deg,#f8fafc 0%,#ffffff 100%);color:#0f172a}.section-header{max-width:760px;margin-bottom:2rem}.section-header h2{font-size:clamp(1.8rem,3vw,2.6rem);line-height:1.05;letter-spacing:-.04em}.section-header p{margin-top:.9rem;color:#64748b;line-height:1.75}.section-dark .section-header p{color:#475569}.hero{padding:clamp(3.5rem,7vw,5.5rem) 0;background:linear-gradient(135deg,#0f172a 0%,#302b63 58%,#3b82f6 100%);color:#fff}.hero-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.9fr);gap:2rem;align-items:center}.eyebrow{display:inline-flex;padding:.45rem .8rem;border-radius:999px;background:rgba(255,255,255,.12);color:#c7d2fe;font-weight:700;font-size:.8rem;margin-bottom:1rem}.hero-copy h1{font-size:clamp(2.5rem,5vw,4.2rem);line-height:.97;letter-spacing:-.06em;max-width:11ch}.subtitle{margin-top:1rem;max-width:58ch;color:#dbe4ff;font-size:1.05rem;line-height:1.8}.hero-actions,.final-actions{display:flex;gap:.85rem;flex-wrap:wrap;margin-top:1.5rem}.btn-primary,.btn-secondary{display:inline-flex;align-items:center;justify-content:center;min-height:46px;padding:.8rem 1.2rem;border-radius:12px;font-weight:700;text-decoration:none}.btn-primary{background:#fff;color:#0f172a}.btn-secondary{border:1px solid rgba(255,255,255,.25);background:transparent;color:#fff}.btn-primary.light{background:#fff;color:#0f172a}.btn-secondary.light{border-color:rgba(15,23,42,.14);background:#eef2ff;color:#1e293b}.btn-secondary.light:hover{background:#e0e7ff;border-color:rgba(99,102,241,.28);color:#111827}.stats-grid{display:grid;gap:.9rem}.stat-card{padding:1.1rem 1.15rem;border-radius:18px;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.18);backdrop-filter:blur(10px);box-shadow:0 18px 40px rgba(15,23,42,.16)}.stat-icon{width:2.6rem;height:2.6rem;border-radius:14px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.16);color:#fff;margin-bottom:.8rem}.stat-card p{line-height:1.7;color:#eef2ff;font-weight:600}.problem-card p,.pillar-card p,.timeline-body p,.partner-card p,.faq-item p,.link-desc,.roi-card li,.quote{line-height:1.7;color:#55657d}.problem-grid,.pillar-grid,.partner-grid,.links-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem}.problem-card,.pillar-card,.partner-card{padding:1.25rem;border-radius:20px;border:1px solid #e2e8f0;background:#fff}.problem-card h3,.pillar-card h3,.timeline-body h3,.partner-card h3{font-size:1.05rem;line-height:1.25}.pillar-head{display:flex;align-items:center;gap:.75rem;margin-bottom:.8rem}.pillar-icon,.partner-icon{width:2.6rem;height:2.6rem;border-radius:14px;display:inline-flex;align-items:center;justify-content:center;background:#eef2ff;color:#4338ca;flex-shrink:0}.timeline{display:grid;gap:1rem}.timeline-item{display:grid;grid-template-columns:auto 1fr;gap:1rem;align-items:start;padding:1.1rem 0;border-top:1px solid #e2e8f0}.timeline-item:last-child{border-bottom:1px solid #e2e8f0}.timeline-index{display:inline-flex;padding:.45rem .65rem;border-radius:999px;background:#eef2ff;color:#4338ca;font-weight:800;letter-spacing:.06em}.table-wrap{overflow:auto;border:1px solid #e2e8f0;border-radius:20px;background:#fff}.compare-table{width:100%;border-collapse:collapse;min-width:760px}.compare-table th,.compare-table td{padding:1rem 1.1rem;text-align:left;border-bottom:1px solid #eef2f7;vertical-align:top}.compare-table thead th{font-size:.8rem;letter-spacing:.08em;color:#64748b;text-transform:uppercase;background:#f8fafc}.compare-table td:first-child{font-weight:700;color:#0f172a;width:22%}.compare-table td{color:#475569}.accent-cell{font-weight:700;color:#4338ca;background:#f8faff}.roi-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}.roi-card{padding:1.3rem;border-radius:20px}.roi-card.bad{background:#fff1f2;border:1px solid #fecdd3}.roi-card.good{background:#ecfdf5;border:1px solid #bbf7d0}.roi-card h3{margin-bottom:.8rem}.roi-card ul{list-style:none;padding:0;margin:0;display:grid;gap:.6rem}.quote{margin-top:1.2rem;padding:1rem 1.2rem;border-left:4px solid #6366f1;background:#fff;border-radius:0 14px 14px 0;font-style:italic}.faq-container{max-width:820px}.faq-list{display:grid;gap:.75rem}.faq-item{padding:1rem 1.1rem;border-radius:16px;border:1px solid #e2e8f0;background:#fff}.faq-item summary{cursor:pointer;font-weight:700;color:#0f172a}.faq-item p{margin-top:.75rem}.links-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.link-card{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;padding:1.1rem;border-radius:18px;border:1px solid #e2e8f0;background:#fff;color:inherit;text-decoration:none}.link-title{display:block;font-weight:800;color:#0f172a}.link-desc{display:block;margin-top:.25rem;font-size:.92rem}.link-arrow{width:1rem;height:1rem;color:#6366f1;flex-shrink:0;margin-top:.15rem}.final-cta{padding:clamp(3rem,6vw,4.5rem) 0;background:linear-gradient(135deg,rgba(238,242,255,.92),rgba(255,255,255,.98));border-top:1px solid rgba(148,163,184,.08);color:#0f172a}.final-cta-inner{display:flex;align-items:center;justify-content:space-between;gap:1.5rem}.final-cta h2{font-size:clamp(1.7rem,3vw,2.4rem);line-height:1.05;letter-spacing:-.04em}.final-cta p{margin-top:.9rem;max-width:60ch;color:#475569;line-height:1.75}.final-cta .btn-primary.light{box-shadow:0 16px 34px rgba(99,102,241,.14)}@media (max-width:980px){.hero-grid,.problem-grid,.pillar-grid,.partner-grid,.roi-grid,.links-grid,.final-cta-inner{grid-template-columns:1fr;display:grid}.hero-copy h1{max-width:none}}@media (max-width:720px){.hero{padding:2.5rem 0}.hero-actions,.final-actions{flex-direction:column}.btn-primary,.btn-secondary{width:100%}}
</style>

