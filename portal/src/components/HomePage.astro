---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import ChatIllustration from './ChatIllustration.astro';
import InternalLinksSection from './InternalLinksSection.astro';
import FaqSection from './FaqSection.astro';
import type { InternalLinksContext, InternalLinksVariant } from '../lib/link-sections';
import { withBasePath } from '../lib/urls';

interface LinkItem {
  label?: string;
  href?: string;
  description?: string;
}

interface PageData {
  meta_title: string;
  meta_description: string;
  h1: string;
  subtitle?: string;
  canonical?: string;
  hero_eyebrow?: string;
  hreflang_ru?: string;
  hreflang_uk?: string;
  hreflang_en?: string;
  hero_cta_primary_label?: string;
  hero_cta_primary_url?: string;
  hero_cta_secondary_label?: string;
  hero_cta_secondary_url?: string;
  hero_trust_facts?: string[];
  proof_facts?: Array<string | { value?: string; label?: string; text?: string }>;
  problem_title?: string;
  problem_intro?: string;
  problems?: { title?: string; text?: string }[];
  solution_title?: string;
  solution_intro?: string;
  solution_steps?: { title?: string; text?: string }[];
  features_title?: string;
  features?: { title?: string; text?: string }[];
  integrations_title?: string;
  integration_blocks?: { label?: string; text?: string }[];
  roi_title?: string;
  roi_intro?: string;
  roi_without_items?: string[];
  roi_with_items?: string[];
  roi_quote?: string;
  use_cases_title?: string;
  use_cases?: { title?: string; audience?: string; text?: string }[];
  faq_title?: string;
  faqs?: { question?: string; answer?: string }[];
  internal_links_title?: string;
  internal_links_intro?: string;
  internal_links?: LinkItem[];
  internal_links_variant?: InternalLinksVariant;
  internal_links_context?: InternalLinksContext;
  sticky_cta_title?: string;
  sticky_cta_text?: string;
  sticky_cta_primary_label?: string;
  sticky_cta_primary_url?: string;
  sticky_cta_secondary_label?: string;
  sticky_cta_secondary_url?: string;
  section_labels?: Record<string, string>;
  software_schema?: Record<string, any> | null;
  faq_schema?: Record<string, any> | null;
}

const { page } = Astro.props as { page: PageData };
const softwareSchema = page.software_schema ? JSON.stringify(page.software_schema) : '';
const faqSchema = page.faq_schema ? JSON.stringify(page.faq_schema) : '';
const useCases = (page.use_cases || []).map((item) => ({
  title: item.title || item.audience || '',
  text: item.text || '',
}));
const toHref = (href?: string) => withBasePath(href);
const sectionLabels = page.section_labels || {};
const placeholderProofLabels = new Set(['proof point', 'home page proof']);

function normalizeProofFact(item: string | { value?: string; label?: string; text?: string }) {
  if (typeof item === 'string') {
    const [value, ...rest] = item.split('|').map((part) => part.trim()).filter(Boolean);
    return {
      value: value || '',
      label: rest.join(' | ') || '',
    };
  }

  return {
    value: item.value || '',
    label: item.label || item.text || '',
  };
}

const proofFactsSource =
  Array.isArray(page.proof_facts) && page.proof_facts.length > 0
    ? page.proof_facts
    : [];

const proofFacts = proofFactsSource
  .map(normalizeProofFact)
  .filter((item) => item.value || item.label)
  .filter((item) => !placeholderProofLabels.has(item.label.trim().toLowerCase()));
---

<Base title={page.meta_title} description={page.meta_description} canonical={page.canonical} hideGlobalStickyCta={Boolean(page.sticky_cta_title || page.sticky_cta_text)}>
  {page.hreflang_ru && <link slot="head" rel="alternate" hreflang="ru" href={page.hreflang_ru} />}
  {page.hreflang_uk && <link slot="head" rel="alternate" hreflang="uk" href={page.hreflang_uk} />}
  {page.hreflang_en && <link slot="head" rel="alternate" hreflang="en" href={page.hreflang_en} />}
  {softwareSchema && <script slot="head" type="application/ld+json" set:html={softwareSchema} />}
  {faqSchema && <script slot="head" type="application/ld+json" set:html={faqSchema} />}

  <section class="hero">
    <div class="hero-dots"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">{page.hero_eyebrow || sectionLabels.hero_eyebrow}</span>
        <h1>{page.h1}</h1>
        {page.subtitle && <p class="subtitle">{page.subtitle}</p>}
        <div class="hero-actions">
          {page.hero_cta_primary_label && page.hero_cta_primary_url && (
            <a href={toHref(page.hero_cta_primary_url)} class="btn-primary">{page.hero_cta_primary_label}</a>
          )}
          {page.hero_cta_secondary_label && page.hero_cta_secondary_url && (
            <a href={toHref(page.hero_cta_secondary_url)} class="btn-secondary">{page.hero_cta_secondary_label}</a>
          )}
        </div>
        {page.hero_trust_facts && page.hero_trust_facts.length > 0 && (
          <ul class="hero-facts">
            {page.hero_trust_facts.map((fact) => (
              <li>
                <Icon name="lucide:circle-check-big" class="fact-icon" />
                <span>{fact}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
      <div class="hero-visual">
        <ChatIllustration />
      </div>
    </div>
  </section>

  {proofFacts.length > 0 && (
    <section class="proof-bar">
      <div class="container proof-grid">
        {proofFacts.map((item) => (
          <article>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))}
      </div>
    </section>
  )}

  {page.problem_title && page.problems && page.problems.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.problem_title}</h2>
          {page.problem_intro && <p>{page.problem_intro}</p>}
        </div>
        <div class="problem-grid">
          {page.problems.map((item, index) => (
            <article class="problem-card">
              <div class="problem-index">0{index + 1}</div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.solution_title && page.solution_steps && page.solution_steps.length > 0 && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.solution_title}</h2>
          {page.solution_intro && <p>{page.solution_intro}</p>}
        </div>
        <div class="step-grid">
          {page.solution_steps.map((item, index) => (
            <article class="step-card">
              <div class="step-index">Шаг {index + 1}</div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.features_title && page.features && page.features.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.features_title}</h2>
        </div>
        <div class="feature-grid">
          {page.features.map((item, index) => (
            <article class="feature-card">
              <div class="feature-icon">
                <Icon name={index === 0 ? 'lucide:inbox' : index === 1 ? 'lucide:bot' : index === 2 ? 'lucide:send' : index === 3 ? 'lucide:workflow' : index === 4 ? 'lucide:database-zap' : 'lucide:chart-column-big'} />
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.integrations_title && page.integration_blocks && page.integration_blocks.length > 0 && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.integrations_title}</h2>
        </div>
        <div class="integration-grid">
          {page.integration_blocks.map((item, index) => (
            <article class="integration-card">
              <div class="integration-icon">
                <Icon name={index === 0 ? 'simple-icons:whatsapp' : index === 1 ? 'lucide:briefcase-business' : index === 2 ? 'lucide:database' : index === 3 ? 'lucide:workflow' : 'lucide:calendar-days'} />
              </div>
              <h3>{item.label}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {page.roi_title && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{page.roi_title}</h2>
          {page.roi_intro && <p>{page.roi_intro}</p>}
        </div>
        <div class="roi-grid">
          <article class="roi-card bad">
            <h3>{sectionLabels.roi_without_title}</h3>
            <ul>{(page.roi_without_items || []).map((item) => <li>{item}</li>)}</ul>
          </article>
          <article class="roi-card good">
            <h3>{sectionLabels.roi_with_title}</h3>
            <ul>{(page.roi_with_items || []).map((item) => <li>{item}</li>)}</ul>
          </article>
        </div>
        {page.roi_quote && <blockquote class="quote">{page.roi_quote}</blockquote>}
      </div>
    </section>
  )}

  {page.use_cases_title && useCases.length > 0 && (
    <section class="section section-soft">
      <div class="container">
        <div class="section-header">
          <h2>{page.use_cases_title}</h2>
        </div>
        <div class="use-case-grid">
          {useCases.map((item, index) => (
            <article class="use-case-card">
              <div class="use-case-icon">
                <Icon name={index === 0 ? 'lucide:megaphone' : index === 1 ? 'lucide:search' : 'lucide:files'} />
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <FaqSection title={page.faq_title} faqs={page.faqs} />

  <InternalLinksSection page={page} />

  {(page.sticky_cta_title || page.sticky_cta_text) && (
    <section class="final-cta">
      <div class="container final-cta-inner">
        <div>
          {page.sticky_cta_title && <h2>{page.sticky_cta_title}</h2>}
          {page.sticky_cta_text && <p>{page.sticky_cta_text}</p>}
        </div>
        <div class="final-actions">
          {page.sticky_cta_primary_label && page.sticky_cta_primary_url && (
            <a href={toHref(page.sticky_cta_primary_url)} class="btn-primary">{page.sticky_cta_primary_label}</a>
          )}
          {page.sticky_cta_secondary_label && page.sticky_cta_secondary_url && (
            <a href={toHref(page.sticky_cta_secondary_url)} class="btn-secondary">{page.sticky_cta_secondary_label}</a>
          )}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .container{margin:0 auto;padding:0 clamp(1.25rem,4vw,2rem)}.section{padding:clamp(3rem,6vw,5rem) 0}.section-soft{background:#f8fafc}.section-header{max-width:760px;margin-bottom:2rem}.section-header h2{font-size:clamp(1.8rem,3vw,2.7rem);line-height:1.03;letter-spacing:-.04em}.section-header p{margin-top:.9rem;color:#64748b;line-height:1.75}.hero{position:relative;overflow:hidden;padding:clamp(2.6rem,5.2vw,4.2rem) 0;background:linear-gradient(135deg,#0f172a 0%,#1f2557 55%,#312e81 100%);color:#fff}.hero-dots{position:absolute;inset:0;background-image:radial-gradient(rgba(199,210,254,.42) 1px,transparent 1px);background-size:28px 28px;opacity:.28}.hero-grid{position:relative;display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.9fr);gap:clamp(1.3rem,3vw,2rem);align-items:center}.eyebrow{display:inline-flex;padding:.4rem .75rem;border-radius:999px;background:rgba(255,255,255,.12);color:#c7d2fe;font-weight:700;font-size:.78rem;margin-bottom:.75rem}.hero-copy h1{font-size:clamp(2.5rem,4.7vw,4.25rem);line-height:.96;letter-spacing:-.065em;color:#fff;max-width:13ch}.subtitle{margin-top:.85rem;max-width:58ch;color:#dbe4ff;font-size:1.03rem;line-height:1.65}.hero-actions,.final-actions{display:flex;gap:.85rem;flex-wrap:wrap;margin-top:1.2rem}.btn-primary,.btn-secondary{display:inline-flex;align-items:center;justify-content:center;min-height:46px;padding:.8rem 1.2rem;border-radius:12px;font-weight:700;text-decoration:none}.btn-primary{background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;box-shadow:0 14px 28px rgba(99,102,241,.18)}.btn-secondary{border:1px solid #cbd5e1;background:#fff;color:#0f172a}.hero .btn-secondary{border:1px solid rgba(255,255,255,.25);background:transparent;color:#fff}.hero-facts{display:grid;gap:.55rem;list-style:none;padding:0;margin:1.15rem 0 0}.hero-facts li{display:flex;gap:.65rem;align-items:flex-start;color:#dbe4ff;font-weight:600}.fact-icon{width:1rem;height:1rem;color:#86efac;flex-shrink:0;margin-top:.2rem}.proof-bar{padding:1rem 0;background:#0f172a;color:#fff}.proof-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:1rem}.proof-grid article{display:grid;gap:.2rem;text-align:center}.proof-grid strong{font-size:1.6rem;letter-spacing:-.04em}.proof-grid span{color:#cbd5e1;font-size:.92rem}.problem-grid,.step-grid,.feature-grid,.integration-grid,.use-case-grid,.links-grid{display:grid;gap:1rem}.problem-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.problem-card,.step-card,.feature-card,.integration-card,.use-case-card{padding:1.25rem;border-radius:20px;border:1px solid #e2e8f0;background:#fff}.problem-index,.step-index{display:inline-flex;padding:.35rem .6rem;border-radius:999px;background:#eef2ff;color:#4338ca;font-weight:700;font-size:.8rem;margin-bottom:.75rem}.problem-card h3,.step-card h3,.feature-card h3,.integration-card h3,.use-case-card h3{font-size:1.05rem;line-height:1.25}.problem-card p,.step-card p,.feature-card p,.integration-card p,.use-case-card p,.faq-item p,.link-desc,.roi-card li,.quote{line-height:1.7;color:#55657d}.step-grid{grid-template-columns:repeat(4,minmax(0,1fr))}.feature-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.integration-grid{grid-template-columns:repeat(5,minmax(0,1fr))}.feature-icon,.integration-icon,.use-case-icon{width:2.6rem;height:2.6rem;border-radius:14px;display:inline-flex;align-items:center;justify-content:center;background:#eef2ff;color:#4338ca;margin-bottom:.8rem}.roi-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}.roi-card{padding:1.3rem;border-radius:20px}.roi-card.bad{background:#fff1f2;border:1px solid #fecdd3}.roi-card.good{background:#ecfdf5;border:1px solid #bbf7d0}.roi-card h3{margin-bottom:.8rem}.roi-card ul{list-style:none;padding:0;margin:0;display:grid;gap:.6rem}.quote{margin-top:1.2rem;padding:1rem 1.2rem;border-left:4px solid #6366f1;background:#f8fafc;border-radius:0 14px 14px 0;font-style:italic}.use-case-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.faq-container{max-width:860px}.faq-list{display:grid;gap:.75rem}.faq-item{padding:1rem 1.1rem;border-radius:16px;border:1px solid #e2e8f0;background:#fff}.faq-item summary{cursor:pointer;font-weight:700;color:#0f172a}.faq-item p{margin-top:.75rem}.links-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.link-card{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;padding:1.1rem;border-radius:18px;border:1px solid #e2e8f0;background:#fff;color:inherit;text-decoration:none}.link-title{display:block;font-weight:800;color:#0f172a}.link-desc{display:block;margin-top:.25rem;font-size:.92rem}.link-arrow{width:1rem;height:1rem;color:#6366f1;flex-shrink:0;margin-top:.15rem}.final-cta{padding:clamp(3rem,6vw,4.5rem) 0;background:linear-gradient(135deg,rgba(238,242,255,.92),rgba(255,255,255,.98));border-top:1px solid rgba(148,163,184,.08);color:#0f172a}.final-cta-inner{display:flex;align-items:center;justify-content:space-between;gap:1.5rem}.final-cta h2{font-size:clamp(1.7rem,3vw,2.4rem);line-height:1.05;letter-spacing:-.04em}.final-cta p{margin-top:.9rem;max-width:60ch;color:#475569;line-height:1.75}@media (max-width:1100px){.integration-grid,.step-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media (max-width:980px){.hero-grid,.proof-grid,.problem-grid,.feature-grid,.integration-grid,.roi-grid,.use-case-grid,.links-grid,.final-cta-inner{grid-template-columns:1fr;display:grid}.hero-copy h1{max-width:none}}@media (max-width:720px){.hero{padding:2.7rem 0}.hero-actions,.final-actions{flex-direction:column}.btn-primary,.btn-secondary{width:100%}}
</style>

