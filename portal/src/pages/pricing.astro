---
import PageV2Page from '../components/PageV2Page.astro';
import PricingPage from '../components/PricingPage.astro';
import { getLandingPage, getManagedRoutePage } from '../lib/strapi';

const resolved = await getManagedRoutePage('/pricing', () => getLandingPage('pricing'));
---

{resolved.kind === 'page_v2' ? <PageV2Page page={resolved.page} /> : <PricingPage page={resolved.page} />}
