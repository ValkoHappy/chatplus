---
import StructuredLandingPage from '../../components/StructuredLandingPage.astro';
import { adaptSolutionPage } from '../../lib/page-adapters';
import { getChannels, getIndustries, getIntegrations, getSiteSettings, getSolutions } from '../../lib/strapi';

export async function getStaticPaths() {
  const solutions = await getSolutions();
  return solutions
    .filter((solution) => solution.slug !== 'tenders')
    .map((solution) => ({
      params: { slug: solution.slug },
      props: { solution },
    }));
}

const { solution } = Astro.props;
const [settings, channels, industries, integrations, solutions] = await Promise.all([
  getSiteSettings(),
  getChannels(),
  getIndustries(),
  getIntegrations(),
  getSolutions(),
]);
const page = adaptSolutionPage(solution, { settings, channels, industries, integrations, solutions });
---

<StructuredLandingPage page={page} />
