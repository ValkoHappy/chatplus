---
import DirectoryPage from '../../components/DirectoryPage.astro';
import { adaptDirectoryPage } from '../../lib/page-adapters';
import { getManagedRoutePageForLegacyRenderer, getSiteSettings, getSolutions } from '../../lib/strapi';

const page = await getManagedRoutePageForLegacyRenderer('/solutions', async () => {
  const [settings, solutions] = await Promise.all([getSiteSettings(), getSolutions()]);
  return adaptDirectoryPage('solutions', settings, solutions);
}, 'directory');
---

<DirectoryPage {...page} />
