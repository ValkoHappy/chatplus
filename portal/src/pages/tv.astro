---
import PageV2Page from '../components/PageV2Page.astro';
import BrandContentPage from '../components/BrandContentPage.astro';
import { getLandingPage, getManagedRoutePage } from '../lib/strapi';

const resolved = await getManagedRoutePage('/tv', () => getLandingPage('tv'));
---

{resolved.kind === 'page_v2' ? <PageV2Page page={resolved.page} /> : <BrandContentPage page={resolved.page} />}
