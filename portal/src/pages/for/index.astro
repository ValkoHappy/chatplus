---
import DirectoryPage from '../../components/DirectoryPage.astro';
import { adaptDirectoryPage } from '../../lib/page-adapters';
import { getBusinessTypes, getManagedRoutePageForLegacyRenderer, getSiteSettings } from '../../lib/strapi';

const page = await getManagedRoutePageForLegacyRenderer('/for', async () => {
  const [settings, businessTypes] = await Promise.all([getSiteSettings(), getBusinessTypes()]);
  return adaptDirectoryPage('business_types', settings, businessTypes);
}, 'directory');
---

<DirectoryPage {...page} />
