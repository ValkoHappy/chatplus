---
import StructuredLandingPage from '../../components/StructuredLandingPage.astro';
import { adaptBusinessTypePage } from '../../lib/page-adapters';
import { getBusinessTypes, getChannels, getIndustries } from '../../lib/strapi';

export async function getStaticPaths() {
  const businessTypes = await getBusinessTypes();
  return businessTypes.map((bt) => ({ params: { slug: bt.slug }, props: { bt } }));
}

const { bt } = Astro.props;
const [businessTypes, industries, channels] = await Promise.all([
  getBusinessTypes(),
  getIndustries(),
  getChannels(),
]);
const page = adaptBusinessTypePage(bt, { businessTypes, industries, channels });
---

<StructuredLandingPage page={page} />
