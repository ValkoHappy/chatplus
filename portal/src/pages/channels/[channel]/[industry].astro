---
import StructuredLandingPage from '../../../components/StructuredLandingPage.astro';
import { adaptChannelIndustryPage } from '../../../lib/page-adapters';
import { getChannels, getIndustries, getIntegrations, getPageV2ByRouteForLegacyRenderer, getSiteSettings, getSolutions } from '../../../lib/strapi';

export async function getStaticPaths() {
  const [channels, industries] = await Promise.all([getChannels(), getIndustries()]);
  return channels.flatMap((channel) =>
    industries.map((industry) => ({
      params: { channel: channel.slug, industry: industry.slug },
      props: { channel, industry },
    }))
  );
}

const { channel, industry } = Astro.props;
const bridgedPage = await getPageV2ByRouteForLegacyRenderer(`/channels/${channel.slug}/${industry.slug}`, 'structured');
const [settings, integrations, solutions] = await Promise.all([
  getSiteSettings(),
  getIntegrations(),
  getSolutions(),
]);
const page = bridgedPage || adaptChannelIndustryPage(channel, industry, { settings, integrations, solutions });
---

<StructuredLandingPage page={page} />
