---
import DirectoryPage from '../../components/DirectoryPage.astro';
import { adaptDirectoryPage } from '../../lib/page-adapters';
import { getChannels, getManagedRoutePageForLegacyRenderer, getSiteSettings } from '../../lib/strapi';

const page = await getManagedRoutePageForLegacyRenderer('/channels', async () => {
  const [settings, channels] = await Promise.all([getSiteSettings(), getChannels()]);
  return adaptDirectoryPage('channels', settings, channels);
}, 'directory');
---

<DirectoryPage {...page} />
