---
import DirectoryPage from '../../components/DirectoryPage.astro';
import { adaptDirectoryPage } from '../../lib/page-adapters';
import { getChannels, getSiteSettings } from '../../lib/strapi';

const [settings, channels] = await Promise.all([getSiteSettings(), getChannels()]);
const page = adaptDirectoryPage('channels', settings, channels);
---

<DirectoryPage {...page} />
