---
import Base from '../../layouts/Base.astro';

const courses = [
  { title: "Chat Plus для начинающих", lessons: 8, duration: "2 часа", level: "Начальный", free: true },
  { title: "Автоматизация через мессенджеры", lessons: 12, duration: "3 часа", level: "Средний", free: true },
  { title: "AI-агенты: настройка и обучение", lessons: 10, duration: "2.5 часа", level: "Средний", free: true },
  { title: "Programmatic SEO для SaaS", lessons: 15, duration: "4 часа", level: "Продвинутый", free: false },
  { title: "Партнёрская программа Chat Plus", lessons: 6, duration: "1.5 часа", level: "Начальный", free: true },
  { title: "Интеграции с CRM-системами", lessons: 9, duration: "2 часа", level: "Средний", free: true },
];
---

<Base title="Chat Plus Academy" description="Бесплатные курсы по автоматизации бизнеса через мессенджеры. Сертификация Chat Plus.">

  <!-- Hero -->
  <section style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); color: white; padding: 4rem 2rem; text-align: center;">
    <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem;">Chat Plus Academy</h1>
    <p style="font-size: 1.15rem; opacity: 0.9; max-width: 500px; margin: 0 auto 2rem;">Бесплатные курсы по автоматизации бизнеса. Получите сертификат Chat Plus.</p>
    <div style="display: flex; gap: 2rem; justify-content: center; font-size: 0.9rem; opacity: 0.85;">
      <span>📚 30+ уроков</span>
      <span>🎓 Сертификация</span>
      <span>✅ Бесплатно</span>
    </div>
  </section>

  <!-- Курсы -->
  <section style="padding: 4rem 2rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 2.5rem;">Курсы</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem;">
        {courses.map(course => (
          <div style="border: 1px solid #e2e8f0; border-radius: 16px; padding: 1.75rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
              <span style={`font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.75rem; border-radius: 20px; ${course.free ? 'background: #f0fdf4; color: #16a34a;' : 'background: #eff6ff; color: #3b82f6;'}`}>
                {course.free ? 'Бесплатно' : 'Pro'}
              </span>
              <span style="font-size: 0.8rem; color: #94a3b8;">{course.level}</span>
            </div>
            <h3 style="font-weight: 700; font-size: 1.05rem; margin-bottom: 1rem; line-height: 1.4;">{course.title}</h3>
            <div style="display: flex; gap: 1rem; font-size: 0.85rem; color: #64748b; margin-bottom: 1.5rem;">
              <span>📖 {course.lessons} уроков</span>
              <span>⏱ {course.duration}</span>
            </div>
            <a href="#" style="display: block; text-align: center; background: #6366f1; color: white; padding: 0.625rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem;">
              Начать курс
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
