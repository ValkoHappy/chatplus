---
import PageV2Page from '../components/PageV2Page.astro';
import CampaignPage from '../components/CampaignPage.astro';
import { getLandingPage, getManagedRoutePage } from '../lib/strapi';

const resolved = await getManagedRoutePage('/prozorro', () => getLandingPage('prozorro'));
---

{resolved.kind === 'page_v2' ? <PageV2Page page={resolved.page} /> : <CampaignPage page={resolved.page} />}
