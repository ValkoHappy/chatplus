---
import ComparisonPage from '../../components/ComparisonPage.astro';
import { adaptCompetitorPage } from '../../lib/page-adapters';
import { getCompetitors, getSiteSettings } from '../../lib/strapi';

export async function getStaticPaths() {
  const competitors = await getCompetitors();
  return competitors.map((competitor) => ({
    params: { slug: competitor.slug },
    props: { competitor },
  }));
}

const { competitor } = Astro.props;
const [settings, competitors] = await Promise.all([getSiteSettings(), getCompetitors()]);
const currentCompetitor = competitors.find((item) => item.slug === competitor.slug) || competitor;
const page = adaptCompetitorPage(currentCompetitor, { settings, competitors }, 'vs');
---

<ComparisonPage page={page} />
