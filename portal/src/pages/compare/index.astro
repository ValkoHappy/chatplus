---
import Base from '../../layouts/Base.astro';
import { getCompetitors } from '../../lib/strapi';
import { withBasePath } from '../../lib/urls';

const competitors = await getCompetitors();
const toHref = (href?: string) => withBasePath(href);

const compareCards = competitors.map((competitor) => ({
  href: `/compare/${competitor.slug}`,
  label: `Chat Plus vs ${competitor.name}`,
  description: competitor.hero_description || `Подробное сравнение Chat Plus и ${competitor.name}.`,
  cta: 'Смотреть сравнение',
}));

const vsCards = competitors.map((competitor) => ({
  href: `/vs/${competitor.slug}`,
  label: `${competitor.name} или Chat Plus`,
  description: competitor.hero_description || `Формат выбора между ${competitor.name} и Chat Plus.`,
  cta: 'Смотреть формат vs',
}));
---

<Base title="Сравнения Chat Plus" description="Сравнения Chat Plus с другими платформами: подробные compare-страницы и сценарии формата vs.">
  <section class="compare-hero">
    <div class="container compare-hero-inner">
      <p class="compare-eyebrow">Сравнения</p>
      <h1 class="compare-title">Сравнения Chat Plus</h1>
      <p class="compare-subtitle">
        Здесь собраны два формата сравнения: подробные разборы платформ и быстрые страницы выбора между Chat Plus и альтернативами.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container compare-grid">
      <section class="compare-section">
        <div class="compare-section-head">
          <h2 class="compare-section-title">Подробные сравнения</h2>
          <p class="compare-section-text">
            Развернутые compare-страницы с акцентом на отличия по модели, ограничениям и практическому внедрению.
          </p>
        </div>
        <div class="compare-cards">
          {compareCards.map((card) => (
            <a href={toHref(card.href)} class="compare-card">
              <span class="compare-card-label">{card.label}</span>
              <span class="compare-card-desc">{card.description}</span>
              <span class="compare-card-cta">{card.cta}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="compare-section">
        <div class="compare-section-head">
          <h2 class="compare-section-title">Формат “или Chat Plus”</h2>
          <p class="compare-section-text">
            Более короткие vs-страницы для пользователей, которые уже выбирают между двумя решениями и хотят быстро сориентироваться.
          </p>
        </div>
        <div class="compare-cards">
          {vsCards.map((card) => (
            <a href={toHref(card.href)} class="compare-card">
              <span class="compare-card-label">{card.label}</span>
              <span class="compare-card-desc">{card.description}</span>
              <span class="compare-card-cta">{card.cta}</span>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>
</Base>

<style>
  .compare-hero {
    padding: clamp(3rem, 7vw, 5rem) 0 clamp(2.5rem, 5vw, 3.25rem);
    background: linear-gradient(180deg, #eef2ff 0%, #ffffff 100%);
  }

  .compare-hero-inner {
    display: grid;
    gap: 1rem;
    max-width: 760px;
  }

  .compare-eyebrow {
    color: #4f46e5;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .compare-title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
    color: #0f172a;
  }

  .compare-subtitle {
    font-size: 1.02rem;
    line-height: 1.8;
    color: #475569;
  }

  .compare-grid {
    display: grid;
    gap: 2.25rem;
  }

  .compare-section {
    display: grid;
    gap: 1rem;
  }

  .compare-section-head {
    display: grid;
    gap: 0.45rem;
    max-width: 760px;
  }

  .compare-section-title {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #0f172a;
  }

  .compare-section-text {
    color: #475569;
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .compare-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .compare-card {
    display: grid;
    gap: 0.5rem;
    min-height: 160px;
    padding: 1.15rem 1.2rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(226, 232, 240, 0.95);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 14px 32px rgba(15, 23, 42, 0.05);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .compare-card:hover {
    transform: translateY(-2px);
    border-color: rgba(99, 102, 241, 0.35);
    box-shadow: 0 20px 40px rgba(79, 70, 229, 0.1);
  }

  .compare-card-label {
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0f172a;
  }

  .compare-card-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #475569;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .compare-card-cta {
    margin-top: auto;
    color: #4f46e5;
    font-size: 0.82rem;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .compare-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
