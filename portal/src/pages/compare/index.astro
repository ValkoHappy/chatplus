---
import Base from '../../layouts/Base.astro';
import { getCompetitors, getPageV2ByRouteForLegacyRenderer } from '../../lib/strapi';
import { withBasePath } from '../../lib/urls';

const pageV2 = await getPageV2ByRouteForLegacyRenderer('/compare', 'comparison_directory');
const competitors = await getCompetitors();
const toHref = (href?: string) => withBasePath(href);

const TECHNICAL_COMPARE_TEXT = new Set([
  'compare alternatives',
  'comparison',
  'alternative',
  'editorial workflow',
  'manual review in strapi',
  'compare the alternative with chat plus before publishing.',
  'request demo',
  'request comparison',
]);

function normalizeCompareText(value: unknown, fallback: string) {
  const text = typeof value === 'string' ? value.trim() : '';
  if (!text) return fallback;
  return TECHNICAL_COMPARE_TEXT.has(text.toLowerCase()) ? fallback : text;
}

function normalizeCompareRow(row: Record<string, unknown>) {
  return {
    parameter: normalizeCompareText(row?.parameter, 'Сравнение'),
    option_one: normalizeCompareText(row?.option_one, 'Описание альтернативы доступно на отдельной странице сравнения.'),
    option_two: normalizeCompareText(row?.option_two, 'Проверьте стоимость, локальную поддержку, омниканальность и AI-сценарии.'),
    chat_plus: normalizeCompareText(row?.chat_plus, 'Chat Plus делает ставку на омниканал, AI и предсказуемую экономику для B2B-команд.'),
  };
}

const fallbackCompareCards = competitors.map((competitor) => ({
  href: `/compare/${competitor.slug}`,
  label: `Chat Plus vs ${competitor.name}`,
  description: competitor.hero_description || `Подробное сравнение Chat Plus и ${competitor.name}.`,
  cta: 'Смотреть сравнение',
}));

const fallbackVsCards = competitors.map((competitor) => ({
  href: `/vs/${competitor.slug}`,
  label: `${competitor.name} или Chat Plus`,
  description: competitor.hero_description || `Формат выбора между ${competitor.name} и Chat Plus.`,
  cta: 'Смотреть формат vs',
}));

const title = pageV2?.metaTitle || 'Сравнения Chat Plus';
const description =
  pageV2?.metaDescription ||
  'Сравнения Chat Plus с другими платформами: подробные compare-страницы и сценарии формата vs.';
const eyebrow = normalizeCompareText(pageV2?.eyebrow, 'Сравнения');
const heading = pageV2?.title || 'Сравнения Chat Plus';
const subtitle =
  pageV2?.subtitle ||
  'Здесь собраны два формата сравнения: подробные разборы платформ и быстрые страницы выбора между Chat Plus и альтернативами.';
const compareSectionTitle = pageV2?.compareSectionTitle || 'Подробные сравнения';
const compareSectionText =
  pageV2?.compareSectionText ||
  'Развернутые compare-страницы с акцентом на отличия по модели, ограничениям и практическому внедрению.';
const vsSectionTitle = pageV2?.vsSectionTitle || 'Формат "или Chat Plus"';
const vsSectionText =
  pageV2?.vsSectionText ||
  'Короткие vs-страницы для пользователей, которые уже выбирают между двумя решениями и хотят быстро сориентироваться.';
const compareCards = pageV2?.compareCards?.length ? pageV2.compareCards : fallbackCompareCards;
const vsCards = pageV2?.vsCards?.length ? pageV2.vsCards : fallbackVsCards;
const technicalFaqQuestions = new Set(['can this page be edited in strapi?']);
const technicalFaqAnswers = new Set(['yes. the page record owns route, seo, sections and links.']);
const faqs = (pageV2?.faqs || []).filter((item) => {
  const question = item.question?.trim().toLowerCase();
  const answer = item.answer?.trim().toLowerCase();
  return !technicalFaqQuestions.has(question || '') && !technicalFaqAnswers.has(answer || '');
});
const comparisonTitle = normalizeCompareText(pageV2?.comparison_title, 'Сравнения Chat Plus');
const comparisonLabels = {
  parameter: normalizeCompareText(pageV2?.section_labels?.comparison_parameter, 'Параметр'),
  optionOne: normalizeCompareText(pageV2?.section_labels?.comparison_option_one, 'Альтернатива'),
  optionTwo: normalizeCompareText(pageV2?.section_labels?.comparison_option_two, 'На что смотреть'),
  chatPlus: normalizeCompareText(pageV2?.section_labels?.comparison_chat_plus, 'Chat Plus'),
};
const comparisonRows = (pageV2?.comparison_rows || []).map((row) => normalizeCompareRow(row));
const finalCtaPrimaryLabel = normalizeCompareText(pageV2?.sticky_cta_primary_label, 'Записаться на демо');
---

<Base title={title} description={description} canonical={pageV2?.canonical} hideGlobalStickyCta={Boolean(pageV2?.sticky_cta_title || pageV2?.sticky_cta_text)}>
  <section class="compare-hero">
    <div class="container compare-hero-inner">
      <p class="compare-eyebrow">{eyebrow}</p>
      <h1 class="compare-title">{heading}</h1>
      <p class="compare-subtitle">{subtitle}</p>
    </div>
  </section>

  <section class="section">
    <div class="container compare-grid">
      <section class="compare-section">
        <div class="compare-section-head">
          <h2 class="compare-section-title">{compareSectionTitle}</h2>
          <p class="compare-section-text">{compareSectionText}</p>
        </div>
        <div class="compare-cards">
          {compareCards.map((card) => (
            <a href={toHref(card.href)} class="compare-card">
              <span class="compare-card-label">{card.label}</span>
              <span class="compare-card-desc">{card.description}</span>
              <span class="compare-card-cta">{card.cta}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="compare-section">
        <div class="compare-section-head">
          <h2 class="compare-section-title">{vsSectionTitle}</h2>
          <p class="compare-section-text">{vsSectionText}</p>
        </div>
        <div class="compare-cards">
          {vsCards.map((card) => (
            <a href={toHref(card.href)} class="compare-card">
              <span class="compare-card-label">{card.label}</span>
              <span class="compare-card-desc">{card.description}</span>
              <span class="compare-card-cta">{card.cta}</span>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>

  {comparisonTitle && comparisonRows.length > 0 && (
    <section class="section section-soft">
      <div class="container">
        <div class="compare-section-head">
          <h2 class="compare-section-title">{comparisonTitle}</h2>
        </div>
        <div class="table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th>{comparisonLabels.parameter}</th>
                <th>{comparisonLabels.optionOne}</th>
                <th>{comparisonLabels.optionTwo}</th>
                <th>{comparisonLabels.chatPlus}</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row) => (
                <tr>
                  <td>{row.parameter}</td>
                  <td>{row.option_one}</td>
                  <td>{row.option_two}</td>
                  <td class="accent-cell">{row.chat_plus}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  {faqs.length > 0 && (
    <section class="section">
      <div class="container faq-container">
        {pageV2.faq_title && <h2 class="compare-section-title">{pageV2.faq_title}</h2>}
        <div class="faq-list">
          {faqs.map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  {(pageV2?.sticky_cta_title || pageV2?.sticky_cta_text) && (
    <section class="compare-final">
      <div class="container compare-final-inner">
        <div>
          {pageV2.sticky_cta_title && <h2>{pageV2.sticky_cta_title}</h2>}
          {pageV2.sticky_cta_text && <p>{pageV2.sticky_cta_text}</p>}
        </div>
        {pageV2.sticky_cta_primary_label && pageV2.sticky_cta_primary_url && (
          <a href={toHref(pageV2.sticky_cta_primary_url)} class="btn-primary">{finalCtaPrimaryLabel}</a>
        )}
      </div>
    </section>
  )}
</Base>

<style>
  .compare-hero {
    padding: clamp(3rem, 7vw, 5rem) 0 clamp(2.5rem, 5vw, 3.25rem);
    background: linear-gradient(180deg, #eef2ff 0%, #ffffff 100%);
  }

  .compare-hero-inner {
    display: grid;
    gap: 1rem;
    max-width: 760px;
  }

  .compare-eyebrow {
    color: #4f46e5;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .compare-title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
    color: #0f172a;
  }

  .compare-subtitle {
    font-size: 1.02rem;
    line-height: 1.8;
    color: #475569;
  }

  .compare-grid {
    display: grid;
    gap: 2.25rem;
  }

  .section-soft {
    background: #f8fafc;
  }

  .compare-section {
    display: grid;
    gap: 1rem;
  }

  .compare-section-head {
    display: grid;
    gap: 0.45rem;
    max-width: 760px;
  }

  .compare-section-title {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #0f172a;
  }

  .compare-section-text {
    color: #475569;
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .compare-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .compare-card {
    display: grid;
    gap: 0.5rem;
    min-height: 160px;
    padding: 1.15rem 1.2rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(226, 232, 240, 0.95);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 14px 32px rgba(15, 23, 42, 0.05);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .compare-card:hover {
    transform: translateY(-2px);
    border-color: rgba(99, 102, 241, 0.35);
    box-shadow: 0 20px 40px rgba(79, 70, 229, 0.1);
  }

  .compare-card-label {
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0f172a;
  }

  .compare-card-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #475569;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .compare-card-cta {
    margin-top: auto;
    color: #4f46e5;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .table-wrap {
    margin-top: 1rem;
    overflow: auto;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    background: #fff;
  }

  .compare-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
  }

  .compare-table th,
  .compare-table td {
    padding: 1rem 1.1rem;
    text-align: left;
    border-bottom: 1px solid #eef2f7;
    vertical-align: top;
  }

  .compare-table thead th {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: #64748b;
    text-transform: uppercase;
    background: #f8fafc;
  }

  .compare-table td:first-child {
    font-weight: 700;
    color: #0f172a;
  }

  .accent-cell {
    font-weight: 700;
    color: #4338ca;
    background: #f8faff;
  }

  .faq-container {
    max-width: var(--container, 1240px);
  }

  .faq-list {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .faq-item {
    padding: 1rem 1.1rem;
    border-radius: 16px;
    border: 1px solid #e2e8f0;
    background: #fff;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 700;
    color: #0f172a;
  }

  .faq-item p {
    margin-top: 0.75rem;
    color: #475569;
    line-height: 1.7;
  }

  .compare-final {
    padding: clamp(2.5rem, 5vw, 3.5rem) 0;
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
    color: #fff;
  }

  .compare-final-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.4rem;
  }

  .compare-final h2 {
    font-size: clamp(1.6rem, 3vw, 2.35rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .compare-final p {
    margin-top: 0.8rem;
    color: #cbd5e1;
    line-height: 1.8;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0.8rem 1.2rem;
    border-radius: 12px;
    background: #fff;
    color: #0f172a;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .compare-cards {
      grid-template-columns: 1fr;
    }

    .compare-final-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
