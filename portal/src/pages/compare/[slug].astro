---
import Base from '../../layouts/Base.astro';
import { competitors } from '../../data/competitors';

export function getStaticPaths() {
  return competitors.map(c => ({ params: { slug: c.slug }, props: { c } }));
}
const { c } = Astro.props;
---
<Base title={`Chat Plus vs ${c.name} — сравнение`} description={`Chat Plus vs ${c.name}: цены, функции, отличия. ${c.ourPrice} против ${c.price}.`}>
  <section style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; padding: 5rem 2rem; text-align: center;">
    <p style="font-size: 0.85rem; font-weight: 600; color: #6366f1; letter-spacing: 0.1em; margin-bottom: 1rem; text-transform: uppercase;">Сравнение</p>
    <h1 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; margin-bottom: 1.5rem;">Chat Plus vs {c.name}</h1>
    <p style="font-size: 1.1rem; opacity: 0.7; max-width: 600px; margin: 0 auto;">{c.verdict}</p>
  </section>

  <!-- Цены -->
  <section style="padding: 4rem 2rem; background: #f8fafc;">
    <div style="max-width: 700px; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 2rem;">Сравнение цен</h2>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
        <div style="background: white; border: 2px solid #6366f1; border-radius: 16px; padding: 2rem;">
          <p style="font-size: 0.8rem; font-weight: 700; color: #6366f1; text-transform: uppercase; margin-bottom: 0.5rem;">Chat Plus</p>
          <p style="font-size: 1.75rem; font-weight: 800; color: #0f172a;">{c.ourPrice}</p>
          <p style="font-size: 0.85rem; color: #64748b; margin-top: 0.5rem;">Фиксированная цена</p>
        </div>
        <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 2rem;">
          <p style="font-size: 0.8rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; margin-bottom: 0.5rem;">{c.name}</p>
          <p style="font-size: 1.75rem; font-weight: 800; color: #94a3b8;">{c.price}</p>
          <p style="font-size: 0.85rem; color: #94a3b8; margin-top: 0.5rem;">+ скрытые платежи</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Сравнение -->
  <section style="padding: 4rem 2rem;">
    <div style="max-width: 900px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
        <div>
          <h3 style="font-size: 1.1rem; font-weight: 700; color: #6366f1; margin-bottom: 1.5rem;">✓ Преимущества Chat Plus</h3>
          <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            {c.ourStrengths.map(s => (
              <div style="display: flex; gap: 0.75rem; align-items: flex-start; padding: 0.75rem; background: #f0fdf4; border-radius: 8px; border: 1px solid #bbf7d0;">
                <span style="color: #16a34a; font-weight: 700; flex-shrink: 0;">✓</span>
                <span style="font-size: 0.9rem;">{s}</span>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h3 style="font-size: 1.1rem; font-weight: 700; color: #94a3b8; margin-bottom: 1.5rem;">✗ Слабые стороны {c.name}</h3>
          <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            {c.weaknesses.map(w => (
              <div style="display: flex; gap: 0.75rem; align-items: flex-start; padding: 0.75rem; background: #fef2f2; border-radius: 8px; border: 1px solid #fecaca;">
                <span style="color: #dc2626; font-weight: 700; flex-shrink: 0;">✗</span>
                <span style="font-size: 0.9rem;">{w}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section style="background: #6366f1; color: white; padding: 4rem 2rem; text-align: center;">
    <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 1rem;">Переходите с {c.name} на Chat Plus</h2>
    <p style="opacity: 0.9; margin-bottom: 2rem;">Поможем перенести данные. Первые 14 дней бесплатно.</p>
    <a href="/demo" style="background: white; color: #6366f1; padding: 1rem 2.5rem; border-radius: 10px; font-weight: 700; display: inline-block;">Попробовать бесплатно</a>
  </section>
</Base>
