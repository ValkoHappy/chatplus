---
import Base from '../layouts/Base.astro';
---

<Base title="Страница не найдена" description="Запрашиваемая страница не существует">
  <section class="error-section">
    <div class="error-glow"></div>
    <div class="container error-inner">
      <span class="error-code">404</span>
      <h1>Страница не найдена</h1>
      <p>Возможно, страница была перемещена или вы перешли по неверной ссылке.</p>
      <div class="error-actions">
        <a href="/" class="btn-primary">На главную</a>
        <a href="/channels" class="btn-outline">Каталог каналов</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .error-section {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 180px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(3rem, 8vw, 6rem) 0;
  }

  .error-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 30%, rgba(99, 102, 241, .14), transparent 40%),
      radial-gradient(circle at 80% 70%, rgba(14, 165, 233, .08), transparent 30%);
    pointer-events: none;
  }

  .container {
    max-width: 620px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2rem);
  }

  .error-inner {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .error-code {
    font-size: clamp(6rem, 16vw, 10rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 1;
    background: linear-gradient(135deg, #6366f1, #a78bfa, #6366f1);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 4s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  h1 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.03em;
  }

  p {
    font-size: 1.05rem;
    color: #64748b;
    line-height: 1.7;
    max-width: 440px;
  }

  .error-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary,
  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.82rem 1.4rem;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, #6366f1, #4f46e5);
    color: #fff;
    box-shadow: 0 14px 34px rgba(99, 102, 241, 0.22);
  }

  .btn-outline {
    background: #fff;
    color: #0f172a;
    border: 1.5px solid #cbd5e1;
  }

  .btn-primary:hover,
  .btn-outline:hover {
    transform: translateY(-1px);
  }

  .btn-outline:hover {
    border-color: #6366f1;
    background: #f5f3ff;
  }

  @media (max-width: 480px) {
    .error-actions {
      flex-direction: column;
      width: 100%;
    }

    .btn-primary,
    .btn-outline {
      width: 100%;
    }
  }
</style>
