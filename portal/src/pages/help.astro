---
import Base from '../layouts/Base.astro';
const categories = [
  { emoji: "🚀", title: "Быстрый старт", desc: "Настройка аккаунта и первые шаги" },
  { emoji: "📱", title: "Каналы", desc: "WhatsApp, Telegram, Instagram и другие" },
  { emoji: "🤖", title: "AI и боты", desc: "Настройка AI-агентов и чат-ботов" },
  { emoji: "🔗", title: "Интеграции", desc: "CRM, календари, автоматизация" },
  { emoji: "💳", title: "Биллинг", desc: "Тарифы, оплата, счета" },
  { emoji: "🛡️", title: "Безопасность", desc: "Настройки приватности и доступа" },
];
---
<Base title="Центр помощи" description="Ответы на вопросы о Chat Plus.">
  <section style="background: #f8fafc; padding: 4rem 2rem; text-align: center;">
    <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 1.5rem;">Чем можем помочь?</h1>
    <input type="text" placeholder="Поиск по базе знаний..." style="width: 100%; max-width: 500px; padding: 0.875rem 1.25rem; border: 1px solid #e2e8f0; border-radius: 10px; font-size: 1rem;" />
  </section>
  <section style="padding: 4rem 2rem;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
      {categories.map(cat => (
        <a href="#" style="border: 1px solid #e2e8f0; border-radius: 16px; padding: 1.75rem; background: white; display: block;">
          <div style="font-size: 2rem; margin-bottom: 0.75rem;">{cat.emoji}</div>
          <h3 style="font-weight: 700; margin-bottom: 0.4rem;">{cat.title}</h3>
          <p style="color: #64748b; font-size: 0.9rem;">{cat.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
