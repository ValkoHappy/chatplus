---
import Base from '../../layouts/Base.astro';
import { features } from '../../data/features';

export function getStaticPaths() {
  return features.map(feature => ({
    params: { slug: feature.slug },
    props: { feature }
  }));
}

const { feature } = Astro.props;
---

<Base title={`Chat Plus ${feature.name}`} description={feature.description}>

  <section style="background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%); color: white; padding: 5rem 2rem;">
    <div style="max-width: 800px; margin: 0 auto; text-align: center;">
      <div style="font-size: 3.5rem; margin-bottom: 1rem;">{feature.emoji}</div>
      <p style="font-size: 0.8rem; font-weight: 600; letter-spacing: 0.1em; opacity: 0.7; margin-bottom: 0.75rem; text-transform: uppercase;">Возможность Chat Plus</p>
      <h1 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; margin-bottom: 1.5rem;">
        Chat Plus {feature.name}
      </h1>
      <p style="font-size: 1.15rem; opacity: 0.9; max-width: 580px; margin: 0 auto 2.5rem;">
        {feature.description}
      </p>
      <a href="/demo" style="background: white; color: #ef4444; padding: 0.875rem 2.5rem; border-radius: 10px; font-weight: 700; font-size: 1rem; display: inline-block;">
        {feature.cta}
      </a>
    </div>
  </section>

  <section style="padding: 4rem 2rem;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="font-size: 1.75rem; font-weight: 800; text-align: center; margin-bottom: 3rem;">Включено в Chat Plus</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem;">
        {feature.features.map(f => (
          <div style="padding: 1.5rem; border: 1px solid #e2e8f0; border-radius: 12px; display: flex; align-items: center; gap: 0.75rem;">
            <span style="color: #f59e0b; font-size: 1.25rem;">✓</span>
            <span style="font-weight: 600;">{f}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); color: white; padding: 4rem 2rem; text-align: center;">
    <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 1rem;">Попробуйте бесплатно 14 дней</h2>
    <p style="opacity: 0.85; margin-bottom: 2rem;">Все возможности включены. Никакой технической экспертизы не нужно.</p>
    <a href="/demo" style="background: white; color: #6366f1; padding: 1rem 2.5rem; border-radius: 10px; font-weight: 700; font-size: 1rem; display: inline-block;">
      {feature.cta}
    </a>
  </section>

</Base>
