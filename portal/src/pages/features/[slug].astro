---
import StructuredLandingPage from '../../components/StructuredLandingPage.astro';
import { adaptFeaturePage } from '../../lib/page-adapters';
import { getFeatures, getIndustries, getIntegrations, getSiteSettings } from '../../lib/strapi';

export async function getStaticPaths() {
  const features = await getFeatures();
  return features.map((feature) => ({
    params: { slug: feature.slug },
    props: { feature },
  }));
}

const { feature } = Astro.props;
const [settings, features, industries, integrations] = await Promise.all([
  getSiteSettings(),
  getFeatures(),
  getIndustries(),
  getIntegrations(),
]);
const page = adaptFeaturePage(feature, { settings, features, industries, integrations });
---

<StructuredLandingPage page={page} />
