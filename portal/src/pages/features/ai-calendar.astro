---
import Base from '../../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { getPageV2ByRouteForLegacyRenderer } from '../../lib/strapi';
import { withBasePath } from '../../lib/urls';

const fallbackMeta = {
  title: 'AI Календарь | Синхронизация записей из чата | Chat Plus',
  description:
    'Автоматическая запись клиентов из WhatsApp, Telegram и Instagram напрямую в ваш Google Calendar или CRM-систему с помощью AI.',
};

const fallbackSteps = [
  {
    title: 'Клиент пишет в мессенджер',
    desc: 'Клиент отправляет сообщение в WhatsApp, Telegram или Instagram с желанием записаться.',
    icon: 'lucide:message-circle',
  },
  {
    title: 'AI понимает контекст',
    desc: 'Нейросеть распознает услугу, желаемое время и специалиста прямо из текста.',
    icon: 'lucide:brain',
  },
  {
    title: 'Проверка свободного времени',
    desc: 'Система мгновенно сверяется с вашим расписанием в Google Calendar или CRM.',
    icon: 'lucide:calendar-search',
  },
  {
    title: 'Подтверждение записи',
    desc: 'AI отправляет клиенту доступные слоты и фиксирует окончательное время.',
    icon: 'lucide:calendar-check-2',
  },
  {
    title: 'Интеграция в календарь',
    desc: 'Событие автоматически создается в вашем календаре со всеми контактными данными.',
    icon: 'lucide:database',
  },
  {
    title: 'Авто-напоминания',
    desc: 'Система сама отправит клиенту напоминание за 24 часа и за час до визита.',
    icon: 'lucide:bell-ring',
  },
];

const fallbackIndustries = [
  {
    name: 'Салоны красоты',
    desc: 'Автоматизация записи на стрижку, маникюр и другие процедуры. Сокращение неявок благодаря автонапоминаниям.',
    icon: 'lucide:scissors',
  },
  {
    name: 'Медицина',
    desc: 'Запись пациентов к нужным врачам 24/7 без участия администратора клиники.',
    icon: 'lucide:stethoscope',
  },
  {
    name: 'HR и рекрутинг',
    desc: 'Планирование собеседований напрямую из переписки с кандидатами.',
    icon: 'lucide:users',
  },
  {
    name: 'Обучение',
    desc: 'Запись на пробные уроки, курсы и консультации прямо из чатов и директов.',
    icon: 'lucide:graduation-cap',
  },
];

const fallbackIntegrations = [
  {
    title: 'Google Calendar',
    text: 'Мгновенная двусторонняя синхронизация',
    icon: 'simple-icons:googlecalendar',
  },
  {
    title: 'Outlook Calendar',
    text: 'Для корпоративных клиентов',
    icon: 'simple-icons:microsoftoutlook',
  },
  {
    title: 'Интеграция с CRM',
    text: 'AmoCRM, Altegio, Yclients и другие',
    icon: 'lucide:briefcase',
  },
];

const toHref = (href?: string) => withBasePath(href);
const pageV2 = await getPageV2ByRouteForLegacyRenderer('/features/ai-calendar', 'ai_calendar');
const title = pageV2?.title || fallbackMeta.title;
const description = pageV2?.description || fallbackMeta.description;
const eyebrow = pageV2?.eyebrow || 'Флагманская функция Chat Plus';
const heroTitle = pageV2?.heroTitle || 'AI Календарь: синхронизация записей из любого чата';
const heroSubtitle =
  pageV2?.heroSubtitle ||
  'Перестаньте вручную переносить записи из мессенджеров. Наш AI агент читает контекст переписки, сверяется с расписанием и автоматически создает события в вашем календаре.';
const primaryLabel = pageV2?.primaryLabel || 'Попробовать бесплатно';
const primaryUrl = pageV2?.primaryUrl || '/demo';
const secondaryLabel = pageV2?.secondaryLabel || 'Как это работает';
const secondaryUrl = pageV2?.secondaryUrl || '#how-it-works';
const stepsTitle = pageV2?.stepsTitle || 'Магия автоматизации';
const stepsIntro = pageV2?.stepsIntro || 'Как Chat Plus превращает простые сообщения в подтвержденные записи в 6 шагов.';
const steps = pageV2?.steps?.length ? pageV2.steps : fallbackSteps;
const integrationsTitle = pageV2?.integrationsTitle || 'Работает с вашим расписанием';
const integrationsIntro =
  pageV2?.integrationsIntro ||
  'Вам не нужно менять свои привычки или переходить на новую CRM. AI Календарь нативно интегрируется с популярными системами управления временем.';
const integrations = pageV2?.integrations?.length ? pageV2.integrations : fallbackIntegrations;
const industriesTitle = pageV2?.industriesTitle || 'Идеально для бизнеса услуг';
const industries = pageV2?.industries?.length ? pageV2.industries : fallbackIndustries;
const finalTitle = pageV2?.finalTitle || 'Готовы автоматизировать записи?';
const finalText =
  pageV2?.finalText || 'Постройте бесшовный процесс от первого сообщения до подтвержденного визита.';
const finalPrimaryLabel = pageV2?.finalPrimaryLabel || 'Записаться на демо';
const finalPrimaryUrl = pageV2?.finalPrimaryUrl || '/demo';
const finalSecondaryLabel = pageV2?.finalSecondaryLabel || 'Смотреть цены';
const finalSecondaryUrl = pageV2?.finalSecondaryUrl || '/pricing';
---

<Base title={title} description={description} canonical={pageV2?.canonical} hideGlobalStickyCta={true}>
  <section class="hero-section">
    <div class="hero-bg-dots"></div>
    <div class="container hero-container">
      <div class="hero-content">
        <div class="eyebrow">{eyebrow}</div>
        <h1 class="hero-title">
          <span class="text-gradient">{heroTitle.split(':')[0]}:</span><br />
          {heroTitle.split(':').slice(1).join(':').trim() || heroTitle}
        </h1>
        <p class="hero-desc">{heroSubtitle}</p>
        <div class="hero-actions">
          <a href={toHref(primaryUrl)} class="btn-primary">{primaryLabel}</a>
          <a href={secondaryUrl} class="btn-outline">{secondaryLabel}</a>
        </div>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="section section-tinted">
    <div class="container">
      <div class="section-header center">
        <h2 class="section-title">{stepsTitle}</h2>
        <p class="section-intro center">{stepsIntro}</p>
      </div>

      <div class="steps-grid">
        {steps.map((step, index) => (
          <div class="step-card">
            <div class="step-header">
              <div class="step-number">{index + 1}</div>
              <div class="step-icon-wrap">
                <Icon name={step.icon} class="step-icon" />
              </div>
            </div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div class="integration-info">
        <h2 class="section-title">{integrationsTitle}</h2>
        <p class="section-intro">{integrationsIntro}</p>

        <ul class="integration-list">
          {integrations.map((item) => (
            <li>
              <div class="int-icon"><Icon name={item.icon} /></div>
              <div>
                <strong>{item.title}</strong>
                <span>{item.text}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="integration-visual">
        <div class="mockup-card">
          <div class="mockup-header">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
          <div class="chat-bubble left">
            Привет! Хочу записаться на маникюр к Анне на пятницу вечером.
          </div>
          <div class="chat-bubble right">
            Здравствуйте! У Анны в эту пятницу есть свободное время в 18:00 и 19:30. Какое время вам удобнее?
          </div>
          <div class="chat-bubble left">Давайте на 18:00.</div>
          <div class="chat-bubble system">
            <Icon name="lucide:calendar-check-2" />
            Событие "Маникюр — Анна" добавлено в Google Calendar на пятницу, 18:00.
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-tinted">
    <div class="container">
      <div class="section-header center">
        <h2 class="section-title">{industriesTitle}</h2>
      </div>

      <div class="industries-grid">
        {industries.map((ind) => (
          <div class="industry-card">
            <div class="ind-icon-wrap">
              <Icon name={ind.icon} class="ind-icon" />
            </div>
            <h3 class="ind-title">{ind.name}</h3>
            <p class="ind-desc">{ind.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <div class="cta-bg-glow"></div>
        <div class="cta-content">
          <h2>{finalTitle}</h2>
          <p>{finalText}</p>
          <div class="cta-actions">
            <a href={toHref(finalPrimaryUrl)} class="btn-primary">{finalPrimaryLabel}</a>
            <a href={toHref(finalSecondaryUrl)} class="btn-white">{finalSecondaryLabel}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .center {
    text-align: center;
    align-items: center;
    display: flex;
    flex-direction: column;
  }

  .hero-section {
    position: relative;
    padding: clamp(4rem, 8vw, 7rem) 0;
    overflow: hidden;
  }
  .hero-bg-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0.4;
    pointer-events: none;
  }
  .hero-container {
    position: relative;
    max-width: 900px;
    text-align: center;
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .hero-title {
    font-size: clamp(2.2rem, 4.5vw, 4rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--text-main);
  }
  .text-gradient {
    background: linear-gradient(135deg, var(--brand), #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc {
    font-size: clamp(1.1rem, 1.5vw, 1.25rem);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 720px;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .step-card {
    background: #fff;
    border-radius: 24px;
    padding: 2rem;
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-soft);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .step-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-brand);
    border-color: rgba(99, 102, 241, 0.3);
  }
  .step-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .step-number {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1;
    color: var(--bg-subtle);
    -webkit-text-stroke: 1.5px rgba(99, 102, 241, 0.3);
  }
  .step-icon-wrap {
    width: 48px; height: 48px;
    border-radius: 12px;
    background: rgba(99, 102, 241, 0.1);
    color: var(--brand);
    display: flex; align-items: center; justify-content: center;
  }
  .step-icon { width: 24px; height: 24px; }
  .step-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .step-desc {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .integration-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .integration-list {
    list-style: none;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .integration-list li {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .int-icon {
    width: 44px; height: 44px;
    border-radius: 10px;
    background: #fff;
    border: 1px solid var(--border-soft);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.04);
    color: var(--text-main);
  }
  .int-icon svg { width: 20px; height: 20px; }
  .integration-list strong {
    display: block;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .integration-list span {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .integration-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mockup-card {
    background: #fff;
    border-radius: 24px;
    border: 1px solid var(--border-soft);
    box-shadow: 0 24px 48px rgba(15, 23, 42, 0.08);
    padding: 1.5rem;
    width: 100%;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mockup-header {
    display: flex; gap: 6px; margin-bottom: 0.5rem;
  }
  .dot {
    width: 12px; height: 12px; border-radius: 50%; background: #e2e8f0;
  }
  .dot:nth-child(1) { background: #fca5a5; }
  .dot:nth-child(2) { background: #fde047; }
  .dot:nth-child(3) { background: #86efac; }

  .chat-bubble {
    padding: 0.75rem 1rem;
    border-radius: 18px;
    font-size: 0.95rem;
    line-height: 1.5;
    max-width: 85%;
  }
  .chat-bubble.left {
    background: #f1f5f9;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .chat-bubble.right {
    background: var(--brand);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  .chat-bubble.system {
    background: rgba(34, 197, 94, 0.1);
    color: #166534;
    align-self: center;
    border-radius: 12px;
    max-width: 100%;
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .chat-bubble.system svg { width: 16px; height: 16px; flex-shrink: 0; }

  .industries-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .industry-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem;
    border: 1px solid var(--border-main);
  }
  .ind-icon-wrap {
    width: 46px; height: 46px;
    border-radius: 12px;
    background: var(--bg-subtle);
    color: var(--brand);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem;
  }
  .ind-icon { width: 22px; height: 22px; }
  .ind-title {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .ind-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .cta-banner {
    position: relative;
    padding: 3.5rem 2rem;
    background: linear-gradient(135deg, var(--brand-dark), var(--brand));
    border-radius: 28px;
    overflow: hidden;
    color: #fff;
    text-align: center;
  }
  .cta-bg-glow {
    position: absolute; inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(255,255,255,0.15), transparent 50%);
  }
  .cta-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .cta-banner h2 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 800;
  }
  .cta-banner p {
    font-size: 1.1rem;
    opacity: 0.9;
    max-width: 600px;
  }
  .cta-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .integration-visual { margin-top: 1rem; }
    .hero-title { font-size: 2.25rem; }
  }
</style>
