---
import Base from '../../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { withBasePath } from '../../lib/urls';

const meta = {
  title: "AI Календарь | Синхронизация записей из чата | Chat Plus",
  description: "Автоматическая запись клиентов из WhatsApp, Telegram и Instagram напрямую в ваш Google Calendar или CRM-систему с помощью AI.",
};

const steps = [
  {
    title: "Клиент пишет в мессенджер",
    desc: "Клиент отправляет сообщение в WhatsApp, Telegram или Instagram с желанием записаться.",
    icon: "lucide:message-circle"
  },
  {
    title: "AI понимает контекст",
    desc: "Нейросеть распознает услугу, желаемое время и специалиста прямо из текста.",
    icon: "lucide:brain"
  },
  {
    title: "Проверка свободного времени",
    desc: "Система мгновенно сверяется с вашим расписанием в Google Calendar или CRM.",
    icon: "lucide:calendar-search"
  },
  {
    title: "Подтверждение записи",
    desc: "AI отправляет клиенту доступные слоты и фиксирует окончательное время.",
    icon: "lucide:calendar-check-2"
  },
  {
    title: "Интеграция в календарь",
    desc: "Событие автоматически создается в вашем календаре со всеми контактными данными.",
    icon: "lucide:database"
  },
  {
    title: "Авто-напоминания",
    desc: "Система сама отправит клиенту напоминание за 24 часа и за час до визита.",
    icon: "lucide:bell-ring"
  }
];

const industries = [
  {
    name: "Салоны красоты",
    desc: "Автоматизация записи на стрижку, маникюр и другие процедуры. Сокращение неявок на 40% благодаря автонапоминаниям.",
    icon: "lucide:scissors"
  },
  {
    name: "Медицина",
    desc: "Запись пациентов к нужным врачам 24/7 без участия администраторов клиники.",
    icon: "lucide:stethoscope"
  },
  {
    name: "HR и Рекрутинг",
    desc: "Планирование собеседований напрямую из переписки с кандидатами.",
    icon: "lucide:users"
  },
  {
    name: "Обучение",
    desc: "Запись на пробные уроки, курсы и консультации прямо из Instagram-директа.",
    icon: "lucide:graduation-cap"
  }
];
const toHref = (href?: string) => withBasePath(href);
---

<Base title={meta.title} description={meta.description}>
  
  <section class="hero-section">
    <div class="hero-bg-dots"></div>
    <div class="container hero-container">
      <div class="hero-content">
        <div class="eyebrow">Флагманская функция Chat Plus</div>
        <h1 class="hero-title">
          <span class="text-gradient">AI Календарь:</span><br/>
          Синхронизация записей из любого чата
        </h1>
        <p class="hero-desc">
          Перестаньте вручную переносить записи из мессенджеров. Наш AI агент читает контекст переписки, сверяется с расписанием и автоматически создает события в вашем календаре.
        </p>
        <div class="hero-actions">
          <a href={toHref('/demo')} class="btn-primary">Попробовать бесплатно</a>
          <a href="#how-it-works" class="btn-outline">Как это работает</a>
        </div>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="section section-tinted">
    <div class="container">
      <div class="section-header center">
        <h2 class="section-title">Магия автоматизации</h2>
        <p class="section-intro center">Как Chat Plus превращает простые сообщения в подтвержденные записи в 6 шагов.</p>
      </div>
      
      <div class="steps-grid">
        {steps.map((step, index) => (
          <div class="step-card">
            <div class="step-header">
              <div class="step-number">{index + 1}</div>
              <div class="step-icon-wrap">
                <Icon name={step.icon} class="step-icon" />
              </div>
            </div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div class="integration-info">
        <h2 class="section-title">Работает с вашим расписанием</h2>
        <p class="section-intro">
          Вам не нужно менять свои привычки или переходить на новую CRM. 
          Наш AI Календарь нативно интегрируется с самыми популярными системами управления временем.
        </p>
        
        <ul class="integration-list">
          <li>
            <div class="int-icon"><Icon name="simple-icons:googlecalendar" /></div>
            <div>
              <strong>Google Calendar</strong>
              <span>Мгновенная двусторонняя синхронизация</span>
            </div>
          </li>
          <li>
            <div class="int-icon"><Icon name="simple-icons:microsoftoutlook" /></div>
            <div>
              <strong>Outlook Calendar</strong>
              <span>Для корпоративных клиентов</span>
            </div>
          </li>
          <li>
            <div class="int-icon"><Icon name="lucide:briefcase" /></div>
            <div>
              <strong>Интеграция с CRM</strong>
              <span>AmoCRM, Altegio, Yclients и другие</span>
            </div>
          </li>
        </ul>
      </div>
      
      <div class="integration-visual">
        <div class="mockup-card">
          <div class="mockup-header">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
          <div class="chat-bubble left">
            Привет! Хочу записаться на маникюр к Анне на пятницу вечером.
          </div>
          <div class="chat-bubble right">
            Здравствуйте! У Анны в эту пятницу есть свободное время в 18:00 и 19:30. Какое время вам удобнее?
          </div>
          <div class="chat-bubble left">
            Давайте на 18:00.
          </div>
          <div class="chat-bubble system">
            <Icon name="lucide:calendar-check-2" />
            Событие &quot;Маникюр — Анна&quot; добавлено в Google Calendar на пятницу, 18:00.
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-tinted">
    <div class="container">
      <div class="section-header center">
        <h2 class="section-title">Идеально для бизнеса услуг</h2>
      </div>
      
      <div class="industries-grid">
        {industries.map(ind => (
          <div class="industry-card">
            <div class="ind-icon-wrap">
              <Icon name={ind.icon} class="ind-icon" />
            </div>
            <h3 class="ind-title">{ind.name}</h3>
            <p class="ind-desc">{ind.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <div class="cta-bg-glow"></div>
        <div class="cta-content">
          <h2>Готовы автоматизировать записи?</h2>
          <p>Постройте бесшовный процесс от первого сообщения до подтвержденного визита.</p>
          <div class="cta-actions">
            <a href={toHref('/demo')} class="btn-primary">Записаться на демо</a>
            <a href={toHref('/pricing')} class="btn-white">Смотреть цены</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Page Specific Layout ── */
  .center {
    text-align: center;
    align-items: center;
    display: flex;
    flex-direction: column;
  }
  
  /* ── Hero ── */
  .hero-section {
    position: relative;
    padding: clamp(4rem, 8vw, 7rem) 0;
    overflow: hidden;
  }
  .hero-bg-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0.4;
    pointer-events: none;
  }
  .hero-container {
    position: relative;
    max-width: 900px;
    text-align: center;
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .hero-title {
    font-size: clamp(2.2rem, 4.5vw, 4rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--text-main);
  }
  .text-gradient {
    background: linear-gradient(135deg, var(--brand), #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc {
    font-size: clamp(1.1rem, 1.5vw, 1.25rem);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 720px;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Steps ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .step-card {
    background: #fff;
    border-radius: 24px;
    padding: 2rem;
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-soft);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .step-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-brand);
    border-color: rgba(99, 102, 241, 0.3);
  }
  .step-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .step-number {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1;
    color: var(--bg-subtle);
    -webkit-text-stroke: 1.5px rgba(99, 102, 241, 0.3);
  }
  .step-icon-wrap {
    width: 48px; height: 48px;
    border-radius: 12px;
    background: rgba(99, 102, 241, 0.1);
    color: var(--brand);
    display: flex; align-items: center; justify-content: center;
  }
  .step-icon { width: 24px; height: 24px; }
  .step-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .step-desc {
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Integration ── */
  .integration-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .integration-list {
    list-style: none;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .integration-list li {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .int-icon {
    width: 44px; height: 44px;
    border-radius: 10px;
    background: #fff;
    border: 1px solid var(--border-soft);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.04);
    color: var(--text-main);
  }
  .int-icon svg { width: 20px; height: 20px; }
  .integration-list strong {
    display: block;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .integration-list span {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  
  /* Mockup Card */
  .integration-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mockup-card {
    background: #fff;
    border-radius: 24px;
    border: 1px solid var(--border-soft);
    box-shadow: 0 24px 48px rgba(15, 23, 42, 0.08);
    padding: 1.5rem;
    width: 100%;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mockup-header {
    display: flex; gap: 6px; margin-bottom: 0.5rem;
  }
  .dot {
    width: 12px; height: 12px; border-radius: 50%; background: #e2e8f0;
  }
  .dot:nth-child(1) { background: #fca5a5; }
  .dot:nth-child(2) { background: #fde047; }
  .dot:nth-child(3) { background: #86efac; }
  
  .chat-bubble {
    padding: 0.75rem 1rem;
    border-radius: 18px;
    font-size: 0.95rem;
    line-height: 1.5;
    max-width: 85%;
  }
  .chat-bubble.left {
    background: #f1f5f9;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .chat-bubble.right {
    background: var(--brand);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  .chat-bubble.system {
    background: rgba(34, 197, 94, 0.1);
    color: #166534;
    align-self: center;
    border-radius: 12px;
    max-width: 100%;
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .chat-bubble.system svg { width: 16px; height: 16px; flex-shrink: 0; }

  /* ── Industries ── */
  .industries-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .industry-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem;
    border: 1px solid var(--border-main);
  }
  .ind-icon-wrap {
    width: 46px; height: 46px;
    border-radius: 12px;
    background: var(--bg-subtle);
    color: var(--brand);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem;
  }
  .ind-icon { width: 22px; height: 22px; }
  .ind-title {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .ind-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* ── CTA Banner ── */
  .cta-banner {
    position: relative;
    padding: 3.5rem 2rem;
    background: linear-gradient(135deg, var(--brand-dark), var(--brand));
    border-radius: 28px;
    overflow: hidden;
    color: #fff;
    text-align: center;
  }
  .cta-bg-glow {
    position: absolute; inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(255,255,255,0.15), transparent 50%);
  }
  .cta-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .cta-banner h2 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 800;
  }
  .cta-banner p {
    font-size: 1.1rem;
    opacity: 0.9;
    max-width: 600px;
  }
  .cta-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Responsive overrides ── */
  @media (max-width: 768px) {
    .integration-visual { margin-top: 1rem; }
    .hero-title { font-size: 2.25rem; }
  }
</style>
