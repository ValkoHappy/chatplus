---
import DirectoryPage from '../../components/DirectoryPage.astro';
import { adaptDirectoryPage } from '../../lib/page-adapters';
import { getFeatures, getManagedRoutePageForLegacyRenderer, getSiteSettings } from '../../lib/strapi';

const page = await getManagedRoutePageForLegacyRenderer('/features', async () => {
  const [settings, features] = await Promise.all([getSiteSettings(), getFeatures()]);
  return adaptDirectoryPage('features', settings, features);
}, 'directory');
---

<DirectoryPage {...page} />
