---
import StructuredLandingPage from '../../components/StructuredLandingPage.astro';
import { getLandingPage } from '../../lib/strapi';

let page;
try {
  page = await getLandingPage('help');
} catch (e) {
  page = {
    meta_title: 'Помощь | Chat Plus',
    meta_description: 'База знаний и поддержка.',
    h1: 'Помощь и поддержка',
    subtitle: 'База знаний скоро будет доступна.'
  };
}
---

<StructuredLandingPage page={page} />
