---
import Base from '../../layouts/Base.astro';

const categories = [
  { emoji: "🚀", title: "Начало работы", articles: ["Как создать аккаунт", "Подключение первого канала", "Настройка команды", "Первый бот"] },
  { emoji: "📱", title: "Каналы", articles: ["WhatsApp Business API", "Telegram подключение", "Instagram Direct", "SMS рассылки"] },
  { emoji: "🤖", title: "AI и автоматизация", articles: ["Настройка AI-агента", "Автозапись в календарь", "Построение воронок", "Триггеры"] },
  { emoji: "🔗", title: "Интеграции", articles: ["AmoCRM интеграция", "Bitrix24 открытые линии", "Google Calendar", "Webhooks"] },
  { emoji: "💳", title: "Тарифы и оплата", articles: ["Выбор тарифа", "Способы оплаты", "Смена тарифа", "Возврат средств"] },
  { emoji: "🔒", title: "Безопасность", articles: ["Двухфакторная аутентификация", "Права доступа", "Экспорт данных", "GDPR и 152-ФЗ"] },
];
---

<Base title="Центр помощи Chat Plus" description="База знаний Chat Plus: ответы на вопросы, инструкции и руководства.">

  <!-- Hero -->
  <section style="background: #f8fafc; padding: 4rem 2rem; text-align: center; border-bottom: 1px solid #e2e8f0;">
    <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem;">Центр помощи</h1>
    <p style="color: #64748b; margin-bottom: 2rem;">Найдите ответ или напишите нам в чат</p>
    <div style="max-width: 500px; margin: 0 auto; position: relative;">
      <input type="text" placeholder="Поиск по базе знаний..." style="width: 100%; padding: 1rem 1.5rem; border: 1px solid #e2e8f0; border-radius: 12px; font-size: 1rem; outline: none;" />
    </div>
  </section>

  <!-- Категории -->
  <section style="padding: 4rem 2rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
        {categories.map(cat => (
          <div style="border: 1px solid #e2e8f0; border-radius: 16px; padding: 1.75rem;">
            <div style="font-size: 2rem; margin-bottom: 0.75rem;">{cat.emoji}</div>
            <h3 style="font-weight: 700; margin-bottom: 1rem;">{cat.title}</h3>
            {cat.articles.map(article => (
              <a href="#" style="display: block; font-size: 0.9rem; color: #6366f1; padding: 0.3rem 0; border-bottom: 1px solid #f1f5f9;">{article} →</a>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
