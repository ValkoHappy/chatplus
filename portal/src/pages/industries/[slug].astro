---
import StructuredLandingPage from '../../components/StructuredLandingPage.astro';
import { adaptIndustryPage } from '../../lib/page-adapters';
import { getChannels, getIndustries, getSiteSettings, getSolutions } from '../../lib/strapi';

export async function getStaticPaths() {
  const industries = await getIndustries();
  return industries.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;
const [settings, channels, industries, solutions] = await Promise.all([
  getSiteSettings(),
  getChannels(),
  getIndustries(),
  getSolutions(),
]);
const page = adaptIndustryPage(industry, { settings, channels, industries, solutions });
---

<StructuredLandingPage page={page} />
