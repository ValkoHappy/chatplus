---
import DirectoryPage from '../../components/DirectoryPage.astro';
import { adaptDirectoryPage } from '../../lib/page-adapters';
import { getIndustries, getManagedRoutePageForLegacyRenderer, getSiteSettings } from '../../lib/strapi';

const page = await getManagedRoutePageForLegacyRenderer('/industries', async () => {
  const [settings, industries] = await Promise.all([getSiteSettings(), getIndustries()]);
  return adaptDirectoryPage('industries', settings, industries);
}, 'directory');
---

<DirectoryPage {...page} />
