---
import Base from '../../layouts/Base.astro';
import ChatIllustration from '../../components/ChatIllustration.astro';

const trustFacts = [
  'Единый inbox для WhatsApp, Telegram, Instagram, Viber и email',
  'AI-ответы и маршрутизация без участия менеджера',
  'Подключение за 15 минут без отдельной разработки',
];

const problems = [
  {
    title: 'Заявки теряются между каналами',
    text: 'Менеджеры прыгают между мессенджерами, часть диалогов остаётся без ответа, а руководитель не видит полную картину.',
  },
  {
    title: 'Ответ приходит слишком поздно',
    text: 'Пока команда разбирает вручную входящие, конкурент отвечает первым и забирает клиента.',
  },
  {
    title: 'CRM остаётся пустой',
    text: 'Данные живут в чатах и телефонах сотрудников, аналитика запаздывает, воронка становится слепой.',
  },
];

const features = [
  {
    title: 'Омниканальный inbox',
    text: 'Все каналы в одном рабочем окне с очередями, приоритетами и единым контекстом диалога.',
    icon: 'inbox',
  },
  {
    title: 'AI first line',
    text: 'Автоответы, квалификация и первичная обработка обращения до подключения менеджера.',
    icon: 'ai',
  },
  {
    title: 'No-code сценарии',
    text: 'Автоворонки, маршрутизация и триггеры без отдельного backend-разработчика.',
    icon: 'flow',
  },
  {
    title: 'CRM-синхронизация',
    text: 'Карточки клиента, статусы и действия менеджера сразу попадают в CRM без ручного ввода.',
    icon: 'crm',
  },
  {
    title: 'Командная работа',
    text: 'SLA, назначения, теги, эскалации и контроль нагрузки на уровне всей поддержки или продаж.',
    icon: 'team',
  },
  {
    title: 'Аналитика',
    text: 'Видны конверсии, каналы, производительность менеджеров и слабые места воронки.',
    icon: 'chart',
  },
];

const metrics = [
  { value: '+35%', label: 'рост конверсии из входящих' },
  { value: '15 мин', label: 'до первого запуска' },
  { value: '0', label: 'потерянных чатов в одном окне' },
];

const comparison = [
  ['Где работает команда', '5 отдельных приложений', 'Один рабочий интерфейс'],
  ['Ответ клиенту', 'Ручной и с задержкой', 'AI + менеджер по SLA'],
  ['Передача в CRM', 'Частично и вручную', 'Автоматически'],
  ['Контроль качества', 'Через ручные отчёты', 'Онлайн-аналитика'],
];
---

<Base
  title="Preview Landing V2"
  description="Предпросмотр нового визуального направления для Chat Plus"
  canonical="https://chatplus.ru/preview/landing-v2"
>
  <section class="preview-hero">
    <div class="hero-noise"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Preview / Landing V2</span>
        <h1>Новый визуальный стиль для продуктовых страниц Chat Plus</h1>
        <p class="hero-text">
          Цель — сделать сайт визуально ближе к сильному SaaS-продукту: меньше ощущения “CMS-секций”, больше
          продуктового интерфейса, иерархии и уверенного первого экрана.
        </p>
        <div class="hero-actions">
          <a href="/demo" class="btn btn-primary">Запросить демо</a>
          <a href="/pricing" class="btn btn-secondary">Сравнить с текущим</a>
        </div>
        <ul class="hero-trust">
          {trustFacts.map((item) => (
            <li>
              <span class="check">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="hero-stage">
        <div class="stage-glow"></div>
        <div class="stage-frame">
          <div class="stage-chips">
            <span>Inbox</span>
            <span>AI</span>
            <span>CRM</span>
          </div>
          <ChatIllustration />
        </div>
        <div class="metric metric-top">
          <strong>+35%</strong>
          <span>конверсия из входящих</span>
        </div>
        <div class="metric metric-bottom">
          <strong>15 мин</strong>
          <span>до первого запуска</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <div class="metrics-grid">
        {metrics.map((item) => (
          <article class="metric-card">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-kicker">Проблема</span>
        <h2>Почему текущие страницы ощущаются слабее, чем должны</h2>
        <p>
          Контент уже нормальный, но визуально он пока не даёт ощущения продукта. Нужно больше глубины, чище
          ритм, сильнее карточки и лучшее разделение секций.
        </p>
      </div>
      <div class="problem-grid">
        {problems.map((item, index) => (
          <article class="problem-card">
            <span class="problem-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="section-head">
        <span class="section-kicker">Подход</span>
        <h2>Что я хочу привнести в боевые шаблоны</h2>
      </div>
      <div class="feature-grid">
        {features.map((item) => (
          <article class="feature-card">
            <div class="feature-head">
              <span class={`feature-icon feature-icon--${item.icon}`}>
                {item.icon === 'inbox' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 12h-5l-2 3H9l-2-3H2" />
                    <path d="M5 5h14l3 7v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-6l3-7Z" />
                  </svg>
                )}
                {item.icon === 'ai' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="8" width="16" height="11" rx="4" />
                    <path d="M12 4v4" />
                    <circle cx="9" cy="13" r="1" />
                    <circle cx="15" cy="13" r="1" />
                  </svg>
                )}
                {item.icon === 'flow' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 7h5v5H6z" />
                    <path d="M13 12h5v5h-5z" />
                    <path d="M11 9h2a2 2 0 0 1 2 2v1" />
                    <path d="M13 17h-2a2 2 0 0 1-2-2v-1" />
                  </svg>
                )}
                {item.icon === 'crm' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="5" width="18" height="14" rx="3" />
                    <path d="M7 11h10" />
                    <path d="M9 15h6" />
                  </svg>
                )}
                {item.icon === 'team' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="9" r="3" />
                    <circle cx="17" cy="8" r="2.5" />
                    <path d="M4.5 18a4.5 4.5 0 0 1 9 0" />
                    <path d="M14 18a3.5 3.5 0 0 1 6.5-1.8" />
                  </svg>
                )}
                {item.icon === 'chart' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 19h16" />
                    <path d="M7 16V9" />
                    <path d="M12 16V5" />
                    <path d="M17 16v-4" />
                  </svg>
                )}
              </span>
              <h3>{item.title}</h3>
            </div>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container compare-shell">
      <div class="compare-copy">
        <span class="section-kicker">Сравнение</span>
        <h2>Как должен ощущаться новый экран</h2>
        <p>
          Визуал должен работать на продуктовую уверенность: показывать интерфейс, цифры, приоритет CTA и
          структурность контента уже в первые секунды.
        </p>
      </div>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Параметр</th>
              <th>Сейчас</th>
              <th>Preview V2</th>
            </tr>
          </thead>
          <tbody>
            {comparison.map((row) => (
              <tr>
                <td>{row[0]}</td>
                <td>{row[1]}</td>
                <td class="accent">{row[2]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-box">
        <div>
          <span class="section-kicker">Следующий шаг</span>
          <h2>Если стиль подходит — переношу его в боевые компоненты</h2>
          <p>После подтверждения применю направление к `StructuredLandingPage.astro` и `DirectoryPage.astro`.</p>
        </div>
        <div class="cta-actions">
          <a href="/preview/directory-v2" class="btn btn-primary">Открыть preview каталога</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  :global(body) {
    background:
      radial-gradient(circle at top left, rgba(99, 102, 241, 0.07), transparent 28%),
      linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  }

  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2rem);
  }

  .section {
    padding: clamp(3.5rem, 8vw, 6rem) 0;
  }

  .section-tight {
    padding-top: 0;
  }

  .section-muted {
    background: linear-gradient(180deg, rgba(99, 102, 241, 0.04), rgba(255, 255, 255, 0));
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .section-head h2 {
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 0.9rem;
    color: #0f172a;
  }

  .section-head p,
  .hero-text,
  .compare-copy p,
  .cta-box p {
    font-size: 1rem;
    line-height: 1.8;
    color: #475569;
  }

  .section-kicker,
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.08);
    color: #4f46e5;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .preview-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(4rem, 8vw, 6.5rem) 0 clamp(3rem, 6vw, 5rem);
  }

  .hero-noise {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 20%, rgba(99, 102, 241, 0.18), transparent 22%),
      radial-gradient(circle at 80% 15%, rgba(14, 165, 233, 0.12), transparent 18%),
      radial-gradient(circle at 60% 80%, rgba(236, 72, 153, 0.1), transparent 16%);
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .hero-copy h1 {
    font-size: clamp(2.4rem, 5vw, 4.25rem);
    line-height: 0.96;
    letter-spacing: -0.055em;
    margin-bottom: 1rem;
    color: #0f172a;
    max-width: 12ch;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
  }

  .hero-actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin: 1.6rem 0 1.8rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.85rem 1.3rem;
    border-radius: 14px;
    font-weight: 700;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: linear-gradient(135deg, #6366f1, #4f46e5);
    color: #fff;
    box-shadow: 0 16px 40px rgba(79, 70, 229, 0.22);
  }

  .btn-primary:hover {
    box-shadow: 0 20px 48px rgba(79, 70, 229, 0.28);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.82);
    color: #0f172a;
    border: 1px solid rgba(148, 163, 184, 0.35);
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    backdrop-filter: blur(10px);
  }

  .hero-trust {
    list-style: none;
    display: grid;
    gap: 0.65rem;
  }

  .hero-trust li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #334155;
    font-size: 0.95rem;
  }

  .check {
    width: 1.4rem;
    height: 1.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    color: #fff;
    font-size: 0.82rem;
    box-shadow: 0 10px 24px rgba(79, 70, 229, 0.24);
  }

  .hero-stage {
    position: relative;
    min-height: 560px;
  }

  .stage-glow {
    position: absolute;
    inset: 10% 3% 8%;
    border-radius: 32px;
    background: radial-gradient(circle at center, rgba(99, 102, 241, 0.2), rgba(99, 102, 241, 0.05) 55%, transparent 72%);
    filter: blur(20px);
  }

  .stage-frame {
    position: relative;
    padding: 1rem;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(226, 232, 240, 0.9);
    backdrop-filter: blur(16px);
    box-shadow:
      0 24px 60px rgba(15, 23, 42, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .stage-chips {
    display: flex;
    gap: 0.55rem;
    margin-bottom: 0.75rem;
    padding-left: 0.35rem;
  }

  .stage-chips span {
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.08);
    color: #4338ca;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .metric {
    position: absolute;
    display: grid;
    gap: 0.2rem;
    padding: 1rem 1.1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(226, 232, 240, 0.9);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
    backdrop-filter: blur(10px);
  }

  .metric strong {
    font-size: 1.35rem;
    color: #0f172a;
    line-height: 1;
  }

  .metric span {
    font-size: 0.82rem;
    color: #64748b;
  }

  .metric-top {
    top: 1rem;
    right: -1rem;
  }

  .metric-bottom {
    left: -1rem;
    bottom: 1.5rem;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .metric-card,
  .problem-card,
  .feature-card,
  .cta-box {
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(226, 232, 240, 0.9);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
    backdrop-filter: blur(10px);
  }

  .metric-card {
    border-radius: 22px;
    padding: 1.3rem 1.4rem;
    display: grid;
    gap: 0.35rem;
  }

  .metric-card strong {
    font-size: clamp(1.45rem, 2.5vw, 2rem);
    color: #0f172a;
    letter-spacing: -0.04em;
  }

  .metric-card span {
    color: #64748b;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .problem-grid,
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .problem-card {
    border-radius: 22px;
    padding: 1.5rem;
  }

  .problem-index {
    display: inline-flex;
    margin-bottom: 1.05rem;
    color: #6366f1;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
  }

  .problem-card h3,
  .feature-card p,
  .cta-box h2 {
    color: #0f172a;
  }

  .problem-card h3 {
    font-size: 1.12rem;
    margin-bottom: 0.75rem;
  }

  .problem-card p {
    color: #475569;
    line-height: 1.7;
  }

  .feature-card {
    border-radius: 20px;
    padding: 1.35rem;
    display: grid;
    gap: 0.9rem;
    align-content: start;
    min-height: 212px;
  }

  .feature-icon {
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
  }

  .feature-icon :global(svg) {
    width: 1.4rem;
    height: 1.4rem;
  }

  .feature-icon--inbox,
  .feature-icon--crm {
    background: linear-gradient(135deg, #eef2ff, #ddd6fe);
    color: #4f46e5;
  }

  .feature-icon--ai,
  .feature-icon--chart {
    background: linear-gradient(135deg, #e0f2fe, #dbeafe);
    color: #0284c7;
  }

  .feature-icon--flow,
  .feature-icon--team {
    background: linear-gradient(135deg, #f5d0fe, #ede9fe);
    color: #9333ea;
  }

  .feature-head {
    display: grid;
    gap: 0.9rem;
  }

  .feature-head h3 {
    color: #0f172a;
    font-size: 1.15rem;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .feature-card p {
    line-height: 1.7;
    color: #334155;
  }

  .compare-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .compare-table-wrap {
    overflow: auto;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(226, 232, 240, 0.9);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 560px;
  }

  .compare-table th,
  .compare-table td {
    padding: 1rem 1.1rem;
    text-align: left;
    border-bottom: 1px solid rgba(226, 232, 240, 0.8);
  }

  .compare-table th {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
    background: rgba(248, 250, 252, 0.9);
  }

  .compare-table td {
    color: #334155;
    line-height: 1.55;
  }

  .compare-table tbody tr:last-child td {
    border-bottom: none;
  }

  .compare-table .accent {
    color: #4338ca;
    font-weight: 700;
  }

  .cta-box {
    border-radius: 28px;
    padding: clamp(1.5rem, 4vw, 2.3rem);
    display: flex;
    justify-content: space-between;
    gap: 1.2rem;
    align-items: center;
  }

  .cta-box h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.08;
    margin: 0.35rem 0 0.65rem;
    letter-spacing: -0.04em;
  }

  .cta-actions {
    flex-shrink: 0;
  }

  @media (max-width: 1100px) {
    .hero-grid,
    .compare-shell {
      grid-template-columns: 1fr;
    }

    .hero-stage {
      min-height: auto;
      max-width: 760px;
    }

    .metric-top {
      right: 0;
    }

    .metric-bottom {
      left: 0;
    }
  }

  @media (max-width: 820px) {
    .metrics-grid,
    .problem-grid,
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: none;
    }

    .cta-box {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }

    .hero-stage {
      display: none;
    }

    .preview-hero {
      padding-top: 3rem;
    }
  }
</style>
