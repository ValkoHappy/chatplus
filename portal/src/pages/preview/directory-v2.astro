---
import Base from '../../layouts/Base.astro';
import DirectoryStackIllustration from '../../components/preview/DirectoryStackIllustration.astro';
import { Icon } from 'astro-icon/components';

const items = [
  {
    title: 'WhatsApp для продаж',
    description: 'Карточка с плотной структурой, нормальной иерархией и сильнее выраженным CTA.',
    tags: ['Sales', 'Popular', 'API'],
    icon: 'simple-icons:whatsapp',
    cta: 'Подключить WhatsApp',
  },
  {
    title: 'Telegram для поддержки',
    description: 'Каталожные страницы должны выглядеть как продуктовые entry points, а не как просто список ссылок.',
    tags: ['Support', 'Bots', 'Inbox'],
    icon: 'simple-icons:telegram',
    cta: 'Подключить Telegram',
  },
  {
    title: 'AmoCRM интеграция',
    description: 'Хочу сделать карточки более “премиальными”: бордер, glow, hover, иконка, метки, нижний action.',
    tags: ['CRM', 'Automation'],
    icon: 'lucide:briefcase-business',
    cta: 'Подключить AmoCRM',
  },
  {
    title: 'Bitrix24 интеграция',
    description: 'Единая дизайн-система для channels, integrations, features и solutions.',
    tags: ['CRM', 'Ops'],
    icon: 'lucide:blocks',
    cta: 'Подключить Bitrix24',
  },
  {
    title: 'AI-ответы',
    description: 'У карточек должен быть ритм, чтобы ими было удобно сканировать большие SEO-каталоги.',
    tags: ['AI', '24/7'],
    icon: 'lucide:bot',
    cta: 'Попробовать AI',
  },
  {
    title: 'No-code сценарии',
    description: 'Нижний блок CTA тоже нужен чище и дороже, без ощущения “приклеенного баннера”.',
    tags: ['Workflows', 'No-code'],
    icon: 'lucide:workflow',
    cta: 'Собрать сценарий',
  },
];
---

<Base
  title="Preview Directory V2"
  description="Предпросмотр нового каталожного стиля для Chat Plus"
  canonical="https://chatplus.ru/preview/directory-v2"
>
  <section class="dir-hero">
    <div class="dir-glow"></div>
    <div class="container">
      <div class="hero-grid">
        <div>
          <span class="eyebrow">Preview / Directory V2</span>
          <h1>Новый стиль каталожных и индексных страниц</h1>
          <p>
            Это вариант того, как могут выглядеть `channels`, `integrations`, `features`, `solutions` и другие
            каталоги после нормальной визуальной шлифовки.
          </p>
          <div class="hero-tags">
            <span>Сильнее визуальная иерархия</span>
            <span>Лучше считываются карточки</span>
            <span>Один язык для всех каталогов</span>
          </div>
        </div>
        <div class="hero-visual">
          <DirectoryStackIllustration />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cards-grid">
        {items.map((item, index) => (
          <article class="item-card">
            <div class="card-top">
              <div class="icon-wrap">
                <Icon name={item.icon} class="card-icon" />
              </div>
              <div>
                <h2>{item.title}</h2>
                <p>{item.description}</p>
              </div>
            </div>
            <div class="tags">
              {item.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
            <div class="card-cta">
              <span>{item.cta}</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="bottom-cta">
        <div>
          <span class="eyebrow">Preview CTA</span>
          <h2>Если этот стиль ок — перенесу его на все каталоговые шаблоны</h2>
          <p>Без изменения структуры Strapi. Меняется только визуальный слой и качество интерфейса.</p>
        </div>
        <a href="/preview/landing-v2" class="cta-button">Вернуться к лендингу</a>
      </div>
    </div>
  </section>
</Base>

<style>
  :global(body) {
    background:
      radial-gradient(circle at top right, rgba(99, 102, 241, 0.06), transparent 26%),
      linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  }

  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2rem);
  }

  .section {
    padding: clamp(3.5rem, 8vw, 5.5rem) 0;
  }

  .section-muted {
    background: linear-gradient(180deg, rgba(99, 102, 241, 0.04), rgba(255, 255, 255, 0));
  }

  .eyebrow {
    display: inline-flex;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.08);
    color: #4f46e5;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .dir-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(4rem, 8vw, 6rem) 0 clamp(2.5rem, 5vw, 4rem);
  }

  .dir-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(99, 102, 241, 0.16), transparent 18%),
      radial-gradient(circle at 80% 10%, rgba(14, 165, 233, 0.1), transparent 16%);
    pointer-events: none;
  }

  .dir-hero .container {
    position: relative;
    max-width: 1180px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 1.5rem;
    align-items: center;
  }

  .hero-visual {
    display: flex;
    justify-content: flex-end;
  }

  .dir-hero h1 {
    font-size: clamp(2.3rem, 5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .dir-hero p,
  .bottom-cta p {
    font-size: 1rem;
    line-height: 1.8;
    color: #475569;
  }

  .hero-tags,
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .hero-tags {
    margin-top: 1.4rem;
  }

  .hero-tags span,
  .tags span {
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(226, 232, 240, 0.9);
    color: #475569;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .item-card,
  .bottom-cta {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(226, 232, 240, 0.9);
    box-shadow: 0 18px 44px rgba(15, 23, 42, 0.07);
    backdrop-filter: blur(10px);
  }

  .item-card {
    border-radius: 24px;
    padding: 1.35rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .item-card:hover {
    border-color: rgba(129, 140, 248, 0.7);
    box-shadow: 0 24px 56px rgba(79, 70, 229, 0.12);
  }

  .card-top {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
  }

  .icon-wrap {
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #eef2ff, #ddd6fe);
    color: #4f46e5;
    flex-shrink: 0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  .card-icon {
    width: 1.35rem;
    height: 1.35rem;
  }

  .card-top h2 {
    font-size: 1.15rem;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: #0f172a;
    margin-bottom: 0.55rem;
  }

  .card-top p {
    color: #475569;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .card-cta {
    margin-top: auto;
    padding-top: 0.4rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #4338ca;
    font-weight: 700;
  }

  .item-card:hover .card-cta svg {
    transform: translateX(3px);
  }

  .card-cta svg {
    transition: transform 0.2s ease;
  }

  .bottom-cta {
    border-radius: 28px;
    padding: clamp(1.5rem, 4vw, 2.2rem);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .bottom-cta h2 {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
    margin: 0.35rem 0 0.7rem;
    color: #0f172a;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.85rem 1.3rem;
    border-radius: 14px;
    background: linear-gradient(135deg, #6366f1, #4f46e5);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 16px 36px rgba(79, 70, 229, 0.22);
    flex-shrink: 0;
  }

  @media (max-width: 920px) {
    .hero-grid,
    .cards-grid {
      grid-template-columns: 1fr 1fr;
    }

    .bottom-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 640px) {
    .hero-grid,
    .cards-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      display: none;
    }

    .cta-button {
      width: 100%;
    }
  }
</style>
