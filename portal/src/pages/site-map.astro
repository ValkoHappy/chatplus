---
import Base from '../layouts/Base.astro';
import { getPageV2ByRouteForLegacyRenderer, getPageV2Pages, getSiteSettings } from '../lib/strapi';
import { getFooterColumns, getSiteMapGroups } from '../lib/navigation';
import { withBasePath } from '../lib/urls';

const pageV2 = await getPageV2ByRouteForLegacyRenderer('/site-map', 'site_map');
const settings = await getSiteSettings();
const pageV2Pages = await getPageV2Pages();
const footerColumns = getFooterColumns(settings.footer_columns, pageV2Pages);
const groups = getSiteMapGroups(footerColumns, pageV2Pages);
const toHref = (href?: string) => withBasePath(href);
const title = pageV2?.metaTitle || 'Карта сайта';
const description =
  pageV2?.metaDescription ||
  'HTML-карта сайта Chat Plus для быстрого перехода по ключевым разделам, ресурсам и специальным страницам.';
const eyebrow = pageV2?.eyebrow || 'Навигация';
const heading = pageV2?.heading || 'Карта сайта';
const subtitle =
  pageV2?.subtitle ||
  'Быстрый доступ к продуктовым разделам, каталогам, ресурсам, страницам компании и специальным маршрутам Chat Plus.';
---

<Base title={title} description={description} canonical={pageV2?.canonical}>
  <section class="site-map-hero">
    <div class="container">
      <p class="site-map-eyebrow">{eyebrow}</p>
      <h1 class="site-map-title">{heading}</h1>
      <p class="site-map-subtitle">{subtitle}</p>
    </div>
  </section>

  <section class="section">
    <div class="container site-map-grid">
      {groups.map((group) => (
        <section class="site-map-group">
          <h2 class="site-map-group-title">{group.title}</h2>
          <div class="site-map-links">
            {group.links.map((link) => (
              <a href={toHref(link.href)} class="site-map-link-card">
                <span class="site-map-link-label">{link.label}</span>
                {link.description && <span class="site-map-link-desc">{link.description}</span>}
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</Base>

<style>
  .site-map-hero {
    padding: clamp(3rem, 7vw, 5rem) 0 clamp(2rem, 5vw, 3rem);
    background: linear-gradient(180deg, #eef2ff 0%, #ffffff 100%);
  }

  .site-map-eyebrow {
    color: #4f46e5;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .site-map-title {
    margin-top: 0.7rem;
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
    color: #0f172a;
  }

  .site-map-subtitle {
    margin-top: 1rem;
    max-width: 760px;
    font-size: 1.02rem;
    line-height: 1.8;
    color: #475569;
  }

  .site-map-grid {
    display: grid;
    gap: 2rem;
  }

  .site-map-group {
    display: grid;
    gap: 1rem;
  }

  .site-map-group-title {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #0f172a;
  }

  .site-map-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .site-map-link-card {
    display: grid;
    gap: 0.45rem;
    min-height: 120px;
    padding: 1.15rem 1.2rem;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(226, 232, 240, 0.95);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 14px 32px rgba(15, 23, 42, 0.05);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .site-map-link-card:hover {
    transform: translateY(-2px);
    border-color: rgba(99, 102, 241, 0.35);
    box-shadow: 0 20px 40px rgba(79, 70, 229, 0.1);
  }

  .site-map-link-label {
    font-size: 1rem;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.02em;
  }

  .site-map-link-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #475569;
  }

  @media (max-width: 768px) {
    .site-map-links {
      grid-template-columns: 1fr;
    }
  }
</style>
