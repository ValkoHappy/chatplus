---
import DirectoryPage from '../../components/DirectoryPage.astro';
import { adaptDirectoryPage } from '../../lib/page-adapters';
import { getIntegrations, getManagedRoutePageForLegacyRenderer, getSiteSettings } from '../../lib/strapi';

const page = await getManagedRoutePageForLegacyRenderer('/integrations', async () => {
  const [settings, integrations] = await Promise.all([getSiteSettings(), getIntegrations()]);
  return adaptDirectoryPage('integrations', settings, integrations);
}, 'directory');
---

<DirectoryPage {...page} />
