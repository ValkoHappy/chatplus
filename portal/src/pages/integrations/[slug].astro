---
import StructuredLandingPage from '../../components/StructuredLandingPage.astro';
import { adaptIntegrationPage } from '../../lib/page-adapters';
import { getChannels, getIntegrations, getPageV2ByRouteForLegacyRenderer, getSiteSettings, getSolutions } from '../../lib/strapi';

export async function getStaticPaths() {
  const integrations = await getIntegrations();
  return integrations.map((integration) => ({
    params: { slug: integration.slug },
    props: { integration },
  }));
}

const { integration } = Astro.props;
const bridgedPage = await getPageV2ByRouteForLegacyRenderer(`/integrations/${integration.slug}`, 'structured');
const [settings, channels, integrations, solutions] = await Promise.all([
  getSiteSettings(),
  getChannels(),
  getIntegrations(),
  getSolutions(),
]);
const page = bridgedPage || adaptIntegrationPage(integration, { settings, channels, integrations, solutions });
---

<StructuredLandingPage page={page} />
