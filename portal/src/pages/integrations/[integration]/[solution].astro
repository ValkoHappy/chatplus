---
import StructuredLandingPage from '../../../components/StructuredLandingPage.astro';
import { adaptIntegrationSolutionPage } from '../../../lib/page-adapters';
import { getIntegrations, getSolutions, getChannels, getPageV2ByRouteForLegacyRenderer, getSiteSettings } from '../../../lib/strapi';

export async function getStaticPaths() {
  const [integrations, solutions] = await Promise.all([getIntegrations(), getSolutions()]);
  return integrations.flatMap((integration) =>
    solutions.map((solution) => ({
      params: { integration: integration.slug, solution: solution.slug },
      props: { integration, solution },
    }))
  );
}

const { integration, solution } = Astro.props;
const bridgedPage = await getPageV2ByRouteForLegacyRenderer(`/integrations/${integration.slug}/${solution.slug}`, 'structured');
const [settings, integrationsList, channels, solutionsList] = await Promise.all([
  getSiteSettings(),
  getIntegrations(),
  getChannels(),
  getSolutions(),
]);
const page = bridgedPage || adaptIntegrationSolutionPage(integration, solution, { settings, integrations: integrationsList, channels, solutions: solutionsList });
---

<StructuredLandingPage page={page} />
