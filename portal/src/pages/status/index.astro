---
import Base from '../../layouts/Base.astro';

const services = [
  { name: "API", status: "operational", uptime: "99.98%" },
  { name: "WhatsApp Gateway", status: "operational", uptime: "99.95%" },
  { name: "Telegram Gateway", status: "operational", uptime: "99.99%" },
  { name: "Dashboard", status: "operational", uptime: "99.97%" },
  { name: "AI-агенты", status: "operational", uptime: "99.94%" },
  { name: "SMS Gateway", status: "operational", uptime: "99.96%" },
  { name: "Webhooks", status: "operational", uptime: "99.99%" },
  { name: "CRM Интеграции", status: "operational", uptime: "99.98%" },
];
---

<Base title="Статус системы Chat Plus" description="Текущий статус всех сервисов Chat Plus. Uptime и инциденты.">

  <section style="padding: 4rem 2rem;">
    <div style="max-width: 700px; margin: 0 auto;">

      <!-- Общий статус -->
      <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 16px; padding: 1.5rem 2rem; display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem;">
        <div style="width: 16px; height: 16px; background: #16a34a; border-radius: 50%; flex-shrink: 0;"></div>
        <div>
          <p style="font-weight: 700; color: #14532d; font-size: 1.1rem;">Все системы работают нормально</p>
          <p style="font-size: 0.85rem; color: #16a34a;">Обновлено: только что</p>
        </div>
      </div>

      <h1 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 2rem;">Статус сервисов</h1>

      <div style="border: 1px solid #e2e8f0; border-radius: 16px; overflow: hidden;">
        {services.map((s, i) => (
          <div style={`display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.5rem; ${i > 0 ? 'border-top: 1px solid #e2e8f0;' : ''}`}>
            <span style="font-weight: 500;">{s.name}</span>
            <div style="display: flex; align-items: center; gap: 1.5rem;">
              <span style="font-size: 0.85rem; color: #64748b;">{s.uptime}</span>
              <span style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: #16a34a; font-weight: 600;">
                <span style="width: 8px; height: 8px; background: #16a34a; border-radius: 50;"></span>
                Работает
              </span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

</Base>
