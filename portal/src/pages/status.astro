---
import Base from '../layouts/Base.astro';
const services = ["API", "WhatsApp интеграция", "Telegram интеграция", "Веб-интерфейс", "База данных", "AI-агенты"];
---
<Base title="Статус сервисов" description="Статус работы Chat Plus в реальном времени.">
  <section style="padding: 4rem 2rem; text-align: center;">
    <div style="font-size: 3rem; margin-bottom: 1rem;">✅</div>
    <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">Все системы работают</h1>
    <p style="color: #64748b;">Uptime 99.9%</p>
  </section>
  <section style="padding: 0 2rem 4rem;">
    <div style="max-width: 700px; margin: 0 auto;">
      {services.map(s => (
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.5rem; border: 1px solid #e2e8f0; border-radius: 10px; margin-bottom: 0.75rem; background: white;">
          <span style="font-weight: 600;">{s}</span>
          <span style="background: #dcfce7; color: #16a34a; padding: 0.3rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">Работает</span>
        </div>
      ))}
    </div>
  </section>
</Base>
