---
import '../styles/global.css';
import '../styles/block-primitives.css';
import { getPageV2Pages, getSiteSettings } from '../lib/strapi';
import { getFooterColumns, getHeaderLinks, getMobileNavSections, isPathActive } from '../lib/navigation';
import { normalizeInternalPath, withBasePath } from '../lib/urls';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  hideGlobalStickyCta?: boolean;
}

const {
  title,
  description,
  image = '/og-image.png',
  canonical,
  hideGlobalStickyCta = false,
} = Astro.props;

const settings = await getSiteSettings();
const site = (Astro.site?.toString() || settings.site_url).replace(/\/$/, '');
const pathname = normalizeInternalPath(Astro.url.pathname);
const isDemoPreview = site.includes('github.io/chatplus');
const finalDescription = description || settings.default_description;
const canonicalURL = (isDemoPreview ? null : canonical) || new URL(pathname, `${site}/`).toString();
const ogImage = /^https?:\/\//.test(image) ? image : `${site}${image.startsWith('/') ? image : `/${image}`}`;
const ogImageType = ogImage.toLowerCase().endsWith('.png')
  ? 'image/png'
  : ogImage.toLowerCase().endsWith('.jpg') || ogImage.toLowerCase().endsWith('.jpeg')
    ? 'image/jpeg'
    : ogImage.toLowerCase().endsWith('.webp')
      ? 'image/webp'
      : ogImage.toLowerCase().endsWith('.svg')
        ? 'image/svg+xml'
        : undefined;
const siteName = settings.site_name?.trim() || 'Chat Plus';
const pageV2Pages = await getPageV2Pages();
const headerLinks = getHeaderLinks(settings.header_links, pageV2Pages);
const footerColumns = getFooterColumns(settings.footer_columns, pageV2Pages);
const mobileNavSections = getMobileNavSections(headerLinks, footerColumns);
const toHref = (href?: string) => withBasePath(href);
const normalizedTitle = (title || '').trim();
const fullTitle = normalizedTitle.endsWith(`| ${siteName}`) || normalizedTitle === siteName
  ? normalizedTitle
  : `${normalizedTitle} | ${siteName}`;

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: settings.site_name,
  url: site,
  logo: `${site}/favicon.svg`,
  description: settings.organization_description || settings.default_description,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    url: `${site}${settings.header_cta_url || '/demo'}`,
  },
});

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: settings.site_name,
  url: site,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${site}/search?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
});
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {import.meta.env.DEV && (
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
  )}
  <title>{fullTitle}</title>
  <meta name="description" content={finalDescription} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalURL} />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={settings.site_name} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={finalDescription} />
  <meta property="og:image" content={ogImage} />
  {ogImageType && <meta property="og:image:type" content={ogImageType} />}
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:alt" content={fullTitle} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="ru_RU" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={finalDescription} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={fullTitle} />

  <link rel="icon" type="image/svg+xml" href={toHref('/favicon.svg')} />
  <link rel="icon" type="image/x-icon" href={toHref('/favicon.ico')} />
  <link rel="apple-touch-icon" href={toHref('/favicon.svg')} />

  <script type="application/ld+json" set:html={orgSchema} />
  <script type="application/ld+json" set:html={websiteSchema} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <slot name="head" />
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <style>
    body {
      background:
        radial-gradient(circle at top left, rgba(99, 102, 241, .06), transparent 20%),
        linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      overflow: visible;
      padding: 0 clamp(1rem, 3vw, 1.6rem);
      border-bottom: 1px solid rgba(226, 232, 240, .94);
      background: rgba(255,255,255,.88);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      box-shadow: 0 12px 28px rgba(15, 23, 42, .04);
    }

    .site-nav {
      max-width: var(--container);
      margin: 0 auto;
      min-height: 72px;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: clamp(1rem, 2vw, 1.35rem);
    }

    .brand-link {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: .75rem;
      padding: .55rem .9rem .55rem .2rem;
      border-radius: 999px;
      flex-shrink: 0;
      color: var(--text-main);
      font-size: 1.12rem;
      font-weight: 800;
      letter-spacing: -.03em;
      transition: transform .18s ease, background .18s ease;
    }

    .brand-link:hover {
      transform: translateY(-1px);
      background: rgba(255, 255, 255, .72);
    }

    .brand-link::before {
      content: '';
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--brand), var(--brand-dark));
      box-shadow: 0 0 0 6px rgba(99, 102, 241, .09);
      flex-shrink: 0;
    }

    .nav-links-wrap {
      display: flex;
      gap: .2rem;
      align-items: center;
      justify-content: center;
      min-width: 0;
      padding: .28rem;
      border-radius: 18px;
      background: rgba(248, 250, 252, .82);
      border: 1px solid rgba(226, 232, 240, .9);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .75);
    }

    .nav-link {
      color: #475569;
      font-size: .94rem;
      font-weight: 600;
      line-height: 1;
      padding: .76rem .9rem;
      border-radius: 14px;
      transition: color .18s ease, background .18s ease, box-shadow .18s ease, transform .18s ease;
    }

    .nav-link:hover {
      color: var(--brand-dark);
      background: rgba(99, 102, 241, .06);
      transform: translateY(-1px);
    }

    .nav-link.is-active {
      color: var(--brand-dark);
      background: linear-gradient(135deg, rgba(99, 102, 241, .12), rgba(79, 70, 229, .08));
      box-shadow: inset 0 0 0 1px rgba(99, 102, 241, .12), 0 8px 20px rgba(99, 102, 241, .08);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: .75rem;
      flex-shrink: 0;
      justify-self: end;
    }

    .header-cta,
    .sticky-cta-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--brand), var(--brand-dark));
      color: #fff;
      font-weight: 700;
      font-size: .9rem;
      white-space: nowrap;
      box-shadow: var(--shadow-brand);
      transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
    }

    .header-cta {
      min-height: 42px;
      padding: .68rem 1.05rem;
      border-radius: 12px;
      font-size: .88rem;
    }

    .sticky-cta-button {
      padding: .62rem 1.15rem;
    }

    .header-cta:hover,
    .sticky-cta-button:hover {
      transform: translateY(-1px);
      filter: saturate(1.05);
      box-shadow: 0 14px 28px rgba(99, 102, 241, .18);
    }

    .nav-toggle {
      display: none;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border: 1px solid var(--border-main);
      border-radius: 12px;
      background: #fff;
      color: var(--text-main);
      cursor: pointer;
      transition: background .18s ease, border-color .18s ease;
    }

    .nav-toggle:hover {
      background: #f8fafc;
      border-color: #cbd5e1;
    }

    .mobile-nav-panel {
      display: none;
    }

    .site-footer {
      margin-top: 0;
      padding: clamp(3.2rem, 6vw, 5.2rem) clamp(1.25rem, 4vw, 2rem) 2rem;
      background:
        radial-gradient(circle at top center, rgba(99, 102, 241, .12), transparent 24%),
        linear-gradient(180deg, rgba(15, 23, 42, .22), transparent 18%),
        #0a0f1e;
      color: var(--text-muted);
    }

    .footer-inner {
      max-width: var(--container);
      margin: 0 auto;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: minmax(240px, 1.15fr) repeat(5, minmax(150px, 1fr));
      gap: 1.5rem clamp(1rem, 2vw, 1.7rem);
      align-items: start;
      margin-bottom: 2.6rem;
    }

    .footer-brand-block,
    .footer-column-card {
      display: grid;
      gap: .95rem;
      min-height: 0;
    }

    .footer-brand-block {
      position: relative;
      padding: .2rem 1.25rem .4rem 0;
      align-content: start;
    }

    .footer-brand-block::after {
      display: none;
    }

    .footer-column-card {
      padding: .25rem 0 0;
      align-content: start;
      border-top: none;
      min-width: 0;
    }

    .footer-brand {
      color: #fff;
      font-weight: 800;
      font-size: 1.55rem;
      letter-spacing: -.03em;
      line-height: 1.02;
      margin-bottom: .2rem;
    }

    .footer-tagline {
      max-width: 300px;
      font-size: .95rem;
      line-height: 1.78;
      color: var(--text-soft);
    }

    .footer-brand-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: fit-content;
      min-height: 40px;
      margin-top: .35rem;
      padding: .7rem 1rem;
      border-radius: 12px;
      background: linear-gradient(135deg, rgba(99, 102, 241, .92), rgba(79, 70, 229, .96));
      color: #fff;
      font-size: .88rem;
      font-weight: 700;
      box-shadow: 0 12px 24px rgba(79, 70, 229, .18);
      transition: transform .18s ease, box-shadow .18s ease;
    }

    .footer-brand-cta:hover {
      transform: translateY(-1px);
      box-shadow: 0 16px 30px rgba(79, 70, 229, .22);
    }

    .footer-title {
      margin-bottom: .45rem;
      color: #e2e8f0;
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .footer-links {
      display: flex;
      flex-direction: column;
      gap: .62rem;
    }

    .footer-link {
      display: block;
      padding: 0;
      margin: 0;
      border-radius: 0;
      color: var(--text-soft);
      font-size: .95rem;
      transition: color .18s ease, transform .18s ease;
    }

    .footer-link:hover {
      color: #fff;
      transform: translateX(2px);
    }

    .footer-link-label {
      color: inherit;
      font-weight: 700;
      line-height: 1.35;
      overflow-wrap: anywhere;
    }

    .footer-bottom {
      border-top: 1px solid rgba(148, 163, 184, .14);
      padding-top: 1.35rem;
      color: #475569;
      font-size: .82rem;
    }

    .footer-bottom-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .footer-meta-links {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .footer-meta-link {
      color: #94a3b8;
      transition: color .18s ease;
    }

    .footer-meta-link:hover {
      color: #fff;
    }

    #sticky-cta {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: .95rem clamp(1rem, 4vw, 2rem);
      background: rgba(10, 15, 30, .88);
      border-top: 1px solid rgba(255,255,255,.08);
      backdrop-filter: blur(14px);
      color: #fff;
      transform: translateY(100%);
      transition: transform .35s cubic-bezier(.4,0,.2,1);
    }

    #sticky-cta.visible {
      transform: translateY(0);
    }

    .sticky-cta-inner {
      width: 100%;
      max-width: var(--container);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .sticky-cta-copy {
      display: grid;
      gap: .2rem;
    }

    .sticky-cta-kicker {
      color: #c7d2fe;
      font-size: .73rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .sticky-cta-text {
      color: var(--text-soft);
      font-size: .9rem;
      font-weight: 500;
      line-height: 1.5;
    }

    .sticky-cta-actions {
      display: flex;
      align-items: center;
      gap: .65rem;
      flex-shrink: 0;
    }

    .sticky-close {
      width: 34px;
      height: 34px;
      border: 0;
      border-radius: 10px;
      background: rgba(255,255,255,.08);
      color: var(--text-soft);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      transition: background .18s ease, color .18s ease;
    }

    .sticky-close:hover {
      background: rgba(255,255,255,.16);
      color: #fff;
    }

    @media (max-width: 1280px) {
      .footer-grid {
        grid-template-columns: minmax(220px, 1.2fr) repeat(3, minmax(180px, 1fr));
      }

      .footer-brand-block {
        grid-column: 1 / -1;
        padding: 0 0 1rem;
        border-bottom: 1px solid rgba(148, 163, 184, .12);
      }

      .footer-brand-block::after {
        display: none;
      }
    }

    @media (max-width: 1024px) {
      .footer-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.1rem 1rem;
      }

      .footer-brand-block {
        grid-column: 1 / -1;
        padding: 0 0 1rem;
        border-bottom: 1px solid rgba(148, 163, 184, .12);
      }

      .footer-column-card {
        padding-top: .35rem;
      }
    }

    @media (max-width: 1140px) {
      .site-nav {
        grid-template-columns: auto 1fr auto;
      }

      .nav-actions {
        margin-left: auto;
        justify-content: flex-end;
      }

      .nav-links-wrap {
        justify-content: flex-start;
        overflow-x: auto;
        scrollbar-width: none;
        background: transparent;
        border: 0;
        box-shadow: none;
        padding: 0;
      }

      .nav-links-wrap::-webkit-scrollbar {
        display: none;
      }
    }

    @media (max-width: 1140px) {
      .nav-links-wrap {
        display: none;
      }

      .nav-toggle {
        display: inline-flex;
        order: 2;
      }

      .header-cta {
        order: 1;
      }

      .mobile-nav-panel {
        position: absolute;
        top: calc(100% + .55rem);
        left: .95rem;
        right: .95rem;
        z-index: 120;
        display: grid;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid var(--border-main);
        border-radius: 22px;
        background: rgba(255,255,255,.98);
        box-shadow: 0 24px 52px rgba(15, 23, 42, .14);
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(-8px);
        transition: opacity .22s ease, transform .22s ease, visibility .22s ease;
      }

      .mobile-nav-panel.open {
        display: grid !important;
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0);
      }

      .mobile-nav-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-height: 46px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--brand), var(--brand-dark));
        color: #fff;
        font-size: .92rem;
        font-weight: 700;
        box-shadow: var(--shadow-brand);
      }

      .mobile-nav-sections {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .9rem;
      }

      .mobile-nav-section {
        display: grid;
        gap: .45rem;
        padding: .8rem;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        background: #f8fafc;
      }

      .mobile-nav-title {
        color: #64748b;
        font-size: .76rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
      }

      .mobile-nav-links {
        display: grid;
        gap: .15rem;
      }

      .mobile-nav-link {
        display: block;
        width: 100%;
        padding: .82rem .95rem;
        border-radius: 12px;
        color: #475569;
        font-size: .95rem;
        font-weight: 600;
        transition: color .18s ease, background .18s ease;
      }

      .mobile-nav-link:hover,
      .mobile-nav-link.is-active {
        color: var(--brand-dark);
        background: rgba(99, 102, 241, .06);
      }

      .sticky-cta-text,
      .sticky-cta-kicker {
        display: none;
      }

      .sticky-cta-inner {
        justify-content: center;
      }
    }

    @media (max-width: 520px) {
      .site-header {
        padding: 0 .9rem;
      }

      .site-nav {
        min-height: 62px;
      }

      .header-cta {
        display: none;
      }

      .footer-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .mobile-nav-panel {
        left: .7rem;
        right: .7rem;
        padding: .85rem;
      }

      .mobile-nav-sections {
        grid-template-columns: 1fr;
      }

      .footer-brand-block {
        padding-right: 0;
      }

      .footer-brand-block::after {
        display: none;
      }

      .footer-bottom-inner {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <header class="site-header" id="site-header">
    <nav class="site-nav">
      <a href={toHref('/')} class="brand-link">{settings.site_name}</a>
      <div class="nav-links-wrap">
        {headerLinks.map((link) => (
          <a href={toHref(link.href)} class:list={['nav-link', { 'is-active': isPathActive(pathname, link.href) }]}>{link.label}</a>
        ))}
      </div>
      <div class="nav-actions">
        <a href={toHref(settings.header_cta_url)} class="header-cta">{settings.header_cta_label}</a>
        <button id="nav-toggle" type="button" class="nav-toggle" aria-label="Меню" aria-controls="mobile-nav" aria-expanded="false">
          <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </nav>
    <div id="mobile-nav" class="mobile-nav-panel">
      <a href={toHref(settings.header_cta_url)} class="mobile-nav-cta">{settings.header_cta_label}</a>
      <div class="mobile-nav-sections">
        {mobileNavSections.map((section) => (
          <section class="mobile-nav-section">
            <p class="mobile-nav-title">{section.title}</p>
            <div class="mobile-nav-links">
              {section.links.map((link) => (
                <a href={toHref(link.href)} class:list={['mobile-nav-link', { 'is-active': isPathActive(pathname, link.href) }]}>{link.label}</a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand-block">
          <p class="footer-brand">{settings.site_name}</p>
          <p class="footer-tagline">{settings.footer_tagline}</p>
          <a href={toHref(settings.header_cta_url)} class="footer-brand-cta">{settings.header_cta_label}</a>
        </div>
        {footerColumns.map((column) => (
          <div class="footer-column-card">
            <p class="footer-title">{column.title}</p>
            <div class="footer-links">
              {column.links.map((link) => (
                <a href={toHref(link.href)} class="footer-link">
                  <span class="footer-link-label">{link.label}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="footer-bottom">
        <div class="footer-bottom-inner">
          <span>{settings.footer_copyright}</span>
          <div class="footer-meta-links">
            <a href={toHref('/site-map')} class="footer-meta-link">Карта сайта</a>
          </div>
        </div>
      </div>
    </div>
  </footer>

  {!hideGlobalStickyCta && (
    <div id="sticky-cta">
      <div class="sticky-cta-inner">
        <div class="sticky-cta-copy">
          <span class="sticky-cta-kicker">Быстрый следующий шаг</span>
          <p class="sticky-cta-text">{settings.sticky_cta_text}</p>
        </div>
        <div class="sticky-cta-actions">
          <a href={toHref(settings.sticky_cta_url)} class="sticky-cta-button">{settings.sticky_cta_label}</a>
          <button id="close-sticky" class="sticky-close" aria-label="Закрыть">&times;</button>
        </div>
      </div>
    </div>
  )}

  <script is:inline>
    (function () {
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('mobile-nav');
      const iconMenu = document.getElementById('icon-menu');
      const iconClose = document.getElementById('icon-close');
      if (!toggle || !menu || !iconMenu || !iconClose) return;

      function openMenu() {
        menu.classList.add('open');
        toggle.setAttribute('aria-expanded', 'true');
        iconMenu.style.display = 'none';
        iconClose.style.display = '';
        document.addEventListener('click', onOutsideClick);
        document.addEventListener('keydown', onEscape);
      }

      function closeMenu() {
        menu.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
        iconMenu.style.display = '';
        iconClose.style.display = 'none';
        document.removeEventListener('click', onOutsideClick);
        document.removeEventListener('keydown', onEscape);
      }

      function onOutsideClick(e) {
        if (!menu.contains(e.target) && !toggle.contains(e.target)) closeMenu();
      }

      function onEscape(e) {
        if (e.key === 'Escape') closeMenu();
      }

      toggle.addEventListener('click', function (e) {
        e.stopPropagation();
        menu.classList.contains('open') ? closeMenu() : openMenu();
      });

      menu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', closeMenu);
      });

      window.addEventListener('resize', function () {
        if (window.innerWidth > 1140) closeMenu();
      }, { passive: true });
    })();

    (function () {
      const bar = document.getElementById('sticky-cta');
      const btn = document.getElementById('close-sticky');
      if (!bar || !btn) return;
      if (sessionStorage.getItem('cta-off')) return;
      const show = () => {
        if (window.scrollY > 400) {
          bar.classList.add('visible');
          window.removeEventListener('scroll', show);
        }
      };
      window.addEventListener('scroll', show, { passive: true });
      btn.addEventListener('click', () => {
        bar.classList.remove('visible');
        sessionStorage.setItem('cta-off', '1');
      });
    })();

    (function () {
      const obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.07 });

      document.querySelectorAll('main section').forEach(function (section, index) {
        if (index === 0) return;
        section.style.opacity = '0';
        section.style.transform = 'translateY(28px)';
        section.style.transition = 'opacity 0.65s ease, transform 0.65s ease';
        obs.observe(section);
      });
    })();

    (function () {
      const els = document.querySelectorAll('[data-count]');
      if (!els.length) return;

      const obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;

          const el = entry.target;
          const target = +el.dataset.count;
          const start = performance.now();
          const duration = 1600;

          function frame(now) {
            const t = Math.min((now - start) / duration, 1);
            const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
            el.textContent = Math.round(ease * target).toLocaleString('ru');
            if (t < 1) requestAnimationFrame(frame);
          }

          requestAnimationFrame(frame);
          obs.unobserve(el);
        });
      }, { threshold: 0.5 });

      els.forEach(function (el) {
        obs.observe(el);
      });
    })();
  </script>
</body>
</html>


