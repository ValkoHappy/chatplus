{
  "kind": "collectionType",
  "collectionName": "competitors",
  "info": {
    "singularName": "competitor",
    "pluralName": "competitors",
    "displayName": "Competitor",
    "description": "Контент страниц /compare/[slug] и /vs/[slug]"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "price": {
      "type": "string",
      "required": true
    },
    "our_price": {
      "type": "string",
      "required": true
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "text"
    },
    "content_origin": {
      "type": "enumeration",
      "enum": [
        "generated",
        "managed"
      ],
      "default": "generated",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "record_mode": {
      "type": "enumeration",
      "enum": [
        "managed",
        "imported",
        "settings"
      ],
      "default": "imported",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "external_id": {
      "type": "string",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "import_batch_id": {
      "type": "string",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "last_imported_at": {
      "type": "datetime",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "sync_strategy": {
      "type": "enumeration",
      "enum": [
        "merge",
        "frozen",
        "system_only"
      ],
      "default": "merge",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "manual_override_fields": {
      "type": "json",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "last_import_diff": {
      "type": "json",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "last_import_payload": {
      "type": "json",
      "private": true,
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "eyebrow": {
      "type": "string"
    },
    "hero_eyebrow": {
      "type": "string"
    },
    "hero_title": {
      "type": "string"
    },
    "hero_description": {
      "type": "text"
    },
    "compare_summary": {
      "type": "text"
    },
    "compare_points": {
      "type": "json"
    },
    "pricing_title": {
      "type": "string"
    },
    "our_price_label": {
      "type": "string"
    },
    "our_price_caption": {
      "type": "string"
    },
    "competitor_price_caption": {
      "type": "string"
    },
    "strengths_title": {
      "type": "string"
    },
    "advantages_title": {
      "type": "string"
    },
    "advantages_intro": {
      "type": "text"
    },
    "weaknesses_title": {
      "type": "string"
    },
    "our_strengths": {
      "type": "json"
    },
    "weaknesses": {
      "type": "json"
    },
    "final_cta_title": {
      "type": "string"
    },
    "final_cta_text": {
      "type": "text"
    },
    "final_cta_label": {
      "type": "string"
    },
    "faq_title": {
      "type": "string"
    },
    "sticky_cta_title": {
      "type": "string"
    },
    "sticky_cta_text": {
      "type": "text"
    },
    "section_labels": {
      "type": "json"
    }
  }
}
