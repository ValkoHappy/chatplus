    "page-v2:local:layout-smoke": "node --env-file=.env scripts/verify-local-layout-markers.mjs --skip-build --keep-approved",
    "page-v2:local:layout-smoke:build": "node --env-file=.env scripts/verify-local-layout-markers.mjs --keep-approved",
    "page-v2:parity-report": "node --env-file=.env --experimental-strip-types scripts/report-page-v2-parity.mjs",
