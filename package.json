    "page-v2:generate:report": "node --env-file=.env scripts/generate-page-v2-drafts.mjs --report",
    "page-v2:live:ready": "node --env-file=.env scripts/check-live-page-v2-readiness.mjs",
    "page-v2:local:audit": "node --env-file=.env scripts/check-local-page-v2-audit.mjs",
    "page-v2:local:cutover-smoke": "node --env-file=.env scripts/smoke-local-page-v2-cutover.mjs",
