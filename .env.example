# Strapi CMS
STRAPI_URL=http://127.0.0.1:1337
STRAPI_TOKEN=your_strapi_api_token_here

# Importer / publish automation
IMPORT_BATCH_ID=
WEBHOOK_TOKEN=replace-with-shared-relay-token
GITHUB_ACTIONS_TOKEN=github_pat_or_actions_token_for_repository_dispatch
GITHUB_REPOSITORY=owner/repo
GITHUB_DISPATCH_EVENT=strapi-content-publish
RELAY_PORT=8787
RELAY_ALLOWED_MODELS=landing-page,page-v2,tenders-page,business-types-page,site-setting,competitor,solution,channel,industry,integration,feature,business-type

# AI content generation
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Transitional VPS deploy
SERVER_HOST=your_server_ip
SERVER_USER=root
SERVER_PATH=/var/www/chatplus
